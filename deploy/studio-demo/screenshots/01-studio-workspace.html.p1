<!DOCTYPE html>
<html lang="en" data-reel-motion>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=1920, height=1080" />
  <title>Li World Studio — workspace (marketing mock)</title>
  <link rel="stylesheet" href="studio-tokens.css" />
  <link rel="stylesheet" href="studio-mock-chrome.css" />
  <link rel="stylesheet" href="studio-reel-motion.css" />  <style>
    * { box-sizing: border-box; }
    body {
      width: 1920px; height: 1080px; margin: 0;
      background: var(--color-bg-primary);
      color: var(--color-text-primary);
      font-family: var(--typography-ui);
      overflow: hidden;
    }
    .mock-banner {
      position: absolute; top: 0; left: 0; right: 0; z-index: 100;
      background: var(--mock-banner-bg, #3d1f00);
      color: #ffdf9e; font-size: 11px; letter-spacing: 0.04em;
      text-align: center; padding: 4px 8px;
      border-bottom: 1px solid var(--color-accent-amber);
    }
    .shell { position: absolute; inset: 24px 0 0 0; }
    .dock {
      position: absolute; left: 0; top: 0; bottom: 0;
      width: var(--shell-left-px);
      background: var(--color-bg-elevated);
      border-right: 1px solid var(--color-border);
      display: flex; flex-direction: column; align-items: center;
      padding: 12px 0; gap: 8px;
    }
    .dock button {
      width: 36px; height: 36px; border: 1px solid var(--color-border);
      border-radius: 6px; background: transparent; color: var(--color-text-muted);
      cursor: pointer;
    }
    .dock button:focus-visible { outline: var(--focus-ring); }
    .dock button.active {
      border-color: var(--color-accent-cyan);
      color: var(--color-accent-cyan);
      box-shadow: inset 0 0 12px rgba(61, 214, 255, 0.15);
    }
    .topbar {
      position: absolute; left: var(--shell-left-px); right: 0; top: 0;
      height: var(--spacing-topbar-height-px);
      background: var(--color-bg-elevated);
      border-bottom: 1px solid var(--color-border);
      display: flex; align-items: center; gap: 16px; padding: 0 16px;
    }
    .profile-chip {
      font-size: 12px; padding: 4px 10px; border-radius: 999px;
      border: 1px solid var(--color-accent-violet); color: var(--color-accent-violet);
    }
    .cmd-hint {
      margin-left: auto; font-size: 12px; color: var(--color-text-muted);
      border: 1px dashed var(--color-border); padding: 6px 12px; border-radius: 6px;
    }
    .viewport {
      position: absolute;
      left: var(--shell-left-px); top: var(--spacing-topbar-height-px);
      right: var(--spacing-inspector-width-px); bottom: 180px;
      background: radial-gradient(circle at 50% 42%, #1a2332, var(--color-bg-primary));
      border-right: 1px solid var(--color-border);
    }
    .viewport-grid {
      position: absolute; inset: 0;
      background-image:
        linear-gradient(var(--color-viewport-grid) 1px, transparent 1px),
        linear-gradient(90deg, var(--color-viewport-grid) 1px, transparent 1px);
      background-size: 48px 48px; opacity: 0.45;
    }
    .hud {
      position: absolute; left: 16px; bottom: 16px;
      font-family: var(--typography-mono); font-size: 11px;
      color: var(--color-accent-mint);
      background: rgba(13, 17, 23, 0.85); padding: 8px 12px;
      border: 1px solid var(--color-border); border-radius: 4px;
    }
    .hud .mock-metric { color: var(--color-text-muted); font-size: 10px; }
    .selection-ring {
      position: absolute; left: 50%; top: 45%; width: 120px; height: 120px;
      transform: translate(-50%, -50%);
      border: 2px solid var(--color-accent-cyan);
      border-radius: 50%; box-shadow: 0 0 24px rgba(61, 214, 255, 0.35);
    }
    .timeline {
      position: absolute;
      left: var(--shell-left-px); right: var(--spacing-inspector-width-px); bottom: 0;
      height: 180px; background: var(--color-bg-elevated);
      border-top: 1px solid var(--color-border); padding: 12px 16px;
    }
    .timeline-track {
      height: 48px; margin-top: 8px; border-radius: 4px;
      background: linear-gradient(90deg, var(--color-border) 1px, transparent 1px);
      background-size: 40px 100%; position: relative;
    }
    .playhead {
      position: absolute; left: 35%; top: 0; bottom: 0; width: 2px;
      background: var(--color-accent-amber);
    }
    .inspector {
      position: absolute; right: 0; top: var(--spacing-topbar-height-px);
      width: var(--spacing-inspector-width-px); bottom: 0;
      background: var(--color-bg-elevated);
      border-left: 1px solid var(--color-border); padding: 16px;
      font-size: 13px;
    }
    .inspector h2 { margin: 0 0 8px; font-size: 14px; }
    .kv { display: grid; grid-template-columns: 100px 1fr; gap: 6px 12px; margin-top: 12px; }
    .kv dt { color: var(--color-text-muted); }
    .agent-strip {
      position: absolute; right: var(--spacing-inspector-width-px); left: var(--shell-left-px);
      bottom: 180px; height: 40px;
      display: flex; align-items: center; gap: 12px; padding: 0 16px;
      background: rgba(22, 27, 34, 0.95);
      border-top: 1px solid var(--color-border);
      font-size: 12px;
    }
    .agent-status {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 4px 10px; border-radius: 4px;
      background: rgba(35, 134, 54, 0.2); color: var(--color-agent-running);
      border: 1px solid var(--color-agent-running);
    }
    .agent-status::before {
      content: ""; width: 8px; height: 8px; border-radius: 50%;
      background: var(--color-agent-running);
      animation: pulse 1.2s ease-in-out infinite;
    }
    @keyframes pulse { 50% { opacity: 0.4; } }
    .agent-cancel {
      margin-left: auto; padding: 4px 12px; border-radius: 4px;
      border: 1px solid var(--color-border); background: transparent;
      color: var(--color-text-primary); cursor: pointer;
    }
    .agent-cancel:focus-visible { outline: var(--focus-ring); }
    .agent-error-strip {
      display: none; width: 100%; margin-top: 4px; padding: 6px 10px;
      border-radius: 4px; font-size: 11px;
      background: rgba(218, 54, 51, 0.15); color: var(--color-agent-error);
      border: 1px solid var(--color-agent-error);
    }
    .agent-strip.is-failed .agent-error-strip { display: block; }
    .agent-strip.is-failed .agent-status {
      background: rgba(218, 54, 51, 0.2); color: var(--color-agent-error);
      border-color: var(--color-agent-error);
    }
    .agent-strip.is-failed .agent-status::before { background: var(--color-agent-error); animation: none; }
    .empty-hint {
      margin-top: 16px; padding: 12px; border-radius: 6px;
      border: 1px dashed var(--color-border); color: var(--color-text-muted);
      font-size: 12px;
    }
  </style>
</head>
<body>
  <div class="mock-banner" role="note">MARKETING MOCK — HTML preview only; native Li Studio uses li-ui/li-gui</div>
  <div class="shell">
    <nav class="dock" aria-label="Tools">
      <div class="dock-item"><button type="button" class="active" title="Select" aria-label="Select">◇</button><span class="dock-label">Select</span></div>
      <div class="dock-item"><button type="button" title="Move" aria-label="Move">✥</button>
      <button type="button" title="Measure" aria-label="Measure">📐</button>
    </nav>
    <aside class="outliner" aria-label="Scene hierarchy">
      <h2>Outliner</h2>
      <ul class="outliner-tree">
        <li class="outliner-node">Scene</li>
        <li class="outliner-node outliner-node--child">Binding site</li>
        <li class="outliner-node outliner-node--child is-selected" aria-current="true">Molecule A</li>
        <li class="outliner-node outliner-node--child">Solvent box</li>
      </ul>
    </aside>
    <header class="topbar">
      <strong>Li World Studio</strong>
      <span class="profile-chip">Drug design</span>
      <span class="cmd-hint" tabindex="0">⌘K Command palette</span>
    </header>
    <main class="viewport" aria-label="3D viewport">
      <div class="viewport-grid" aria-hidden="true"></div>
      <div class="selection-ring" aria-hidden="true"></div>
      <div class="hud">
        <div>FPS: <strong>60</strong> (bench simulate — no native pixels)</div>
        <div>Particles: <strong>10,000</strong> (display tier)</div>
        <div class="mock-metric">wgpu smoke stub_pass · li-render FPS hook · surface_ok=false</div>
      </div>
    </main>
    <aside class="agent-strip" aria-label="Agent copilot">
      <span class="agent-status">Running · Optimize binding pose</span>
      <span>Last: placed water molecule at site A</span>
      <button type="button" class="agent-cancel">Cancel</button>
    </aside>
    <section class="timeline" aria-label="Timeline">
      <div style="display:flex;justify-content:space-between;align-items:center;">
        <strong>Timeline</strong>
        <span style="font-size:12px;color:var(--color-text-muted);">Frame 142 / 480 · 24 fps</span>
      </div>
      <div class="timeline-track"><div class="playhead"></div></div>
    </section>
    <aside class="inspector" aria-label="Inspector">
      <h2>Inspector</h2>
      <p>Selection: <strong>Molecule A</strong></p>
      <dl class="kv">
        <dt>Atoms</dt><dd>48</dd>
        <dt>Force field</dt><dd>AMBER ff14SB</dd>
        <dt>Charge</dt><dd>0.0 e</dd>
      </dl>
      <div class="empty-hint">Select a bond or atom to edit constraints. No GPU error.</div>
    </aside>
  </div>
</body>
  <script src="studio-reel-motion.js"></script></html>
