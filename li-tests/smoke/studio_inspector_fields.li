import studio

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if li_std_studio_version() < 6:
    return 1
  var layout: StudioShellLayout = layout_studio_shell_adaptive(1280.0, 720.0)
  var insp: StudioInspectorCompose = studio_compose_inspector_selected(layout)
  if insp.has_selection != 1:
    return 2
  if insp.field_count < 2:
    return 3
  if insp.widget_pilot == 1:
    if insp.field0.label_rect.w <= 0.0:
      return 4
  if insp.widget_pilot != 1:
    if insp.field0.label_rect.w != studio_inspector_field_label_width_px():
      return 4
  if insp.field1.value_rect.w <= 0.0:
    return 5
  var shell: StudioShellCompose = studio_compose_shell(1280.0, 720.0, 0, 1, 1)
  if shell.inspector.field_count < 2:
    return 6
  return 0
