import studio
import ui

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if li_std_studio_version() < 6:
    return 1
  if li_std_ui_version() < 7:
    return 2
  var layout: StudioShellLayout = layout_studio_shell_adaptive(1280.0, 720.0)
  var compose: StudioShellCompose = studio_compose_shell(1280.0, 720.0, 0, 0, 0)
  var topbar_frame: PaintFrame = paint_frame_new()
  studio_paint_topbar_profile(topbar_frame, layout.topbar, studio_profile_game())
  if topbar_frame.last_kind != paint_op_draw_glyphs():
    return 3
  if text_layout_rect_inside(topbar_frame.last_rect, layout.topbar, 1.0) != 1:
    return 4
  var dock_frame: PaintFrame = paint_frame_new()
  studio_paint_dock(dock_frame, compose.dock)
  if dock_frame.last_kind != paint_op_draw_glyphs():
    return 5
  if text_layout_rect_inside(dock_frame.last_rect, compose.dock.rect, 2.0) != 1:
    return 6
  var outliner_frame: PaintFrame = paint_frame_new()
  studio_paint_outliner(outliner_frame, compose.outliner, compose.hover)
  if outliner_frame.last_kind != paint_op_draw_glyphs():
    return 7
  if text_layout_rect_inside(outliner_frame.last_rect, compose.outliner.rect, 2.0) != 1:
    return 8
  var chip: Rect = studio_profile_chip_rect_at(layout.topbar.x, layout.topbar.y, layout.topbar.w, layout.topbar.h, studio_profile_game())
  var glyph_dest: Rect = studio_paint_glyph_text_rect(chip, studio_profile_label_glyph_count(studio_profile_game()))
  if text_layout_rect_inside(glyph_dest, chip, 1.0) != 1:
    return 9
  return 0
