import sim
import studio

# WP-GD-02 — WorldSnapshot validity after studio_sim_step_hook + shell timeline cache.

def main() raises Alloc, IO -> int
  requires true
  ensures result == 0
  decreases 0
=
  var cfg: StudioProjectConfig = studio_project_config_new(studio_profile_game())
  var sess: SimSessionStub = sim_session_stub_default()
  if studio_sim_step_hook(cfg, sess, 0.016) != sim_status_ok():
    return 10
  if studio_world_checkpoint_after_sim_tick(studio_profile_game(), sess) != sim_status_ok():
    return 11
  var snap: WorldSnapshot = studio_game_world_checkpoint_from_session(sess)
  if studio_game_world_checkpoint_stub(snap) != 1:
    return 12
  if snap.tick != sess.tick:
    return 13
  if studio_game_world_checkpoint_roundtrip(sess) != 1:
    return 14
  var shell: StudioShellCompose = studio_compose_shell_profile(1280.0, 720.0, 0, 0, studio_profile_game())
  if shell.world_checkpoint.valid != 0:
    return 15
  var duration: int = studio_timeline_duration_ticks_default()
  studio_apply_config_to_sim(cfg, sess)
  if studio_timeline_reset_for_session(sess, duration) != 0:
    return 16
  if studio_timeline_toggle_play() != 1:
    return 17
  if studio_shell_timeline_tick_sim_step(shell, cfg, sess, 0.016, duration) != 1:
    return 18
  if shell.world_checkpoint.valid != 1:
    return 19
  if shell.world_checkpoint.tick != sess.tick:
    return 20
  if shell.world_checkpoint.entity_count != studio_game_entity_count_stub():
    return 21
  return 0
