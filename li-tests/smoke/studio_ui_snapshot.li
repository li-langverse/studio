import studio

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if li_std_studio_version() < 50:
    return 1
  if studio_ui_snapshot_version() != 1:
    return 2
  var shell: StudioShellCompose = studio_compose_shell(1280.0, 720.0, 0, 1, 1)
  var snap: UiSnapshot = studio_ui_snapshot_from_compose(shell, 0)
  if snap.element_count < 18:
    return 3
  if ui_snapshot_element_find_by_tag(snap, ui_snapshot_tag_topbar_profile_chip()) < 0:
    return 4
  if ui_snapshot_element_find_by_tag(snap, ui_snapshot_tag_agent_send_button()) < 0:
    return 5
  return 0
