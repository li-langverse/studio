import studio
import ui

def main() -> int raises IO
  requires true
  ensures result == 0
  decreases 0
=
  if li_std_studio_version() < 48:
    return 1
  if studio_viewport_overlay_scrim_alpha() != 0.55:
    return 2
  if studio_paint_viewport_chip_cmds() != 3:
    return 3
  if studio_paint_viewport_error_cmds() != 10:
    return 4
  if studio_paint_viewport_empty_cmds() != 10:
    return 5
  if studio_paint_viewport_menu_btn_cmds() != 3:
    return 6
  var layout: StudioShellLayout = layout_studio_shell_adaptive(1280.0, 720.0)
  var overlay: StudioViewportErrorOverlay = studio_compose_viewport_error_overlay(layout, studio_err_gpu())
  var err_frame: PaintFrame = paint_frame_new()
  studio_paint_viewport_error(err_frame, overlay)
  if err_frame.cmd_count != studio_paint_viewport_error_cmds():
    return 7
  if err_frame.last_kind != paint_op_draw_glyphs():
    return 8
  var empty_shell: StudioShellCompose = studio_compose_shell(1280.0, 720.0, 0, 0, 0)
  var empty_frame: PaintFrame = paint_frame_new()
  studio_paint_viewport_empty(empty_frame, empty_shell.viewport_empty)
  if empty_frame.cmd_count != studio_paint_viewport_empty_cmds():
    return 9
  if empty_frame.last_kind != paint_op_draw_glyphs():
    return 10
  var drug: StudioShellCompose = studio_compose_shell_drug_litl(1280.0, 720.0, 2, 1)
  drug.scene_entity_count = 1
  drug.viewport_empty.empty_visible = 0
  studio_attach_viewport_shell(drug)
  var vp_frame: PaintFrame = paint_frame_new()
  studio_paint_viewport_display(vp_frame, drug.layout.viewport, drug.viewport_display)
  if vp_frame.last_kind != paint_op_draw_glyphs():
    return 11
  var menu_frame: PaintFrame = paint_frame_new()
  studio_paint_viewport_menu(menu_frame, drug.viewport_menu)
  if menu_frame.cmd_count != studio_paint_viewport_menu_cmds(drug.viewport_menu):
    return 12
  if menu_frame.last_kind != paint_op_draw_glyphs():
    return 13
  return 0
