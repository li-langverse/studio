import studio

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if li_std_studio_version() < 50:
    return 1
  var shell: StudioShellCompose = studio_compose_shell(1280.0, 720.0, 0, 0, 0)
  if studio_ui_click_tag(shell, ui_snapshot_tag_dock_slot_1()) != 1:
    return 2
  if shell.dock.active_slot != 1:
    return 3
  if studio_ui_key_tag(shell, studio_ui_key_tag_cmd_k()) != studio_key_action_palette_toggle():
    return 4
  if shell.palette.is_open != studio_palette_open_flag():
    return 5
  return 0
