import studio

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if li_std_studio_version() < 6:
    return 1
  studio_timeline_reset_mock()
  if studio_timeline_playing() != 0:
    return 2
  var pct0: float = studio_timeline_playhead_pct()
  if studio_timeline_toggle_play() != 1:
    return 3
  if studio_timeline_playing() != 1:
    return 4
  if studio_timeline_tick_frame() != 1:
    return 5
  var pct1: float = studio_timeline_playhead_pct()
  if pct1 <= pct0:
    return 6
  var layout: StudioShellLayout = layout_studio_shell_adaptive(1280.0, 720.0)
  var timeline: StudioTimelineCompose = studio_compose_timeline(layout)
  if timeline.play_btn_rect.w != studio_timeline_play_btn_size_px():
    return 7
  if timeline.playhead_pct != studio_timeline_playhead_pct():
    return 8
  return 0
