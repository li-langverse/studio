import studio

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if li_std_studio_version() < 16:
    return 1
  var layout: StudioShellLayout = layout_studio_shell_adaptive(1280.0, 720.0)
  var idle: StudioAgentChromeCompose = studio_compose_agent_chrome(layout, studio_agent_task_idle(), studio_agent_context_none())
  if idle.invoke_input_visible != 1:
    return 2
  if studio_paint_agent_cmds(studio_agent_task_idle(), studio_agent_context_none(), 1, 0) != 6:
    return 3
  var tool: StudioAgentToolRequest = studio_agent_tool_request_none()
  tool.tool_id = studio_mcp_lic_build()
  var running: StudioAgentChromeCompose = studio_compose_agent_chrome_with_tool(layout, studio_agent_task_running(), studio_agent_context_world(), tool)
  if running.tool_trace_visible != 1:
    return 4
  return 0
