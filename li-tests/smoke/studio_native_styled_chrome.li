import studio
import ui

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if li_std_studio_version() < 6:
    return 1
  if li_std_ui_version() < 5:
    return 2
  if paint_op_kind_max() != paint_op_fill_gradient():
    return 3
  var compose: StudioShellCompose = studio_compose_shell_palette(1280.0, 720.0, 0, 1, studio_palette_closed_flag())
  var dock: StudioDockCompose = compose.dock
  var dframe: PaintFrame = paint_frame_new()
  studio_paint_dock(dframe, dock)
  if dframe.last_kind != paint_op_draw_glyphs():
    return 4
  if studio_paint_dock_cmds() != 20:
    return 7
  if dframe.cmd_count != studio_paint_dock_cmds():
    return 10
  var timeline: StudioTimelineCompose = compose.timeline
  var tframe: PaintFrame = paint_frame_new()
  studio_paint_timeline(tframe, timeline)
  if tframe.last_kind != paint_op_stroke_round_rect():
    return 5
  var shell_frame: PaintFrame = paint_frame_new()
  studio_paint_shell_chrome(shell_frame, compose)
  if shell_frame.cmd_count < studio_paint_dock_cmds():
    return 6
  return 0
