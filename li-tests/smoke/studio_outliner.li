import studio

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if li_std_studio_version() < 6:
    return 1
  var layout: StudioShellLayout = layout_studio_shell_adaptive(1280.0, 720.0)
  var outliner: StudioOutlinerCompose = studio_compose_outliner(layout.dock, 0)
  if outliner.node_count != studio_outliner_demo_node_count():
    return 2
  if outliner.node_count > studio_outliner_max_nodes():
    return 3
  if outliner.selected_node != studio_outliner_selected_demo():
    return 4
  if outliner.node0.label_id != studio_outliner_label_root():
    return 5
  if outliner.node1.label_id != studio_outliner_label_camera():
    return 6
  if outliner.node2.label_id != studio_outliner_label_mesh():
    return 7
  if outliner.row0_rect.h != studio_outliner_row_height_px():
    return 8
  var compose: StudioShellCompose = studio_compose_shell(1920.0, 1080.0, 1, 1, 1)
  if compose.outliner.node_count != studio_outliner_demo_node_count():
    return 9
  if studio_paint_outliner_cmds(outliner.node_count) != 8:
    return 10
  var frame: PaintFrame = paint_frame_new()
  studio_paint_outliner(frame, compose.outliner)
  if frame.cmd_count != 8:
    return 11
  if frame.last_kind != paint_op_draw_glyphs():
    return 12
  return 0
