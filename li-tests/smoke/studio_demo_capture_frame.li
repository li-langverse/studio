import studio

def main() -> int raises IO, Alloc
  requires true
  ensures result == 0
  decreases 0
=
  if li_std_studio_version() < 50:
    return 1
  var shell: StudioShellCompose = studio_compose_shell(1280.0, 720.0, 0, 1, 1)
  var cap: int = studio_demo_capture_frame(shell, "build/demo-recorder/capture-smoke.ppm", 1280, 720)
  if cap != 1:
    return 2
  return 0
