import studio

# wsg-w5-installer-ci — Windows + Linux installer CI matrix (Inno + AppImage wiring).
def main() -> int raises IO
  requires true
  ensures result == 0
  decreases 0
=
  if li_std_studio_version() < 38:
    return 1
  if studio_installer_ci_version() != 1:
    return 2
  if studio_installer_ci_smoke() != 0:
    return 3
  return 0
