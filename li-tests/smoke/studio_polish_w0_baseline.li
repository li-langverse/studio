import studio

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if li_std_studio_version() < 40:
    return 1
  if studio_paint_topbar_profile_cmds() != 3:
    return 2
  if studio_paint_outliner_row_cmds() != 2:
    return 3
  var frame: PaintFrame = studio_shell_frame(640.0, 360.0)
  if frame.cmd_count < studio_paint_dock_cmds():
    return 4
  return 0
