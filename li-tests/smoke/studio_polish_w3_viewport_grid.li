import studio
import ui

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if li_std_studio_version() < 43:
    return 1
  if studio_paint_viewport_grid_cmds() != 5:
    return 2
  if studio_viewport_grid_major_spacing_px() != 64.0:
    return 3
  if font_atlas_codepoint_supported(studio_viewport_hud_grid_label_first_codepoint()) != 1:
    return 4
  if studio_paint_viewport_hud_cmds() != 12:
    return 5
  var sci: StudioShellCompose = studio_compose_shell_profile(1280.0, 720.0, 0, 1, studio_profile_sim_scientific())
  sci.scene_entity_count = 1
  sci.viewport_empty.empty_visible = 0
  studio_attach_viewport_shell(sci)
  if sci.viewport_display.background != studio_viewport_bg_grid():
    return 6
  if sci.viewport_display.grid_legend_rect.w != 56.0:
    return 7
  var grid_frame: PaintFrame = paint_frame_new()
  studio_paint_viewport_grid(grid_frame, sci.layout.viewport)
  if grid_frame.cmd_count != studio_paint_viewport_grid_cmds():
    return 8
  if grid_frame.last_kind != paint_op_stroke_round_rect():
    return 9
  var shell_frame: PaintFrame = paint_frame_new()
  studio_paint_shell_chrome(shell_frame, sci)
  if shell_frame.cmd_count != studio_shell_chrome_count_for_compose(sci):
    return 10
  return 0
