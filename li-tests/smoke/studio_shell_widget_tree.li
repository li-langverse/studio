import studio

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if li_std_studio_version() < 36:
    return 1
  if studio_shell_widget_tree_version() != 1:
    return 2
  var shell: StudioShellCompose = studio_compose_shell(1280.0, 720.0, 0, 1, 1)
  if shell.widget_tree_active != 1:
    return 3
  if shell.widget_tree.region_count != shell_widget_tree_region_count():
    return 4
  if shell_widget_tree_all_regions_laid_out(shell.widget_tree_layout) != 1:
    return 5
  return 0
