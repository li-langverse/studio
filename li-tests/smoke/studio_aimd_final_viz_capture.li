import sim.scientific
import studio

extern proc li_rt_studio_aimd_scenario_reset() -> int
  requires true
  ensures result >= 0
  decreases 0

extern proc li_rt_studio_aimd_batch_steps_from_env() -> int
  requires true
  ensures result >= 64
  decreases 0

extern proc li_rt_studio_aimd_batch_write_json(path: str, steps: int, ok: int, checksum: float, energy_drift: float, gpu_path: int, dft_stride: int, dft_calls: int) -> int raises IO
  requires true
  ensures result >= 0
  ensures result <= 1
  decreases steps

def main() -> int raises IO, Alloc
  requires true
  ensures result == 0
  decreases 0
=
  if li_rt_studio_aimd_scenario_reset() != 0:
    return 1
  var steps: int = li_rt_studio_aimd_batch_steps_from_env()
  if echem_aimd_batch_steps_valid(steps) != 1:
    return 2
  if studio_aimd_hero_configure(steps, 300, 0, studio_aimd_algo_echem_interface()) != 1:
    return 3
  var batch: AimdBatchResult = echem_aimd_batch_run(steps)
  if batch.ok != 1:
    return 4
  if batch.checksum_ok != 1:
    return 5
  if li_rt_studio_aimd_batch_write_json("build/aimd-demo/out/batch-result.json", batch.steps, batch.ok, batch.checksum, batch.energy_drift, batch.gpu_path, batch.dft_stride, batch.dft_calls) != 1:
    return 6
  if studio_aimd_final_viz_ok(batch, "build/aimd-demo/out/final-frame.ppm", 1280, 720) != 1:
    return 7
  return 0
