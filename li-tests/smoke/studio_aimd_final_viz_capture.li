import sim.scientific
import studio

extern proc li_rt_studio_aimd_batch_steps_from_env() -> int
  requires true
  ensures result >= 64
  decreases 0

def main() -> int raises IO, Alloc
  requires true
  ensures result == 0
  decreases 0
=
  var steps: int = li_rt_studio_aimd_batch_steps_from_env()
  if echem_aimd_batch_steps_valid(steps) != 1:
    steps = echem_aimd_batch_demo_steps()
  var batch: AimdBatchResult = echem_aimd_batch_run(steps)
  if batch.ok != 1:
    return 1
  var path: str = "build/aimd-demo/out/final-frame.ppm"
  if studio_aimd_final_viz_ok(batch, path, 1280, 720) != 1:
    return 2
  return 0
