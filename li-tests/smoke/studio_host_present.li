import studio

def main() -> int raises IO
  requires true
  ensures result == 0
  decreases 0
=
  if li_std_studio_version() < 6:
    return 1
  if li_std_lig_present_version() < 1:
    return 2
  var compose: StudioShellCompose = studio_compose_shell(1280.0, 720.0, 0, 0, 0)
  var r: int = studio_shell_host_frame(compose, 0)
  if r != 0:
    return 3
  var input: InputState = studio_shell_input_from_host()
  if input.key_digit < 0:
    return 4
  return 0
