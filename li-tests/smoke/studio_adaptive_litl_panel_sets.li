import studio

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if li_std_studio_version() < 28:
    return 1
  var hyp: int = drug_litl_stage_hypothesis()
  var gen: int = drug_litl_stage_generate()
  var dft: int = drug_litl_stage_dft()
  var lab: int = drug_litl_stage_lab()
  var retrain: int = drug_litl_stage_retrain()
  if studio_adaptive_panel_region_for_litl_stage(hyp) != studio_region_inspector():
    return 2
  if studio_adaptive_panel_region_for_litl_stage(gen) != studio_region_viewport():
    return 3
  if studio_adaptive_panel_region_for_litl_stage(dft) != studio_region_inspector():
    return 4
  if studio_adaptive_panel_region_for_litl_stage(lab) != studio_region_timeline():
    return 5
  if studio_adaptive_panel_region_for_litl_stage(retrain) != studio_region_agent_strip():
    return 6
  var shell0: StudioShellCompose = studio_compose_shell_drug_litl(1280.0, 720.0, 0, 1)
  if shell0.panel.active_region != studio_region_inspector():
    return 7
  if shell0.inspector.field_rows != studio_drug_litl_inspector_field_rows(hyp):
    return 8
  var shell3: StudioShellCompose = studio_compose_shell_drug_litl(1280.0, 720.0, 3, 1)
  if shell3.panel.active_region != studio_region_timeline():
    return 9
  if studio_adaptive_panel_set_id(lab) != lab:
    return 10
  var mcp: StudioAgentToolRequest = studio_mcp_tool_dispatch_arg(studio_mcp_studio_adaptive_layout(), lab)
  if mcp.status != studio_mcp_tool_status_ok():
    return 11
  if mcp.result_code != lab:
    return 12
  return 0
