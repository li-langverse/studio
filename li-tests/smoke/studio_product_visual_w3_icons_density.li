import studio
import ui

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if li_std_studio_version() < 47:
    return 1
  if studio_density_dock_slot_size_px() != 32.0:
    return 2
  if studio_dock_slot_gap_px() != studio_spacing_unit_px():
    return 3
  if studio_dock_padding_px() != studio_spacing_rhythm_px():
    return 4
  if studio_paint_topbar_tool_cmds() != 4:
    return 5
  if studio_paint_timeline_cmds() != 10:
    return 6
  var slot: Rect = rect_make(0.0, 0.0, studio_dock_slot_size_px(), studio_dock_slot_size_px())
  var icon: Rect = studio_dock_icon_content_rect(slot)
  if icon.w != slot.w - studio_density_dock_icon_inset_px() * 2.0:
    return 7
  var shell: StudioShellCompose = studio_compose_shell(1280.0, 720.0, 1, 1, 1)
  var top: PaintFrame = paint_frame_new()
  studio_paint_topbar_tools(top, shell.layout.topbar)
  if top.cmd_count != studio_paint_topbar_tool_cmds():
    return 8
  if top.last_kind != paint_op_draw_image():
    return 9
  var tl: PaintFrame = paint_frame_new()
  studio_paint_timeline(tl, shell.timeline, shell.hover, shell.motion)
  if tl.cmd_count != studio_paint_timeline_cmds():
    return 10
  if tl.last_kind != paint_op_draw_image():
    return 11
  return 0
