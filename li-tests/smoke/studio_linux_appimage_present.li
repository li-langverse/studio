import studio

# wsg-w5-linux-appimage — Linux AppDir/AppImage with bundled SDL + wgpu env.
def main() -> int raises IO
  requires true
  ensures result == 0
  decreases 0
=
  if li_std_studio_version() < 38:
    return 1
  if studio_linux_appimage_version() != 1:
    return 2
  if studio_c_host_slim_version() != 1:
    return 3
  if studio_present_loop_raster_version() != 1:
    return 4
  return 0
