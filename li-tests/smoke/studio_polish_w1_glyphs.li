import studio

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if li_std_studio_version() < 40:
    return 1
  if studio_paint_glyph_pipeline_ok() != 1:
    return 2
  if studio_paint_dock_cmds() != 13:
    return 3
  if studio_paint_viewport_hud_cmds() != 9:
    return 4
  if studio_paint_inspector_field_glyph_cmds() != 4:
    return 5
  var dock_frame: PaintFrame = paint_frame_new()
  var compose: StudioShellCompose = studio_compose_shell(1280.0, 720.0, 1, 1, 1)
  studio_paint_dock(dock_frame, compose.dock)
  if dock_frame.cmd_count != studio_paint_dock_cmds():
    return 6
  if dock_frame.last_kind != paint_op_draw_glyphs():
    return 7
  var drug: StudioShellCompose = studio_compose_shell_drug_litl(1280.0, 720.0, 2, 1)
  if studio_inspector_uses_drug_litl_labels(drug.inspector.field_rows) != 1:
    return 8
  var insp_frame: PaintFrame = paint_frame_new()
  studio_paint_inspector(insp_frame, drug.inspector)
  if insp_frame.cmd_count != studio_paint_inspector_selected_cmds():
    return 9
  var sci: StudioShellCompose = studio_compose_shell_profile(1280.0, 720.0, 0, 1, studio_profile_sim_scientific())
  sci.scene_entity_count = 1
  sci.viewport_empty.empty_visible = 0
  studio_attach_viewport_shell(sci)
  var vp_frame: PaintFrame = paint_frame_new()
  studio_paint_viewport_display(vp_frame, sci.layout.viewport, sci.viewport_display)
  if vp_frame.last_kind != paint_op_draw_glyphs():
    return 10
  return 0
