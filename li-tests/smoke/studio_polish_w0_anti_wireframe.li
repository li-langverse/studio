import studio
import ui

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if li_std_studio_version() < 40:
    return 1
  var compose: StudioShellCompose = studio_compose_shell(1280.0, 720.0, 0, 0, 0)
  var dock_frame: PaintFrame = paint_frame_new()
  studio_paint_dock(dock_frame, compose.dock)
  if dock_frame.last_kind != paint_op_draw_image():
    return 2
  var timeline_frame: PaintFrame = paint_frame_new()
  studio_paint_timeline(timeline_frame, compose.timeline)
  if timeline_frame.last_kind != paint_op_stroke_round_rect():
    return 3
  var empty_vp: StudioViewportEmptyCompose = compose.viewport_empty
  var vp_frame: PaintFrame = paint_frame_new()
  studio_paint_viewport_empty(vp_frame, empty_vp)
  if vp_frame.last_kind != paint_op_stroke_round_rect():
    return 4
  return 0
