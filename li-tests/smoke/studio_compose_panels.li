import studio

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if li_std_studio_version() < 3:
    return 1
  if li_std_gui_version() < 1:
    return 2
  if li_std_ui_studio_composables_version() < 3:
    return 3
  var compose: StudioShellCompose = studio_compose_shell(1920.0, 1080.0, 2, 1)
  if studio_compose_ok(compose) != 1:
    return 4
  if compose.dock.active_slot != 2:
    return 5
  if compose.timeline.playhead_pct != studio_timeline_playhead_pct():
    return 6
  var panel_cmds: int = studio_paint_compose_panels_count(1)
  if panel_cmds < 10:
    return 7
  var shell: PaintFrame = studio_shell_frame(1280.0, 720.0)
  var shell_compose: StudioShellCompose = studio_compose_shell_agent(1280.0, 720.0, 0, 1, 1, studio_agent_task_running())
  if shell.cmd_count != studio_shell_chrome_count_for_compose(shell_compose):
    return 8
  var timing: PanelSwitchTiming = studio_panel_switch_inspector(compose.panel, 42.0)
  if gui_panel_switch_within_budget(timing) != 1:
    return 9
  var slow: PanelSwitchTiming = studio_panel_switch_timeline(compose.panel, 150.0)
  if gui_panel_switch_within_budget(slow) != 0:
    return 10
  return 0
