import studio

def main() -> int raises IO
  requires true
  ensures result == 0
  decreases 0
=
  if li_std_studio_version() < 8:
    return 1
  var drug: int = studio_profile_sim_drug_design()
  if studio_vertical_demo_frame(drug, 0) != 0:
    return 10
  if studio_vertical_demo_frame(drug, 1) != 0:
    return 20
  if studio_vertical_demo_frame(drug, 2) != 0:
    return 30
  var compose: StudioShellCompose = studio_compose_shell_drug_litl(1280.0, 720.0, 2, 1)
  if compose.config.active_profile != drug:
    return 40
  var layout0: StudioShellLayout = studio_adaptive_layout_for_drug_tick(1280.0, 720.0, 0)
  if compose.layout.inspector.w <= layout0.inspector.w:
    return 50
  return 0
