import studio
import ui

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if li_std_studio_version() < 46:
    return 1
  if studio_elevation_shadow_layer_count() != 3:
    return 2
  if studio_paint_panel_shadow_cmds() != studio_elevation_shadow_layer_count():
    return 3
  if studio_paint_elevated_panel_shadow_cmds() != 5:
    return 4
  var panel: Rect = rect_make(10.0, 10.0, 120.0, 80.0)
  var frame: PaintFrame = paint_frame_new()
  studio_paint_panel_shadow(frame, panel)
  if frame.cmd_count != 3:
    return 5
  var elevated: PaintFrame = paint_frame_new()
  studio_paint_elevated_panel_with_shadow(elevated, panel)
  if elevated.cmd_count != 5:
    return 6
  if elevated.last_kind != paint_op_stroke_round_rect():
    return 7
  return 0
