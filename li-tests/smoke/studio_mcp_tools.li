import studio

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if li_std_studio_version() < 6:
    return 1
  if studio_mcp_tool_count() != 11:
    return 2
  if studio_mcp_tool_id_valid(studio_mcp_world_scaffold()) != 1:
    return 3
  if studio_mcp_tool_from_name("lic_build") != studio_mcp_lic_build():
    return 4
  if studio_mcp_tool_from_name(studio_mcp_tool_name(studio_mcp_sim_set_profile())) != studio_mcp_sim_set_profile():
    return 5
  if studio_mcp_tool_from_name(studio_mcp_tool_name(studio_mcp_publish_bundle())) != studio_mcp_publish_bundle():
    return 6
  var tool_req: StudioAgentToolRequest = studio_agent_tool_request_none()
  if tool_req.tool_id != studio_mcp_tool_unknown():
    return 7
  var layout: StudioShellLayout = layout_studio_shell_adaptive(1280.0, 720.0)
  var running_tool: StudioAgentToolRequest = studio_agent_tool_request_none()
  running_tool.tool_id = studio_mcp_lic_check()
  running_tool.status = studio_mcp_tool_status_pending()
  running_tool.result_code = studio_mcp_tool_result_ok()
  var agent: StudioAgentChromeCompose = studio_compose_agent_chrome_with_tool(layout, studio_agent_task_running(), studio_agent_context_world(), running_tool)
  if agent.tool_request.tool_id != studio_mcp_lic_check():
    return 8
  return 0
