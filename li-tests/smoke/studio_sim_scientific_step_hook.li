import scene
import sim
import studio

def main() -> int raises IO
  requires true
  ensures result == 0
  decreases 0
=
  if li_std_studio_version() < 10:
    return 1
  studio_viewport_display_reset_for_profile(studio_profile_sim_scientific())
  var cfg: StudioProjectConfig = studio_project_config_new(studio_profile_sim_scientific())
  var sess: SimSessionStub = sim_session_stub_default()
  if studio_sim_scientific_step_hook(sess, 1.0) != sim_status_ok():
    return 10
  if sess.tick != 1:
    return 11
  if studio_viewport_display_read_particle_tier() != scene_md_tier_1k():
    return 12
  if studio_viewport_display_read_particle_draw_points() != 1000:
    return 13
  var vp: Rect = rect_make(0.0, 0.0, 1280.0, 720.0)
  var disp: StudioViewportDisplayCompose = studio_compose_viewport_display(vp, studio_profile_sim_scientific())
  if disp.tier_particles != 1000:
    return 14
  if studio_sim_scientific_tier_for_tick(11) != scene_md_tier_100k():
    return 15
  return 0
