import studio

# wsg-w5-windows-native — Windows SDL present host (.exe), no WSL requirement for window I/O.
def main() -> int raises IO
  requires true
  ensures result == 0
  decreases 0
=
  if li_std_studio_version() < 35:
    return 1
  if studio_windows_native_present_version() != 1:
    return 2
  if studio_c_host_slim_version() != 1:
    return 3
  if studio_present_loop_raster_version() != 1:
    return 4
  return 0
