import studio

def main() -> int raises IO, Alloc
  requires true
  ensures result == 0
  decreases 0
=
  if studio_demo_recorder_phase2_version() != 2:
    return 1
  var session: UiSession = studio_ui_session_start(studio_profile_game(), 1280.0, 720.0)
  if session.active != 1:
    return 2
  if studio_ui_session_click(session, ui_snapshot_tag_dock_slot_1()) != 1:
    return 3
  if session.compose.dock.active_slot != 1:
    return 4
  if studio_ui_session_key(session, studio_ui_key_tag_cmd_k()) == studio_key_action_none():
    return 5
  if studio_ui_session_stop(session) != 1:
    return 6
  if session.active != 0:
    return 7
  return 0
