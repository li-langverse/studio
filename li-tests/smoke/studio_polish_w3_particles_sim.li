import studio
import sim

def main() -> int raises IO
  requires true
  ensures result == 0
  decreases 0
=
  if li_std_studio_version() < 45:
    return 1
  if studio_viewport_display_profile_wants_scene(studio_profile_sim_rl()) != 1:
    return 2
  if studio_paint_viewport_rl_preview_cmds() != 6:
    return 3
  studio_viewport_display_prepare_for_profile(studio_profile_sim_rl())
  var rl_vp: Rect = rect_make(0.0, 0.0, 1280.0, 720.0)
  var rl_disp: StudioViewportDisplayCompose = studio_compose_viewport_display(rl_vp, studio_profile_sim_rl())
  if rl_disp.background != studio_viewport_bg_grid():
    return 4
  if rl_disp.particle_dots_visible != 1:
    return 5
  if rl_disp.tier_particles < 1000:
    return 6
  var rl_shell: StudioShellCompose = studio_vertical_demo_compose(studio_profile_sim_rl(), 0, 0)
  if rl_shell.scene_entity_count != 1:
    return 7
  if rl_shell.viewport_empty.empty_visible != 0:
    return 8
  studio_viewport_display_prepare_for_profile(studio_profile_sim_drug_design())
  var drug: StudioShellCompose = studio_compose_shell_drug_litl(1280.0, 720.0, 2, 1)
  if drug.viewport_display.biomol_style != studio_biomol_style_sticks():
    return 9
  if drug.viewport_display.particle_dots_visible != 1:
    return 10
  studio_viewport_display_reset_for_profile(studio_profile_sim_scientific())
  var sess: SimSessionStub = sim_session_stub_default()
  if studio_sim_scientific_step_hook(sess, 1.0) != sim_status_ok():
    return 11
  var sci_vp: Rect = rect_make(0.0, 0.0, 1280.0, 720.0)
  var sci_disp: StudioViewportDisplayCompose = studio_compose_viewport_display(sci_vp, studio_profile_sim_scientific())
  if sci_disp.particle_tier_id < scene_md_tier_1k():
    return 12
  return 0
