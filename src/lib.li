def studio_viewport_error_kind_for_render_smoke(smoke: RenderViewportSmoke) -> int
  requires true
  ensures result >= studio_viewport_error_none()
  ensures result <= studio_err_missing_asset()
  decreases 0
=
  if render_viewport_smoke_ok(smoke) == 1:
    return studio_viewport_error_none()
  if lig_wgpu_smoke_passed(smoke.wgpu) != 1:
    return studio_err_gpu()
  return studio_err_missing_asset()

def studio_viewport_error_report(kind: int) raises IO -> int
  requires kind >= studio_viewport_error_none()
  requires kind <= studio_err_missing_asset()
  ensures result == kind
  decreases kind
=
  return li_rt_studio_viewport_error_set_mock(kind)

def studio_viewport_error_sync_render(compose: var StudioShellCompose) raises IO -> unit
  requires studio_profile_id_valid(compose.config.active_profile) == 1
  requires compose.layout.viewport_w > 0.0
  requires compose.layout.viewport_h > 0.0
  ensures compose.viewport_error.error_kind == studio_viewport_error_kind()
  decreases 0
=
  var vp: ViewportRegion = gui_viewport_region_from_layout(compose.layout)
  var pid: int = compose.config.active_profile
  var smoke: RenderViewportSmoke = render_wgpu_draw_list_smoke_pure(vp, pid)
  var kind: int = studio_viewport_error_kind_for_render_smoke(smoke)
  if kind != studio_viewport_error_none():
    var _reported: int = studio_viewport_error_report(kind)
  var lay: StudioShellLayout = compose.layout
  compose.viewport_error = studio_compose_viewport_error_overlay(lay, studio_viewport_error_kind())

def studio_shell_handle_viewport_error_pointer(compose: var StudioShellCompose, input: InputState) -> int
  requires compose.layout.viewport_w > 0.0
  requires input.pointer_down >= 0
  requires input.pointer_down <= 1
  ensures result >= studio_viewport_error_action_none()
  ensures result <= studio_viewport_error_action_retry_clicked()
  decreases input.pointer_down
=
  if input.pointer_down != 1:
    return studio_viewport_error_action_none()
  if compose.viewport_error.visible != 1:
    return studio_viewport_error_action_none()
  if rect_contains(compose.viewport_error.retry_rect, input.pointer_x, input.pointer_y) != 1:
    return studio_viewport_error_action_none()
  var _cleared: int = studio_viewport_error_retry()
  var lay: StudioShellLayout = compose.layout
  compose.viewport_error = studio_compose_viewport_error_overlay(lay, studio_viewport_error_kind())
  return studio_viewport_error_action_retry_clicked()

def studio_viewport_error_kind_from_wgpu_probe(probe: RenderViewportWgpuProbe) -> int
  requires probe.draw_submit_ok >= 0
  requires probe.draw_submit_ok <= 1
  requires probe.surface_ok >= 0
  requires probe.surface_ok <= 1
  requires probe.asset_ok >= 0
  requires probe.asset_ok <= 1
  ensures result >= studio_viewport_error_none()
  ensures result <= studio_err_missing_asset()
  decreases probe.draw_submit_ok
=
  if probe.asset_ok == 0:
    return studio_err_missing_asset()
  if probe.draw_submit_ok == 0:
    return studio_err_gpu()
  if probe.surface_ok == 0:
    return studio_err_gpu()
  return studio_viewport_error_none()

def studio_viewport_error_probe_from_layout(layout: StudioShellLayout, profile_id: int) -> RenderViewportWgpuProbe raises IO
  requires layout.viewport.w > 0.0
  requires layout.viewport.h > 0.0
  requires studio_profile_id_valid(profile_id) == 1
  ensures result.draw_submit_ok >= 0
  ensures result.draw_submit_ok <= 1
  ensures result.surface_ok >= 0
  ensures result.surface_ok <= 1
  ensures result.asset_ok >= 0
  ensures result.asset_ok <= 1
  decreases profile_id
=
  var lay_copy: StudioShellLayout = layout
  var vp: ViewportRegion = gui_viewport_region_from_layout(lay_copy)
  return render_viewport_wgpu_probe(vp, profile_id, 1)

def studio_viewport_error_sync_from_wgpu(compose: StudioShellCompose) raises IO -> int
  requires studio_profile_id_valid(compose.config.active_profile) == 1
  ensures result >= studio_viewport_error_none()
  ensures result <= studio_err_missing_asset()
  decreases compose.config.active_profile
=
  var current: int = studio_viewport_error_kind()
  if current != studio_viewport_error_none():
    return current
  var lay_copy: StudioShellLayout = compose.layout
  var probe: RenderViewportWgpuProbe = studio_viewport_error_probe_from_layout(lay_copy, compose.config.active_profile)
  var kind: int = studio_viewport_error_kind_from_wgpu_probe(probe)
  if kind != studio_viewport_error_none():
    studio_viewport_error_set_mock(kind)
  return kind

def studio_viewport_error_retry_wgpu(layout: StudioShellLayout, profile_id: int) raises IO -> int
  requires layout.viewport.w > 0.0
  requires layout.viewport.h > 0.0
  requires studio_profile_id_valid(profile_id) == 1
  ensures result >= studio_viewport_error_none()
  ensures result <= studio_err_missing_asset()
  decreases profile_id
=
  studio_viewport_error_retry()
  var lay_copy: StudioShellLayout = layout
  var probe: RenderViewportWgpuProbe = studio_viewport_error_probe_from_layout(lay_copy, profile_id)
  var kind: int = studio_viewport_error_kind_from_wgpu_probe(probe)
  if kind != studio_viewport_error_none():
    studio_viewport_error_set_mock(kind)
  return kind

def studio_viewport_error_wgpu_probe_ok(probe: RenderViewportWgpuProbe) -> int
  requires probe.draw_submit_ok >= 0
  requires probe.draw_submit_ok <= 1
  ensures result >= 0
  ensures result <= 1
  decreases probe.draw_submit_ok
=
  if studio_viewport_error_kind_from_wgpu_probe(probe) != studio_viewport_error_none():
    return 0
  return render_viewport_wgpu_probe_ok(probe)

def studio_viewport_error_visible(error_kind: int) -> int
  requires error_kind >= studio_viewport_error_none()
  requires error_kind <= studio_err_missing_asset()
  ensures result >= 0
  ensures result <= 1
  decreases error_kind
=
  if error_kind == studio_viewport_error_none():
    return 0
  return 1

def studio_viewport_error_message_rect_at(vp_x: float, vp_y: float, vp_w: float, vp_h: float) -> Rect
  requires vp_w >= studio_viewport_error_retry_width_px()
  requires vp_h >= studio_viewport_error_message_height_px() + studio_viewport_error_retry_height_px() + 32.0
  ensures result.w >= studio_viewport_error_retry_width_px()
  ensures result.h == studio_viewport_error_message_height_px()
  decreases 0
=
  var msg_w: float = studio_viewport_error_retry_width_px() + 120.0
  if msg_w > vp_w - 32.0:
    msg_w = vp_w - 32.0
  var x: float = vp_x + (vp_w - msg_w) / 2.0
  var y: float = vp_y + (vp_h * 0.40)
  return rect_make(x, y, msg_w, studio_viewport_error_message_height_px())

def studio_viewport_error_retry_rect_at(vp_x: float, vp_y: float, vp_w: float, vp_h: float) -> Rect
  requires vp_w >= studio_viewport_error_retry_width_px()
  requires vp_h >= studio_viewport_error_retry_height_px() + 32.0
  ensures result.w == studio_viewport_error_retry_width_px()
  ensures result.h == studio_viewport_error_retry_height_px()
  decreases 0
=
  var x: float = vp_x + (vp_w - studio_viewport_error_retry_width_px()) / 2.0
  var y: float = vp_y + (vp_h * 0.52)
  return rect_make(x, y, studio_viewport_error_retry_width_px(), studio_viewport_error_retry_height_px())

