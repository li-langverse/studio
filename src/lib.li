  ensures frame.cmd_count == old(frame.cmd_count) + studio_paint_elevated_panel_shadow_cmds()
  ensures frame.last_kind == paint_op_stroke_round_rect()
  decreases 0
=
  studio_paint_panel_shadow(frame, rect)
  paint_frame_push_elevated_panel(frame, rect)

