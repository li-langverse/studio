def studio_paint_inspector_field_glyphs(frame: var PaintFrame, inspector: StudioInspectorCompose) -> unit
  requires frame.cmd_count >= 0
  requires inspector.has_selection == 1
  requires inspector.widget_pilot == 1
  ensures frame.cmd_count == old(frame.cmd_count) + studio_paint_inspector_field_glyph_cmds()
  decreases inspector.field_rows
=
  var rows: int = inspector.field_rows
  var cp0: int = studio_inspector_field_label_first_codepoint(0, rows)
  var n0: int = studio_inspector_field_label_glyph_count(0, rows)
  studio_paint_glyph_text(frame, inspector.field0.label_rect, cp0, n0, studio_color_text_muted())
  var vp0: int = studio_inspector_field_value_first_codepoint(0, rows)
  var nv0: int = studio_inspector_field_value_glyph_count(0, rows)
  studio_paint_glyph_text(frame, inspector.field0.value_rect, vp0, nv0, studio_color_text_primary())
  var cp1: int = studio_inspector_field_label_first_codepoint(1, rows)
  var n1: int = studio_inspector_field_label_glyph_count(1, rows)
  studio_paint_glyph_text(frame, inspector.field1.label_rect, cp1, n1, studio_color_text_muted())
  var vp1: int = studio_inspector_field_value_first_codepoint(1, rows)
  var nv1: int = studio_inspector_field_value_glyph_count(1, rows)
  studio_paint_glyph_text(frame, inspector.field1.value_rect, vp1, nv1, studio_color_text_primary())

