type PublishFigureResult = object
  public ok: int
  public format: int
  public template: int
  public width_px: int
  public height_px: int
  public dpi: int
  public sim_checksum: float
  public byte_checksum: float
  public magic_tag: int

def studio_publish_figure(
    fmt: int,
    template: int,
    sim_checksum: float,
    proof_pass: int) raises IO -> PublishFigureResult
  requires sim_checksum >= 0.0
  ensures result.format == fmt
  ensures result.template == template
  decreases fmt
=
  var r: PublishFigureResult
  r.ok = 0
  r.format = fmt
  r.template = template
  r.width_px = 0
  r.height_px = 0
  r.dpi = 0
  r.sim_checksum = sim_checksum
  r.byte_checksum = 0.0
  r.magic_tag = 0
  if studio_publish_format_ok(fmt) != 1:
    return r
  if studio_publish_template_ok(template) != 1:
    return r
  if studio_publish_proof_pass_ok(proof_pass) != 1:
    return r
  r.width_px = studio_publish_template_width_px(template)
  r.height_px = studio_publish_template_height_px(template)
  r.dpi = studio_publish_template_dpi(template)
  if fmt == studio_publish_format_png():
    if r.dpi < 300:
      r.dpi = 300
  var w_f: float = studio_int_as_float(r.width_px)
  var h_f: float = studio_int_as_float(r.height_px)
  var d_f: float = studio_int_as_float(r.dpi)
  r.byte_checksum = sim_checksum + w_f + h_f + d_f
  r.magic_tag = studio_publish_magic_for_format(fmt)
  r.ok = 1
  return r

# WP-PUB-01 publish mode — Select template → lic build proof → export figure (≤3 clicks).
def studio_publish_wizard_step_select() -> int
  requires true
  ensures result == 0
  decreases 0
=
  return 0

def studio_publish_wizard_step_proof() -> int
  requires true
  ensures result == 1
  decreases 0
=
  return 1

def studio_publish_wizard_step_export() -> int
  requires true
  ensures result == 2
  decreases 0
=
  return 2

type StudioPublishFlowState = object
  public format: int
  public template: int
  public wizard_step: int
  public click_count: int
  public proof_pass: int
  public export_ok: int
  public last_magic: int

def studio_publish_flow_init(fmt: int, tmpl: int) -> StudioPublishFlowState
  requires studio_publish_format_ok(fmt) == 1
  requires studio_publish_template_ok(tmpl) == 1
  ensures result.format == fmt
  ensures result.template == tmpl
  ensures result.wizard_step == studio_publish_wizard_step_select()
  decreases fmt
=
  var f: StudioPublishFlowState
  f.format = fmt
  f.template = tmpl
  f.wizard_step = studio_publish_wizard_step_select()
  f.click_count = 0
  f.proof_pass = 0
  f.export_ok = 0
  f.last_magic = 0
  return f

def studio_publish_flow_advance(
    flow: var StudioPublishFlowState,
    sim_checksum: float) -> int
  requires studio_publish_format_ok(flow.format) == 1
  requires studio_publish_template_ok(flow.template) == 1
  requires sim_checksum >= 0.0
  ensures flow.click_count >= 0
  ensures result >= 0
  ensures result <= 4
  decreases flow.wizard_step
=
  flow.click_count = flow.click_count + 1
  if flow.wizard_step == studio_publish_wizard_step_select():
    flow.wizard_step = studio_publish_wizard_step_proof()
    return 0
  if flow.wizard_step == studio_publish_wizard_step_proof():
    if flow.proof_pass != 1:
      return 1
    flow.wizard_step = studio_publish_wizard_step_export()
    return 0
  if flow.wizard_step == studio_publish_wizard_step_export():
    var fig: PublishFigureResult = studio_publish_figure(flow.format, flow.template, sim_checksum, flow.proof_pass)
    if fig.ok != 1:
      return 2
    if fig.magic_tag != studio_publish_magic_for_format(flow.format):
      return 3
    flow.export_ok = 1
    flow.last_magic = fig.magic_tag
    return 0
  return 4

def studio_publish_three_click_flow(
    fmt: int,
    tmpl: int,
    sim_checksum: float,
    proof_pass: int) -> int
  requires studio_publish_format_ok(fmt) == 1
  requires studio_publish_template_ok(tmpl) == 1
  requires sim_checksum >= 0.0
  ensures result >= 0
  ensures result <= 6
  decreases fmt
=
  var flow: StudioPublishFlowState = studio_publish_flow_init(fmt, tmpl)
  if studio_publish_flow_advance(flow, sim_checksum) != 0:
    return 1
  flow.proof_pass = proof_pass
  if studio_publish_flow_advance(flow, sim_checksum) != 0:
    return 2
  if proof_pass != 1:
    return 3
  if studio_publish_flow_advance(flow, sim_checksum) != 0:
    return 4
  if flow.click_count != 3:
    return 5
  if flow.export_ok != 1:
    return 6
  if flow.last_magic != studio_publish_magic_for_format(fmt):
    return 7
  return 0

# WP-PUB-02 — studio.publish.table scientific export (HDF5/CSV contract; not file I/O).
def studio_publish_table_format_hdf5() -> int
  requires true
  ensures result == 1
  decreases 0
=
  return 1

def studio_publish_table_format_csv() -> int
  requires true
  ensures result == 2
  decreases 0
=
  return 2

def studio_publish_table_format_ok(fmt: int) -> int
  requires true
  ensures result >= 0
  ensures result <= 1
  decreases fmt
=
  if fmt == studio_publish_table_format_hdf5():
    return 1
  if fmt == studio_publish_table_format_csv():
    return 1
  return 0

def studio_publish_table_schema_columns() -> int
  requires true
  ensures result == 5
  decreases 0
=
  return 5

def studio_publish_table_magic_hdf5() -> int
  requires true
  ensures result == 48465
  decreases 0
=
  return 48465

def studio_publish_table_magic_csv() -> int
  requires true
  ensures result == 43553
  decreases 0
=
  return 43553

def studio_publish_table_magic_for_format(fmt: int) -> int
  requires studio_publish_table_format_ok(fmt) == 1
  ensures result > 0
  decreases fmt
=
  if fmt == studio_publish_table_format_csv():
    return studio_publish_table_magic_csv()
  return studio_publish_table_magic_hdf5()

def studio_publish_table_rows_from_pipeline(pipeline: VizPipelineState) -> int
  requires pipeline.profile_id == viz_profile_sim_scientific()
  requires pipeline.source_count >= 0
  ensures result >= 0
  ensures result <= 512
  decreases pipeline.source_count
=
  if pipeline.source_count <= 0:
    return 0
  var dots: int = viz_pipeline_viewport_particle_dots(pipeline)
  if dots <= 0:
    return pipeline.source_count
  return pipeline.source_count + dots

def studio_publish_table_pipeline_ok(pipeline: VizPipelineState) -> int
  requires pipeline.profile_id == viz_profile_sim_scientific()
  ensures result >= 0
  ensures result <= 1
  decreases pipeline.source_count
=
  if pipeline.source_count < 1:
    return 0
  if studio_publish_table_rows_from_pipeline(pipeline) <= 0:
    return 0
  return 1

type PublishTableResult = object
  public ok: int
  public format: int
  public row_count: int
  public col_count: int
  public source_count: int
  public sim_checksum: float
  public byte_checksum: float
  public magic_tag: int

def studio_publish_table(
    fmt: int,
    pipeline: VizPipelineState,
    sim_checksum: float,
    proof_pass: int) raises IO -> PublishTableResult
  requires sim_checksum >= 0.0
  requires pipeline.profile_id == viz_profile_sim_scientific()
  ensures result.format == fmt
  ensures result.ok >= 0
  ensures result.ok <= 1
  ensures result.row_count >= 0
  ensures result.col_count >= 0
  decreases fmt
=
  var r: PublishTableResult
  r.ok = 0
  r.format = fmt
  r.row_count = 0
  r.col_count = 0
  r.source_count = pipeline.source_count
  r.sim_checksum = sim_checksum
  r.byte_checksum = 0.0
  r.magic_tag = 0
  if studio_publish_table_format_ok(fmt) != 1:
    return r
  if studio_publish_proof_pass_ok(proof_pass) != 1:
    return r
  if studio_publish_table_pipeline_ok(pipeline) != 1:
    return r
  r.row_count = studio_publish_table_rows_from_pipeline(pipeline)
  r.col_count = studio_publish_table_schema_columns()
  var rows_f: float = studio_int_as_float(r.row_count)
  var cols_f: float = studio_int_as_float(r.col_count)
  var src_f: float = studio_int_as_float(r.source_count)
  r.byte_checksum = sim_checksum + rows_f + cols_f + src_f
  r.magic_tag = studio_publish_table_magic_for_format(fmt)
  r.ok = 1
  return r

def studio_publish_table_from_viz_tick(
    tick: int,
    fmt: int,
    sim_checksum: float,
    proof_pass: int) -> PublishTableResult
  requires tick >= 1
  requires tick <= 64
  requires sim_checksum >= 0.0
  ensures result.format == fmt
  ensures result.ok >= 0
  ensures result.ok <= 1
  decreases tick
=
  var pipe: VizPipelineState = studio_sim_scientific_viz_for_tick(tick)
  return studio_publish_table(fmt, pipe, sim_checksum, proof_pass)

