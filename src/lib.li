def studio_vertical_dod_sim_scientific_composable_ok() -> int raises IO
  requires true
  ensures result >= 0
  ensures result <= 1
  decreases 0
=
  var md_oracle: float = sim_scientific_oracle_checksum_md()
  var md105: SimRunResult = run_algo(105, 1)
  if run_result_ok(md105) != 1:
    return 0
  if md105.checksum != md_oracle:
    return 0
  var cfg: StudioProjectConfig = studio_project_config_new(studio_profile_sim_scientific())
  var sess: SimSessionStub = sim_session_stub_default()
  studio_viewport_display_reset_for_profile(studio_profile_sim_scientific())
  if studio_sim_scientific_step_hook(sess, 1.0) != sim_status_ok():
    return 0
  var vp: Rect = rect_make(0.0, 0.0, 1280.0, 720.0)
  var pipeline: VizPipelineState = studio_sim_scientific_viz_for_tick(sess.tick)
  var display: StudioViewportDisplayCompose = studio_compose_viewport_display(vp, studio_profile_sim_scientific())
  if studio_sim_scientific_viz_viewport_ok(pipeline, display) != 1:
    return 0
  return 1

def studio_vertical_dod_sim_drug_design_composable_ok() -> int
  requires true
  ensures result >= 0
  ensures result <= 1
  decreases 0
=
  var lab: int = drug_litl_stage_lab()
  if studio_adaptive_panel_set_id(lab) != lab:
    return 0
  if studio_adaptive_panel_region_for_litl_stage(lab) != studio_region_timeline():
    return 0
  var shell: StudioShellCompose = studio_compose_shell_drug_litl(1280.0, 720.0, lab, 1)
  if shell.panel.active_region != studio_region_timeline():
    return 0
  return 1

def studio_vertical_dod_profile_composable_ok(profile_id: int) -> int raises Alloc, IO
  requires studio_profile_id_valid(profile_id) == 1
  ensures result >= 0
  ensures result <= 1
  decreases profile_id
=
  if profile_id == studio_profile_game():
    return studio_vertical_dod_game_composable_ok()
  if profile_id == studio_profile_sim_rl():
    return studio_vertical_dod_sim_rl_composable_ok()
  if profile_id == studio_profile_sim_automotive():
    return studio_vertical_dod_sim_automotive_composable_ok()
  if profile_id == studio_profile_sim_robotics():
    return studio_vertical_dod_sim_robotics_composable_ok()
  if profile_id == studio_profile_sim_additive():
    return studio_vertical_dod_sim_additive_composable_ok()
  if profile_id == studio_profile_sim_scientific():
    return studio_vertical_dod_sim_scientific_composable_ok()
  if profile_id == studio_profile_sim_drug_design():
    return studio_vertical_dod_sim_drug_design_composable_ok()
  return 0

def studio_vertical_dod_all_profiles_ok() -> int raises Alloc, IO
  requires true
  ensures result >= 0
  ensures result <= 1
  decreases 0
=
  if studio_vertical_dod_profile_composable_ok(studio_profile_game()) != 1:
    return 0
  if studio_vertical_dod_profile_composable_ok(studio_profile_sim_rl()) != 1:
    return 0
  if studio_vertical_dod_profile_composable_ok(studio_profile_sim_automotive()) != 1:
    return 0
  if studio_vertical_dod_profile_composable_ok(studio_profile_sim_robotics()) != 1:
    return 0
  if studio_vertical_dod_profile_composable_ok(studio_profile_sim_additive()) != 1:
    return 0
  if studio_vertical_dod_profile_composable_ok(studio_profile_sim_scientific()) != 1:
    return 0
  if studio_vertical_dod_profile_composable_ok(studio_profile_sim_drug_design()) != 1:
    return 0
  return 1

