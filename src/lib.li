type StudioShellHoverState = object
  public dock_slot: int
  public outliner_row: int
  public timeline_play_btn: int
  public timeline_playhead: int

def studio_shell_hover_new() -> StudioShellHoverState
  requires true
  ensures result.dock_slot == studio_hover_dock_none()
  ensures result.outliner_row == studio_hover_outliner_none()
  ensures result.timeline_play_btn == 0
  ensures result.timeline_playhead == 0
  decreases 0
=
  var h: StudioShellHoverState
  h.dock_slot = studio_hover_dock_none()
  h.outliner_row = studio_hover_outliner_none()
  h.timeline_play_btn = 0
  h.timeline_playhead = 0
  return h

def studio_shell_hover_dock_slot_is(hover: StudioShellHoverState, slot: int) -> int
  requires slot >= 0
  requires slot < studio_dock_slot_count()
  ensures result >= 0
  ensures result <= 1
  decreases slot
=
  if hover.dock_slot == slot:
    return 1
  return 0

def studio_shell_hover_outliner_row_is(hover: StudioShellHoverState, row: int) -> int
  requires row >= 0
  requires row <= 2
  ensures result >= 0
  ensures result <= 1
  decreases row
=
  if hover.outliner_row == row:
    return 1
  return 0

def studio_shell_sync_hover(compose: var StudioShellCompose, input: InputState) -> unit
  requires true
  ensures compose.hover.dock_slot >= studio_hover_dock_none()
  decreases 0
=
  var h: StudioShellHoverState = studio_shell_hover_new()
  var px: float = input.pointer_x
  var py: float = input.pointer_y
  var slot: int = 0
  while slot < compose.dock.slot_count:
    var sr: Rect = studio_dock_slot_rect_at(compose.dock.rect.x, compose.dock.rect.y, compose.dock.rect.w, compose.dock.rect.h, slot)
    if rect_contains(sr, px, py) == 1:
      h.dock_slot = slot
    slot = slot + 1
  if compose.outliner.node_count > 0:
    if rect_contains(compose.outliner.row0_rect, px, py) == 1:
      h.outliner_row = 0
  if compose.outliner.node_count > 1:
    if rect_contains(compose.outliner.row1_rect, px, py) == 1:
      h.outliner_row = 1
  if compose.outliner.node_count > 2:
    if rect_contains(compose.outliner.row2_rect, px, py) == 1:
      h.outliner_row = 2
  if rect_contains(compose.timeline.play_btn_rect, px, py) == 1:
    h.timeline_play_btn = 1
  if rect_contains(compose.timeline.playhead_rect, px, py) == 1:
    h.timeline_playhead = 1
  compose.hover = h

