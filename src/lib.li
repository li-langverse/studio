def studio_publish_bundle_flow_advance(
    flow: var StudioPublishBundleFlowState,
    config: StudioProjectConfig,
    checkpoint: StudioWorldCheckpoint,
    sim_checksum: float) -> int
  requires studio_profile_id_valid(flow.profile_id) == 1
  requires flow.viz_tick >= 1
  requires flow.viz_tick <= 64
  requires sim_checksum >= 0.0
  ensures flow.click_count >= 0
  ensures result >= 0
  ensures result <= 4
  decreases flow.wizard_step
=
  flow.click_count = flow.click_count + 1
  if flow.wizard_step == studio_publish_bundle_wizard_step_select():
    flow.wizard_step = studio_publish_bundle_wizard_step_proof()
    return 0
  if flow.wizard_step == studio_publish_bundle_wizard_step_proof():
    if flow.proof_pass != 1:
      return 1
