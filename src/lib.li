=
  return studio_mcp_tool_dispatch_mode_arg(studio_mode_agent(), tool_id, arg)

def studio_mcp_tool_dispatch_mode_arg(mode: int, tool_id: int, arg: int) -> StudioAgentToolRequest raises IO
  requires true
  ensures result.tool_id == tool_id
  decreases tool_id
=
  var out: StudioAgentToolRequest = studio_agent_tool_request_none()
  out.tool_id = tool_id
  if studio_mode_valid(mode) != 1:
    out.status = studio_mcp_tool_status_failed()
    out.result_code = studio_mcp_tool_result_err_io()
    return out
  if studio_mcp_tool_id_valid(tool_id) != 1:
    out.status = studio_mcp_tool_status_failed()
    out.result_code = studio_mcp_tool_result_err_io()
    return out
  if studio_mode_mcp_tool_allowed(mode, tool_id) != 1:
    out.status = studio_mcp_tool_status_failed()
    out.result_code = studio_mcp_tool_result_err_io()
    return out
  if tool_id == studio_mcp_world_scaffold():
    var profile0: int = studio_mcp_arg_normalize_profile(arg)
    if studio_world_scaffold_write(studio_world_li_path_default()) != 1:
      out.status = studio_mcp_tool_status_failed()
      out.result_code = studio_mcp_tool_result_err_io()
      return out
    out.status = studio_mcp_tool_status_ok()
    out.result_code = profile0
    return out
  if tool_id == studio_mcp_sim_set_profile():
    var profile1: int = studio_mcp_arg_normalize_profile(arg)
    out.status = studio_mcp_tool_status_ok()
    out.result_code = profile1
    return out
  if tool_id == studio_mcp_lic_check():
    if arg < studio_mcp_arg_lic_check_pass():
      out.status = studio_mcp_tool_status_failed()
      out.result_code = studio_mcp_tool_result_err_proof()
      return out
    out.status = studio_mcp_tool_status_ok()
    out.result_code = studio_mcp_tool_result_ok()
    return out
  if tool_id == studio_mcp_lic_build():
    if arg == studio_mcp_arg_lic_build_fail():
      out.status = studio_mcp_tool_status_failed()
      out.result_code = studio_mcp_tool_result_err_proof()
      return out
    out.status = studio_mcp_tool_status_ok()
    out.result_code = studio_mcp_tool_result_ok()
    return out
  if tool_id == studio_mcp_publish_bundle():
    var proof0: int = studio_mcp_arg_normalize_publish_proof(arg)
    var cfg0: StudioProjectConfig = studio_project_config_from_additive_toml_fixture()
    var sess0: SimSessionStub = sim_session_stub_default()
    studio_apply_config_to_sim(cfg0, sess0)
    sess0.tick = 8
    var chk0: StudioWorldCheckpoint = studio_world_checkpoint_capture(cfg0.active_profile, sess0)
    var bundle0: PublishBundleResult = studio_publish_bundle(cfg0, chk0, 42.0, 8, proof0)
    if bundle0.ok != 1:
      out.status = studio_mcp_tool_status_failed()
      out.result_code = studio_mcp_tool_result_err_proof()
      return out
    out.status = studio_mcp_tool_status_ok()
    out.result_code = bundle0.magic_tag
    return out
  if tool_id == studio_mcp_am_export_print():
    var fmt: int = studio_mcp_arg_normalize_am_format(arg)
    if sim_additive_export_format_ok(fmt) != 1:
      out.status = studio_mcp_tool_status_failed()
      out.result_code = studio_mcp_tool_result_err_io()
      return out
    var slot0: int = studio_printer_profile_slot_bambu()
    var print0: AmExportPrintResult = sim_export_print(fmt, 1, slot0, 1)
    if print0.ok != 1:
      out.status = studio_mcp_tool_status_failed()
      out.result_code = studio_mcp_tool_result_err_io()
      return out
    if print0.magic_tag != am_export_magic_for_format(fmt):
      out.status = studio_mcp_tool_status_failed()
      out.result_code = studio_mcp_tool_result_err_io()
      return out
    out.status = studio_mcp_tool_status_ok()
    out.result_code = fmt
    return out
  if tool_id == studio_mcp_chem_dft_run():
    var method: int = arg
    if method < 0:
      method = 0
    var dft: DrugLitlStagePayload = drug_litl_stage_payload(drug_litl_stage_dft())
    if dft.dft_energy_hartree >= 0.0:
      out.status = studio_mcp_tool_status_failed()
      out.result_code = studio_mcp_tool_result_err_io()
      return out
    out.status = studio_mcp_tool_status_ok()
    out.result_code = method
    return out
  if tool_id == studio_mcp_studio_adaptive_layout():
    var stage0: int = studio_mcp_arg_normalize_litl_stage(arg)
    var layout0: StudioShellLayout = layout_studio_shell_drug_litl(1280.0, 720.0, stage0)
    if layout0.inspector.w < studio_inspector_width_for_drug_litl_stage(stage0):
      out.status = studio_mcp_tool_status_failed()
      out.result_code = studio_mcp_tool_result_err_io()
      return out
    out.status = studio_mcp_tool_status_ok()
    out.result_code = stage0
    return out
  if tool_id == studio_mcp_set_viewport_background():
    var bg: int = arg
    if bg < studio_viewport_bg_solid():
      bg = studio_viewport_bg_solid()
    if bg > studio_viewport_bg_gradient():
      bg = studio_viewport_bg_gradient()
    out.result_code = li_rt_studio_viewport_display_set_bg(bg)
    out.status = studio_mcp_tool_status_ok()
    return out
  if tool_id == studio_mcp_set_particle_display():
    var tier: int = arg
    if tier < studio_particle_display_off():
      tier = studio_particle_display_off()
    if tier > scene_md_tier_100k():
      tier = scene_md_tier_100k()
    out.result_code = li_rt_studio_viewport_display_set_particle_tier(tier)
    out.status = studio_mcp_tool_status_ok()
    return out
  if tool_id == studio_mcp_set_biomol_style():
    var style: int = arg
    if style < studio_biomol_style_cartoon():
      style = studio_biomol_style_cartoon()
    if style > studio_biomol_style_sticks():
      style = studio_biomol_style_sticks()
    out.result_code = li_rt_studio_viewport_display_set_biomol_style(style)
    out.status = studio_mcp_tool_status_ok()
    return out
  out.status = studio_mcp_tool_status_failed()
  out.result_code = studio_mcp_tool_result_err_io()
  return out

