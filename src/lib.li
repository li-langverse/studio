def studio_profile_chip_width_px() -> float
  requires true
  ensures result == 88.0
  decreases 0
=
  return 88.0

def studio_profile_chip_height_px() -> float
  requires true
  ensures result == 24.0
  decreases 0
=
  return 24.0

def studio_profile_paint_tag_h(profile_id: int) -> float
  requires studio_profile_id_valid(profile_id) == 1
  ensures result >= 20.0
  ensures result <= 28.0
  decreases profile_id
=
  if profile_id == studio_profile_game():
    return 21.0
  if profile_id == studio_profile_sim_rl():
    return 22.0
  if profile_id == studio_profile_sim_automotive():
    return 23.0
  if profile_id == studio_profile_sim_robotics():
    return 24.0
  if profile_id == studio_profile_sim_additive():
    return 25.0
  if profile_id == studio_profile_sim_scientific():
    return 26.0
  if profile_id == studio_profile_sim_drug_design():
    return 27.0
  return 20.0

def studio_profile_chip_rect_at(top_x: float, top_y: float, top_w: float, top_h: float, profile_id: int) -> Rect
  requires top_w >= studio_profile_chip_width_px() + 16.0
  requires top_h >= studio_profile_chip_height_px()
  requires studio_profile_id_valid(profile_id) == 1
  ensures result.w == studio_profile_chip_width_px()
  decreases profile_id
=
  var pid_tag: int = profile_id
  var tag_h: float = studio_profile_paint_tag_h(pid_tag)
  var pad: float = 12.0
  var x: float = top_x + top_w - studio_profile_chip_width_px() - pad
  var y: float = top_y + (top_h - studio_profile_chip_height_px()) / 2.0
  return rect_make(x, y, studio_profile_chip_width_px(), tag_h)

def studio_profile_color(profile_id: int) -> Color
  requires studio_profile_id_valid(profile_id) == 1
  ensures result.r >= 0.0
  decreases profile_id
=
  if profile_id == studio_profile_game():
    return studio_color_accent_cyan()
  if profile_id == studio_profile_sim_rl():
    return studio_color_accent_mint()
  if profile_id == studio_profile_sim_drug_design():
    return studio_color_accent_violet()
  return studio_color_accent_amber()

def studio_paint_topbar_profile_cmds() -> int
  requires true
  ensures result == 1
  decreases 0
=
  return 1

def studio_paint_topbar_profile(frame: var PaintFrame, topbar: Rect, profile_id: int) -> unit
  requires frame.cmd_count >= 0
  requires studio_profile_id_valid(profile_id) == 1
  ensures frame.cmd_count == old(frame.cmd_count) + studio_paint_topbar_profile_cmds()
  ensures frame.last_kind == paint_op_stroke_rect()
  decreases profile_id
=
  var pid_chip: int = profile_id
  var pid_color: int = profile_id
  frame.cmd_count = frame.cmd_count + studio_paint_topbar_profile_cmds()
  frame.last_kind = paint_op_stroke_rect()
  var top_copy: Rect = topbar
  var top_x: float = top_copy.x
  var top_y: float = top_copy.y
  var top_w: float = top_copy.w
  var top_h: float = top_copy.h
  frame.last_rect = studio_profile_chip_rect_at(top_x, top_y, top_w, top_h, pid_chip)
  frame.last_color = studio_profile_color(pid_color)



