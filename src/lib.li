# WP-UX-16 / WP-AM-03 — additive export wizard (Review → Pre-flight → Export/Print, ≤3 clicks).
def studio_am_export_wizard_step_review() -> int
  requires true
  ensures result == 0
  decreases 0
=
  return 0

def studio_am_export_wizard_step_preflight() -> int
  requires true
  ensures result == 1
  decreases 0
=
  return 1

def studio_am_export_wizard_step_export() -> int
  requires true
  ensures result == 2
  decreases 0
=
  return 2

type StudioAmExportFlowState = object
  public click_count: int
  public wizard_step: int
  public export_ok: int
  public format: int
  public last_magic: int

def studio_am_export_flow_init(fmt: int) -> StudioAmExportFlowState
  requires sim_additive_export_format_ok(fmt) == 1
  ensures result.click_count == 0
  ensures result.wizard_step == studio_am_export_wizard_step_review()
  ensures result.format == fmt
  decreases 0
=
  var f: StudioAmExportFlowState
  f.click_count = 0
  f.wizard_step = studio_am_export_wizard_step_review()
  f.export_ok = 0
  f.format = fmt
  f.last_magic = 0
  return f

def studio_am_export_format_in_mask(fmt: int, mask: int) raises IO -> int
  requires true
  ensures result >= 0
  ensures result <= 1
  decreases fmt
=
  if fmt == am_export_format_3mf():
    if mask == studio_export_format_mask_3mf():
      return 1
    if mask == studio_export_format_mask_3mf() + studio_export_format_mask_gcode():
      return 1
  if fmt == am_export_format_gcode():
    if mask == studio_export_format_mask_gcode():
      return 1
    if mask == studio_export_format_mask_3mf() + studio_export_format_mask_gcode():
      return 1
  if fmt == am_export_format_stl():
    if mask == studio_export_format_mask_stl():
      return 1
  return 0

def studio_am_export_flow_advance(
    flow: var StudioAmExportFlowState,
    cfg: StudioProjectConfig,
    sim_out: var SimSessionStub) raises IO -> int
  requires sim_additive_export_format_ok(flow.format) == 1
  requires flow.click_count >= 0
  requires flow.click_count <= 2
  ensures result >= 0
  ensures result <= 7
  decreases flow.click_count
=
  flow.click_count = flow.click_count + 1
  if flow.wizard_step == studio_am_export_wizard_step_review():
    if cfg.active_profile != studio_profile_sim_additive():
      return 1
    if studio_am_export_format_in_mask(flow.format, cfg.export_cfg.format_mask) != 1:
      return 2
    flow.wizard_step = studio_am_export_wizard_step_preflight()
    return 0
  if flow.wizard_step == studio_am_export_wizard_step_preflight():
    if sim_out.tick < 1:
      studio_apply_profile_to_sim(cfg, sim_out)
      if sim_additive_tick_stub(1) != 1:
        return 3
      if sim_step(sim_out, 0.02) != sim_status_ok():
        return 4
    if cfg.export_cfg.require_sim_pass == 1:
      if sim_additive_require_sim_pass_ok(1) != 1:
        return 5
      if sim_out.tick < 1:
        return 6
    flow.wizard_step = studio_am_export_wizard_step_export()
    return 0
  if flow.wizard_step == studio_am_export_wizard_step_export():
    var slot: int = cfg.export_cfg.printer_profile_slot
    if slot == studio_printer_profile_slot_none():
      slot = studio_printer_profile_slot_bambu()
    var pass_flag: int = cfg.export_cfg.require_sim_pass
    var print_r: AmExportPrintResult = sim_export_print(flow.format, pass_flag, slot, 1)
    if print_r.ok != 1:
      return 7
    flow.last_magic = print_r.magic_tag
    flow.export_ok = 1
    return 0
  return 8

def studio_am_export_three_click_flow(
    cfg: StudioProjectConfig, sim_out: var SimSessionStub, fmt: int) raises IO -> int
  requires sim_additive_export_format_ok(fmt) == 1
  ensures result >= 0
  ensures result <= 10
  decreases fmt
=
  var flow: StudioAmExportFlowState = studio_am_export_flow_init(fmt)
  if studio_am_export_flow_advance(flow, cfg, sim_out) != 0:
    return 1
  if studio_am_export_flow_advance(flow, cfg, sim_out) != 0:
    return 2
  if studio_am_export_flow_advance(flow, cfg, sim_out) != 0:
    return 3
  if flow.click_count != 3:
    return 4
  if flow.export_ok != 1:
    return 5
  if flow.last_magic != am_export_magic_for_format(fmt):
    return 6
  return 0

