# PH-SIM scientific — multi-physics tick + MD tier bench sync into viewport display (CPU paint; not wgpu).
def studio_sim_scientific_tier_for_tick(tick: int) -> int
  requires tick >= 1
  requires tick <= 64
  ensures result >= scene_md_tier_1k()
  ensures result <= scene_md_tier_100k()
  decreases tick
=
  if tick <= 1:
    return scene_md_tier_1k()
  if tick <= 10:
    return scene_md_tier_10k()
  return scene_md_tier_100k()

# WP-SCI-04 — sim.viz pipeline panels drive viewport field compose (not wgpu volume draw).
def studio_viz_pipeline_init() -> VizPipelineState
  requires true
  ensures result.profile_id == viz_profile_sim_scientific()
  decreases 0
=
  return viz_pipeline_init()

def studio_viewport_display_apply_viz_pipeline(
    display: StudioViewportDisplayCompose, pipeline: VizPipelineState) -> StudioViewportDisplayCompose
  requires pipeline.profile_id == viz_profile_sim_scientific()
  ensures result.background == display.background
  decreases pipeline.source_count
=
  var out: StudioViewportDisplayCompose = display
  var fields: VizViewportFields = viz_pipeline_to_viewport_fields(pipeline)
  if fields.particle_dots_visible == 1:
    out.particle_dots_visible = 1
  if fields.tier_label_visible != 1:
    out.particle_dots_visible = 0
  return out

def studio_sim_scientific_viz_viewport_ok(
    pipeline: VizPipelineState, display: StudioViewportDisplayCompose) -> int
  requires pipeline.profile_id == viz_profile_sim_scientific()
  requires display.particle_tier_id >= scene_md_tier_1k()
  ensures result >= 0
  ensures result <= 1
  decreases pipeline.source_count
=
  if viz_pipeline_viewport_ok(pipeline, display.particle_tier_id, display.tier_particles) != 1:
    return 0
  var applied: StudioViewportDisplayCompose = studio_viewport_display_apply_viz_pipeline(display, pipeline)
  if pipeline.inspector_section == viz_inspector_section_display():
    if applied.particle_dots_visible != 1:
      return 0
  if display.tier_particles <= 0:
    return 0
  if display.tier_label_rect.w <= 0.0:
    return 0
  return 1

def studio_sim_scientific_viz_for_tick(tick: int) -> VizPipelineState
  requires tick >= 1
  requires tick <= 64
  ensures result.profile_id == viz_profile_sim_scientific()
  decreases tick
=
  return viz_pipeline_scientific_step(viz_pipeline_init(), tick)

def studio_viz_tick_for_particle_tier(tier_id: int) -> int
  requires tier_id >= scene_md_tier_1k()
  requires tier_id <= scene_md_tier_100k()
  ensures result >= 1
  ensures result <= 64
  decreases tier_id
=
  if tier_id == scene_md_tier_1k():
    return 3
  if tier_id == scene_md_tier_10k():
    return 5
  return 8

def studio_sim_scientific_step_hook(sim_out: var SimSessionStub, dt: float) -> int
  requires sim_out.tick >= 0
  requires sim_out.replay_capacity > 0
  ensures result >= 0
  ensures result <= 1
  decreases sim_out.tick
=
  if dt <= 0.0:
    return sim_status_invalid_dt()
  var detail: int = sim_out.output_detail
  if detail > 3:
    detail = 3
  var next_step: int = sim_out.tick + 1
  if next_step > 64:
    next_step = 64
  if sim_scientific_tick_at(next_step, detail) != 1:
    return sim_status_invalid_dt()
  var tier: int = studio_sim_scientific_tier_for_tick(next_step)
  if studio_md_particle_tier_select_ok(tier) != 1:
    tier = scene_md_tier_10k()
  if studio_md_particle_tier_select_ok(tier) != 1:
    tier = scene_md_tier_1k()
  var tier_meta: SceneMdParticleTier = scene_md_particle_tier_by_id(tier)
  var _bench: SceneParticleDraw = scene_bench_particle_tier_simulate(tier)
  var particle_n: int = tier_meta.particles
  if _bench.draw_points > 0:
    particle_n = _bench.draw_points
  if li_rt_studio_viewport_display_sync_scientific_step(tier, particle_n) != 1:
    return sim_status_invalid_dt()
  if sim_step(sim_out, dt) != sim_status_ok():
    return sim_status_invalid_dt()
  return sim_status_ok()

# PH-SIM SIM-3 — RL profile: env pool batches sim_step on the studio session (contract stub, not PH-ML async).
def studio_sim_rl_step_hook(sim_out: var SimSessionStub, dt: float) -> int
  requires sim_out.tick >= 0
  requires sim_out.replay_capacity > 0
  ensures result >= 0
  ensures result <= 1
  decreases sim_out.tick
=
  return sim_rl_session_env_pool_step(sim_out, dt)

# PH-SIM SIM-5 — automotive/robotics: sensor raycast bus on session before replay tick.
def studio_sim_sensor_step_hook(sim_out: var SimSessionStub, dt: float) -> int
  requires sim_out.tick >= 0
  requires sim_out.replay_capacity > 0
  ensures result >= 0
  ensures result <= 1
  decreases sim_out.tick
=
  return sim_sensor_session_bus_step(sim_out, dt)

# WP-ROBO-03 / WP-UX-03 — 6-DOF IK on session + sensor bus + replay tick.
def studio_sim_robotics_step_hook(sim_out: var SimSessionStub, dt: float) -> int
  requires sim_out.tick >= 0
  requires sim_out.replay_capacity > 0
  ensures result >= 0
  ensures result <= 1
  decreases sim_out.tick
=
  if dt <= 0.0:
    return sim_status_invalid_dt()
  if sim_robotics_session_ik_step(sim_out, dt) != 1:
    return sim_status_invalid_dt()
  if sim_sensor_session_bus_step(sim_out, dt) != sim_status_ok():
    return sim_status_invalid_dt()
  if sim_step(sim_out, dt) != sim_status_ok():
    return sim_status_invalid_dt()
  return sim_status_ok()

def studio_game_session_physics_load(session: SimSessionStub) -> GamePhysicsState
  requires session.tick >= 0
  ensures result.px == session.game_px
  ensures result.step_count == session.game_physics_steps
  decreases session.tick
=
  var st: GamePhysicsState = game_physics_state_default()
  st.px = session.game_px
  st.py = session.game_py
  st.pz = session.game_pz
  st.vx = session.game_vx
  st.vy = session.game_vy
  st.vz = session.game_vz
  st.step_count = session.game_physics_steps
  return st

def studio_game_session_physics_store(session: var SimSessionStub, state: GamePhysicsState) -> unit
  requires session.tick >= 0
  ensures session.game_px == state.px
  ensures session.game_physics_steps == state.step_count
  decreases session.tick
=
  session.game_px = state.px
  session.game_py = state.py
  session.game_pz = state.pz
  session.game_vx = state.vx
  session.game_vy = state.vy
  session.game_vz = state.vz
  session.game_physics_steps = state.step_count

# PH-SIM vertical gap #4 — game profile: physics.runtime on session-persisted GamePhysicsState.
def studio_game_step_hook(sim_out: var SimSessionStub, frame_dt: float) -> int
  requires frame_dt > 0.0
  requires sim_out.tick >= 0
  ensures result >= 0
  ensures result <= 1
  decreases sim_out.tick
=
  var st: GamePhysicsState = studio_game_session_physics_load(sim_out)
  game_physics_step_hook(st, frame_dt)
  studio_game_session_physics_store(sim_out, st)
  return sim_status_ok()

