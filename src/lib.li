def studio_compose_agent_progress_run(run: StudioAgentRun, status_rect: Rect) -> StudioAgentProgress
  requires run.task_state >= studio_agent_task_idle()
  requires run.task_state <= studio_agent_task_done()
  requires run.step_index >= 0
  requires run.step_total == studio_agent_real_pipeline_steps()
  requires run.step_index <= run.step_total
  ensures result.visible == studio_agent_progress_visible(run.task_state)
  decreases run.step_index
=
  var out: StudioAgentProgress
  out.visible = studio_agent_progress_visible(run.task_state)
  out.step_index = run.step_index
  out.step_total = run.step_total
  out.progress_rect = rect_make(0.0, 0.0, 0.0, 0.0)
  if out.visible == 1:
    out.progress_rect = studio_agent_progress_rect_at(status_rect, out.step_index, out.step_total)
  return out

def studio_agent_sync_chrome_from_run(compose: var StudioShellCompose, run: StudioAgentRun) -> unit
  requires compose.layout.viewport_w > 0.0
  requires run.task_state >= studio_agent_task_idle()
  requires run.task_state <= studio_agent_task_done()
  requires run.agent_context_label >= studio_agent_context_none()
  requires run.agent_context_label <= studio_agent_context_selection()
  ensures compose.agent.task_state == run.task_state
  decreases run.task_state
=
  studio_reactive_resync_agent_task(compose, run.task_state)
  studio_reactive_flush_agent_from_run(compose, run)

def studio_shell_agent_run_tick(compose: var StudioShellCompose, run: var StudioAgentRun) -> int
  requires compose.layout.viewport_w > 0.0
  requires run.task_state >= studio_agent_task_idle()
  requires run.task_state <= studio_agent_task_done()
  ensures result >= 0
  ensures result <= 1
  decreases run.step_index
=
  if run.task_state != studio_agent_task_running():
    return 0
  run = studio_agent_run_next(run)
  studio_agent_sync_chrome_from_run(compose, run)
  return 1

def studio_shell_handle_agent_pointer(compose: var StudioShellCompose, run: var StudioAgentRun, input: InputState) -> int
  requires compose.layout.viewport_w > 0.0
  requires run.task_state >= studio_agent_task_idle()
  requires run.task_state <= studio_agent_task_done()
  requires input.pointer_down >= 0
  requires input.pointer_down <= 1
  ensures result >= studio_agent_action_none()
  ensures result <= studio_agent_action_undo()
  decreases input.pointer_down
=
  if input.pointer_down != 1:
    return studio_agent_action_none()
  if compose.agent.cancel_visible == 1:
    if rect_contains(compose.agent.cancel_rect, input.pointer_x, input.pointer_y) == 1:
      run = studio_agent_run_cancel(run)
      studio_agent_sync_chrome_from_run(compose, run)
      return studio_agent_action_cancel()
  if compose.agent.retry_visible == 1:
    if rect_contains(compose.agent.retry_hint_rect, input.pointer_x, input.pointer_y) == 1:
      run = studio_agent_run_retry(run)
      studio_agent_sync_chrome_from_run(compose, run)
      return studio_agent_action_retry()
  if compose.agent.invoke_input_visible == 1:
    if rect_contains(compose.agent.send_rect, input.pointer_x, input.pointer_y) == 1:
      var ctx: int = studio_agent_context_for_shell(compose.inspector.has_selection, studio_agent_task_idle())
      run = studio_agent_run_start(ctx)
      studio_agent_sync_chrome_from_run(compose, run)
      return studio_agent_action_send()
  return studio_agent_action_none()

