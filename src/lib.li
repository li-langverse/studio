# W4 — 4/8px spacing rhythm (design tokens).
def studio_spacing_unit_px() -> float
  requires true
  ensures result == 4.0
  decreases 0
=
  return 4.0

def studio_spacing_rhythm_px() -> float
  requires true
  ensures result == studio_spacing_unit_px() * 2.0
  decreases 0
=
  return studio_spacing_unit_px() * 2.0

def studio_color_panel_shadow() -> Color
  requires true
  ensures result.a >= 0.2
  ensures result.a <= 0.5
  decreases 0
=
  return color_rgb(0.0, 0.0, 0.0, 0.32)

def studio_paint_panel_shadow_offset_px() -> float
  requires true
