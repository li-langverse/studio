def studio_timeline_reset_for_session(sim_out: var SimSessionStub, duration_ticks: int) raises IO -> int
  requires duration_ticks >= 1
  ensures sim_out.tick == 0
  ensures result == 0
  decreases 0
=
  if sim_reset(sim_out) != sim_status_ok():
    return 1
  var _rt: int = li_rt_studio_timeline_reset_playback()
  studio_timeline_sync_playhead_from_tick(0, duration_ticks)
  return 0

def studio_timeline_scrub_to_tick(tick: int, duration_ticks: int) raises IO -> unit
  requires tick >= 0
  requires duration_ticks >= 1
  ensures true
