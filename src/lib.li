def studio_timeline_tick_sim_step(config: StudioProjectConfig, sim_out: var SimSessionStub, dt: float, duration_ticks: int) raises IO -> int
  requires studio_profile_id_valid(config.active_profile) == 1
  requires sim_out.tick >= 0
  requires duration_ticks >= 1
  ensures result >= -1
  ensures result <= 1
  decreases sim_out.tick
=
  if studio_timeline_playing() == 0:
    return 0
  var tick_before: int = sim_out.tick
  if studio_sim_step_hook(config, sim_out, dt) != sim_status_ok():
    return -1
  studio_timeline_sync_playhead_from_session(sim_out, duration_ticks)
  if sim_out.tick > tick_before:
    return 1
  return 0

