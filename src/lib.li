# WP-GD-04 — glTF ingest via li-assets into studio scene entity count.
def studio_gltf_ingest_mesh(path: str) raises Alloc, IO -> GltfIngestMesh
  requires true
  ensures result.status >= assets_gltf_status_ok()
  ensures result.status <= assets_gltf_status_err()
  decreases 0
=
  return assets_gltf_ingest_path(path)

def studio_shell_apply_gltf_ingest(compose: var StudioShellCompose, path: str) raises Alloc, IO -> int
  requires compose.layout.viewport_w > 0.0
  ensures result >= 0
  ensures result <= 1
  decreases 0
=
  var mesh: GltfIngestMesh = assets_gltf_ingest_path(path)
  if assets_gltf_ingest_ok(mesh) != 1:
    return 0
  compose.scene_entity_count = mesh.entity_slots
  compose.viewport_empty.empty_visible = 0
  compose.viewport_empty.title_rect = rect_make(0.0, 0.0, 0.0, 0.0)
  compose.viewport_empty.cta_rect = rect_make(0.0, 0.0, 0.0, 0.0)
  var sc: Scene = scene_new()
  if assets_gltf_scene_attach(mesh, sc) != 1:
    return 0
  if sc.node_count != compose.scene_entity_count:
    return 0
  return 1

def studio_gltf_ingest_default_into_shell(compose: var StudioShellCompose) raises Alloc, IO -> int
  requires compose.layout.viewport_w > 0.0
  ensures result >= 0
  ensures result <= 1
  decreases 0
=
  var path: str = studio_world_asset_ref_path_default()
  return studio_shell_apply_gltf_ingest(compose, path)

