  if has_selection == 0:
    out.inspector.has_selection = 0
    out.inspector.field_rows = 0
    out.inspector.empty_visible = 1
    out.inspector.hint_line1_rect = studio_inspector_empty_hint_line_rect_at(layout.inspector.x, layout.inspector.y, layout.inspector.w, 0)
    out.inspector.hint_line2_rect = studio_inspector_empty_hint_line_rect_at(layout.inspector.x, layout.inspector.y, layout.inspector.w, 1)
    out.inspector.hint_box_rect = studio_inspector_empty_hint_box_rect_at(layout.inspector.x, layout.inspector.y, layout.inspector.w, layout.inspector.h)
    out.inspector.field_row_rect = rect_make(0.0, 0.0, 0.0, 0.0)
  if has_selection == 1:
    out.inspector.has_selection = 1
    out.inspector.field_rows = studio_inspector_field_rows()
    out.inspector.empty_visible = 0
    out.inspector.hint_line1_rect = rect_make(0.0, 0.0, 0.0, 0.0)
