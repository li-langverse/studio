def studio_publish_bundle_world_sha256_fields(name: int, tick: int, entity_count: int, asset_ref_count: int) raises IO -> float
  requires tick >= 0
  requires entity_count >= 0
  requires asset_ref_count >= 0
  ensures result >= 0.0
  decreases tick
=
  var n_f: float = studio_int_as_float(name)
  var t_f: float = studio_int_as_float(tick)
  var e_f: float = studio_int_as_float(entity_count)
  var a_f: float = studio_int_as_float(asset_ref_count)
  return n_f * 1000.0 + t_f * 10.0 + e_f + a_f * 0.1

def studio_publish_bundle_world_sha256(snapshot: WorldSnapshot) -> float
  requires true
  ensures result >= 0.0
  decreases snapshot.tick
=
  return studio_publish_bundle_world_sha256_fields(snapshot.name, snapshot.tick, snapshot.entity_count, snapshot.asset_ref_count)

def studio_publish_bundle_world_sha256_from_checkpoint(checkpoint: StudioWorldCheckpoint) -> float
  requires checkpoint.tick >= 0
  ensures result >= 0.0
  decreases checkpoint.tick
=
  if checkpoint.valid == 1:
    return studio_publish_bundle_world_sha256_fields(checkpoint.name, checkpoint.tick, checkpoint.entity_count, checkpoint.asset_ref_count)
  var snap: WorldSnapshot = studio_world_scaffold_snapshot()
  return studio_publish_bundle_world_sha256(snap)

def studio_publish_bundle_manifest_checksum(
    lic_version: int,
    profile_id: int,
    determinism_tier: int,
    sim_checksum: float,
    world_sha256: float,
    figure_magic: int,
    data_magic: int) raises IO -> float
  requires lic_version >= 0
  requires sim_checksum >= 0.0
  requires world_sha256 >= 0.0
  ensures result >= 0.0
  decreases lic_version
=
  var lv_f: float = studio_int_as_float(lic_version)
  var pf_f: float = studio_int_as_float(profile_id)
  var dt_f: float = studio_int_as_float(determinism_tier)
  var fig_f: float = studio_int_as_float(figure_magic)
  var dat_f: float = studio_int_as_float(data_magic)
  return lv_f + pf_f * 10.0 + dt_f * 100.0 + sim_checksum + world_sha256 + fig_f + dat_f

type PublishBundleResult = object
  public ok: int
  public lic_version: int
  public profile_id: int
  public determinism_tier: int
  public sim_checksum: float
  public world_sha256: float
  public figure_count: int
  public data_count: int
  public entry_count: int
  public manifest_checksum: float
  public byte_checksum: float
  public magic_tag: int

def studio_publish_bundle(
    config: StudioProjectConfig,
    checkpoint: StudioWorldCheckpoint,
    sim_checksum: float,
    viz_tick: int,
    proof_pass: int) -> PublishBundleResult
  requires studio_profile_id_valid(config.active_profile) == 1
  requires studio_determinism_tier_valid(config.determinism_tier) == 1
  requires sim_checksum >= 0.0
  requires viz_tick >= 1
  requires viz_tick <= 64
  ensures result.profile_id == config.active_profile
  ensures result.determinism_tier == config.determinism_tier
  ensures result.ok >= 0
  ensures result.ok <= 1
  decreases config.active_profile
=
  var r: PublishBundleResult
  r.ok = 0
  r.lic_version = li_std_studio_version()
  r.profile_id = config.active_profile
  r.determinism_tier = config.determinism_tier
  r.sim_checksum = sim_checksum
  r.world_sha256 = studio_publish_bundle_world_sha256_from_checkpoint(checkpoint)
  r.figure_count = 0
  r.data_count = 0
  r.entry_count = 0
  r.manifest_checksum = 0.0
  r.byte_checksum = 0.0
  r.magic_tag = 0
  if studio_publish_proof_pass_ok(proof_pass) != 1:
    return r
  var fig_magic: int = 0
  var dat_magic: int = 0
  var fig: PublishFigureResult = studio_publish_figure(studio_publish_format_svg(), studio_publish_template_nature_single(), sim_checksum, proof_pass)
  if fig.ok == 1:
    r.figure_count = 1
    fig_magic = fig.magic_tag
  if config.active_profile == studio_profile_sim_scientific():
    var tbl: PublishTableResult = studio_publish_table_from_viz_tick(viz_tick, studio_publish_table_format_hdf5(), sim_checksum, proof_pass)
    if tbl.ok == 1:
      r.data_count = 1
      dat_magic = tbl.magic_tag
  r.entry_count = 1 + r.figure_count + r.data_count
  if r.entry_count < 2:
    return r
  r.manifest_checksum = studio_publish_bundle_manifest_checksum(r.lic_version, r.profile_id, r.determinism_tier, sim_checksum, r.world_sha256, fig_magic, dat_magic)
  var ec_f: float = studio_int_as_float(r.entry_count)
  var fc_f: float = studio_int_as_float(r.figure_count)
  var dc_f: float = studio_int_as_float(r.data_count)
  r.byte_checksum = r.manifest_checksum + ec_f + fc_f + dc_f
  r.magic_tag = studio_publish_bundle_magic_zip()
  r.ok = 1
  return r

