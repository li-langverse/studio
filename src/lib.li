  requires true
  ensures result == 0
  decreases 0
=
  return 0

def studio_publish_table_wizard_step_proof() -> int
  requires true
  ensures result == 1
  decreases 0
=
  return 1

def studio_publish_table_wizard_step_export() -> int
  requires true
  ensures result == 2
  decreases 0
=
  return 2

type StudioPublishTableFlowState = object
  public format: int
  public viz_tick: int
  public wizard_step: int
  public click_count: int
  public proof_pass: int
  public export_ok: int
  public last_magic: int
  public last_row_count: int

def studio_publish_table_flow_init(fmt: int, viz_tick: int) -> StudioPublishTableFlowState
  requires studio_publish_table_format_ok(fmt) == 1
  requires viz_tick >= 1
  requires viz_tick <= 64
  ensures result.format == fmt
  ensures result.viz_tick == viz_tick
  ensures result.wizard_step == studio_publish_table_wizard_step_select()
  decreases fmt
=
  var f: StudioPublishTableFlowState
  f.format = fmt
  f.viz_tick = viz_tick
  f.wizard_step = studio_publish_table_wizard_step_select()
  f.click_count = 0
  f.proof_pass = 0
  f.export_ok = 0
  f.last_magic = 0
  f.last_row_count = 0
  return f

def studio_publish_table_flow_advance(
    flow: var StudioPublishTableFlowState,
    sim_checksum: float) -> int
  requires studio_publish_table_format_ok(flow.format) == 1
  requires flow.viz_tick >= 1
  requires flow.viz_tick <= 64
  requires sim_checksum >= 0.0
  ensures flow.click_count >= 0
  ensures result >= 0
  ensures result <= 6
  decreases flow.wizard_step
=
  flow.click_count = flow.click_count + 1
  if flow.wizard_step == studio_publish_table_wizard_step_select():
    flow.wizard_step = studio_publish_table_wizard_step_proof()
    return 0
  if flow.wizard_step == studio_publish_table_wizard_step_proof():
    if flow.proof_pass != 1:
      return 1
    flow.wizard_step = studio_publish_table_wizard_step_export()
    return 0
  if flow.wizard_step == studio_publish_table_wizard_step_export():
    var tbl: PublishTableResult = studio_publish_table_from_viz_tick(flow.viz_tick, flow.format, sim_checksum, flow.proof_pass)
    if tbl.ok != 1:
      return 2
    if tbl.magic_tag != studio_publish_table_magic_for_format(flow.format):
      return 3
    if tbl.row_count <= 0:
      return 4
    if tbl.col_count != studio_publish_table_schema_columns():
      return 5
    flow.export_ok = 1
    flow.last_magic = tbl.magic_tag
    flow.last_row_count = tbl.row_count
    return 0
  return 6

def studio_publish_table_three_click_flow(
    fmt: int,
    viz_tick: int,
    sim_checksum: float,
    proof_pass: int) -> int
  requires studio_publish_table_format_ok(fmt) == 1
  requires viz_tick >= 1
  requires viz_tick <= 64
  requires sim_checksum >= 0.0
  ensures result >= 0
  ensures result <= 8
  decreases fmt
=
  var flow: StudioPublishTableFlowState = studio_publish_table_flow_init(fmt, viz_tick)
  if studio_publish_table_flow_advance(flow, sim_checksum) != 0:
    return 1
  flow.proof_pass = proof_pass
  if studio_publish_table_flow_advance(flow, sim_checksum) != 0:
    return 2
  if proof_pass != 1:
    return 3
  if studio_publish_table_flow_advance(flow, sim_checksum) != 0:
    return 4
  if flow.click_count != 3:
    return 5
  if flow.export_ok != 1:
    return 6
  if flow.last_magic != studio_publish_table_magic_for_format(fmt):
    return 7
  if flow.last_row_count <= 0:
    return 8
  return 0

