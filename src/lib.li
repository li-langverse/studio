=
  if profile_id == studio_profile_game():
    return 1
  if profile_id == studio_profile_sim_rl():
    return 1
  if profile_id == studio_profile_sim_scientific():
    return 1
  if profile_id == studio_profile_sim_drug_design():
    return 1
  return 0

def studio_viewport_menu_btn_width_px() -> float
  requires true
  ensures result == 72.0
  decreases 0
=
  return 72.0

def studio_viewport_menu_btn_height_px() -> float
  requires true
  ensures result == 22.0
  decreases 0
=
  return 22.0

def studio_viewport_menu_btn_rect_at(vp: Rect, slot: int) -> Rect
  requires vp.w >= studio_viewport_menu_btn_width_px() * 3.0 + 32.0
  requires vp.h >= studio_viewport_menu_btn_height_px() + 16.0
  requires slot >= 0
  requires slot <= 2
  ensures result.w == studio_viewport_menu_btn_width_px()
  ensures result.h == studio_viewport_menu_btn_height_px()
  decreases slot
=
  var pad: float = 12.0
  var gap: float = 6.0
  var step: float = studio_viewport_menu_btn_width_px() + gap
  var x: float = vp.x + pad
  if slot == 1:
    x = x + step
  if slot == 2:
    x = x + step + step
  var y: float = vp.y + pad
  return rect_make(x, y, studio_viewport_menu_btn_width_px(), studio_viewport_menu_btn_height_px())

def studio_viewport_hud_fps_rect(vp: Rect) -> Rect
  requires vp.w >= 80.0
  requires vp.h >= 24.0
  ensures result.w == 56.0
  ensures result.h == 14.0
  decreases 0
=
  return rect_make(vp.x + 8.0, vp.y + 8.0, 56.0, 14.0)

def studio_viewport_hud_particle_rect(vp: Rect) -> Rect
  requires vp.w >= 140.0
  requires vp.h >= 24.0
  ensures result.w == 72.0
  ensures result.h == 14.0
  decreases 0
=
  return rect_make(vp.x + 68.0, vp.y + 8.0, 72.0, 14.0)

def studio_viewport_hud_native_badge_rect(vp: Rect) -> Rect
  requires vp.w >= 160.0
  requires vp.h >= 24.0
  ensures result.w == 18.0
  ensures result.h == 14.0
  decreases 0
=
  return rect_make(vp.x + 144.0, vp.y + 8.0, 18.0, 14.0)

def studio_viewport_display_tier_label_rect(vp: Rect) -> Rect
  requires vp.w >= 120.0
  requires vp.h >= 24.0
  ensures result.w >= 80.0
  decreases 0
=
  return rect_make(vp.x + 12.0, vp.y + vp.h - 28.0, 120.0, 16.0)

def studio_viewport_display_biomol_chip_rect(vp: Rect) -> Rect
  requires vp.w >= 96.0
  requires vp.h >= 24.0
  ensures result.w == 88.0
  ensures result.h == 18.0
  decreases 0
=
  return rect_make(vp.x + vp.w - 100.0, vp.y + vp.h - 28.0, 88.0, 18.0)

def studio_viewport_display_particle_dot_rect_at(vp: Rect, index: int) -> Rect
  requires vp.w >= 64.0
  requires vp.h >= 64.0
  requires index >= 0
  requires index < studio_viewport_display_particle_dot_count()
  ensures result.w == 6.0
  ensures result.h == 6.0
  decreases index
=
  var cx: float = vp.x + vp.w * 0.35
  var cy: float = vp.y + vp.h * 0.42
  if index == 1:
    cx = cx + 14.0
  if index == 2:
    cx = cx + 28.0
  if index == 3:
    cx = cx + 42.0
  if index == 4:
    cy = cy + 14.0
  if index == 5:
    cx = cx + 14.0
    cy = cy + 14.0
  if index == 6:
    cx = cx + 28.0
    cy = cy + 14.0
  if index == 7:
    cx = cx + 42.0
    cy = cy + 14.0
  return rect_make(cx, cy, 6.0, 6.0)

def studio_viewport_display_particle_dot_count() -> int
  requires true
  ensures result == 8
  decreases 0
=
  return 8

type StudioViewportDisplayCompose = object
  public background: int
  public particle_tier_id: int
  public biomol_style: int
  public tier_particles: int
  public tier_label_rect: Rect
  public biomol_chip_rect: Rect
  public particle_dots_visible: int
  public fps_display: int
  public fps_meets_target: int
  public fps_hud_tag: int
  public hud_native_pixels: int
  public fps_hud_rect: Rect
  public particle_hud_rect: Rect
  public native_badge_rect: Rect
  public grid_legend_rect: Rect

type StudioViewportMenuCompose = object
  public menu_visible: int
  public bg_btn: Rect
  public particle_btn: Rect
  public biomol_btn: Rect

def studio_viewport_display_compose_new() -> StudioViewportDisplayCompose
  requires true
  ensures result.background == studio_viewport_bg_solid()
  ensures result.particle_tier_id == studio_particle_display_off()
  decreases 0
=
  var d: StudioViewportDisplayCompose
  d.background = studio_viewport_bg_solid()
  d.particle_tier_id = studio_particle_display_off()
  d.biomol_style = studio_biomol_style_cartoon()
  d.tier_particles = 0
  d.tier_label_rect = rect_make(0.0, 0.0, 0.0, 0.0)
  d.biomol_chip_rect = rect_make(0.0, 0.0, 0.0, 0.0)
  d.particle_dots_visible = 0
  d.fps_display = 0
  d.fps_meets_target = 0
  d.fps_hud_tag = 0
  d.hud_native_pixels = 0
  d.fps_hud_rect = rect_make(0.0, 0.0, 0.0, 0.0)
  d.particle_hud_rect = rect_make(0.0, 0.0, 0.0, 0.0)
  d.native_badge_rect = rect_make(0.0, 0.0, 0.0, 0.0)
  d.grid_legend_rect = rect_make(0.0, 0.0, 0.0, 0.0)
  return d

def studio_viewport_menu_compose_new() -> StudioViewportMenuCompose
  requires true
  ensures result.menu_visible == 0
  decreases 0
=
  var m: StudioViewportMenuCompose
  m.menu_visible = 0
  m.bg_btn = rect_make(0.0, 0.0, 0.0, 0.0)
  m.particle_btn = rect_make(0.0, 0.0, 0.0, 0.0)
  m.biomol_btn = rect_make(0.0, 0.0, 0.0, 0.0)
  return m

def studio_compose_viewport_display(vp: Rect, profile_id: int) raises IO -> StudioViewportDisplayCompose
  requires vp.w >= 0.0
  requires vp.h >= 0.0
  requires studio_profile_id_valid(profile_id) == 1
  ensures result.background >= studio_viewport_bg_solid()
  ensures result.tier_label_rect.w >= 0.0
  decreases profile_id
=
  var out: StudioViewportDisplayCompose = studio_viewport_display_compose_new()
  out.background = studio_viewport_display_read_bg()
  out.particle_tier_id = studio_viewport_display_read_particle_tier()
  out.biomol_style = studio_viewport_display_read_biomol_style()
  out.tier_label_rect = studio_viewport_display_tier_label_rect(vp)
  out.biomol_chip_rect = studio_viewport_display_biomol_chip_rect(vp)
  if out.particle_tier_id >= scene_md_tier_1k():
    var tier: SceneMdParticleTier = scene_md_particle_tier_by_id(out.particle_tier_id)
    var draw_pts: int = studio_viewport_display_read_particle_draw_points()
    out.tier_particles = tier.particles
    if draw_pts > 0:
      out.tier_particles = draw_pts
    out.particle_dots_visible = 1
  var fps_counter: RenderFpsCounter = render_fps_counter_shell_simulate()
  if lig_present_host_active() == 1:
    fps_counter = render_viewport_host_fps_counter(1)
  out.fps_display = render_fps_counter_display_fps(fps_counter)
  out.fps_meets_target = render_fps_counter_meets_target(fps_counter)
  out.fps_hud_tag = render_fps_counter_hud_tag(fps_counter)
  out.hud_native_pixels = fps_counter.native_pixels
  out.fps_hud_rect = studio_viewport_hud_fps_rect(vp)
  out.particle_hud_rect = studio_viewport_hud_particle_rect(vp)
  out.native_badge_rect = studio_viewport_hud_native_badge_rect(vp)
  out.grid_legend_rect = studio_viewport_hud_grid_legend_rect(vp)
  if profile_id == studio_profile_sim_rl():
    out.background = studio_viewport_bg_grid()
    out.particle_tier_id = scene_md_tier_1k()
    out.tier_particles = 1000
    out.particle_dots_visible = 1
  if profile_id == studio_profile_sim_drug_design():
    out.background = studio_viewport_bg_grid()
    if out.biomol_style == studio_biomol_style_cartoon():
      out.biomol_style = studio_biomol_style_sticks()
    if out.particle_tier_id < scene_md_tier_1k():
      out.particle_tier_id = scene_md_tier_1k()
    if out.particle_tier_id >= scene_md_tier_1k():
      var drug_tier: SceneMdParticleTier = scene_md_particle_tier_by_id(out.particle_tier_id)
      out.tier_particles = drug_tier.particles
      out.particle_dots_visible = 1
  if profile_id == studio_profile_game():
    out.background = studio_viewport_bg_grid()
    out.particle_tier_id = studio_particle_display_off()
    out.particle_dots_visible = 0
    out.tier_particles = 0
  if profile_id == studio_profile_sim_scientific():
    if out.particle_tier_id >= scene_md_tier_1k():
      var viz_tick: int = studio_viz_tick_for_particle_tier(out.particle_tier_id)
      var viz_pipe: VizPipelineState = studio_sim_scientific_viz_for_tick(viz_tick)
      if viz_pipe.source_count >= 1:
        out = studio_viewport_display_apply_viz_pipeline(out, viz_pipe)
  return out

def studio_viewport_hud_ok(display: StudioViewportDisplayCompose) -> int
  requires display.fps_display >= 0
  requires display.hud_native_pixels >= 0
  requires display.hud_native_pixels <= 1
  ensures result >= 0
  ensures result <= 1
  decreases display.fps_hud_tag
=
  if display.fps_display < 60:
    return 0
  if display.fps_meets_target != 1:
    return 0
  if display.fps_hud_tag != 1:
    return 0
  if display.fps_hud_rect.w != 56.0:
    return 0
  if display.particle_hud_rect.w != 72.0:
    return 0
  if display.hud_native_pixels != 0:
    return 0
  return 1

def studio_viewport_hud_particle_ok(display: StudioViewportDisplayCompose) -> int
  requires display.tier_particles >= 0
  ensures result >= 0
  ensures result <= 1
  decreases display.tier_particles
=
  if display.particle_tier_id < scene_md_tier_1k():
    return 1
  if display.tier_particles < 1000:
    return 0
  return 1

def studio_viewport_hud_color_fps(meets_target: int, native_pixels: int) -> Color
  requires meets_target >= 0
  requires meets_target <= 1
  requires native_pixels >= 0
  requires native_pixels <= 1
  ensures result.a == 1.0
  decreases meets_target
=
  if native_pixels == 1:
    return studio_color_accent_cyan()
  if meets_target == 1:
    return color_rgb(0.2, 0.75, 0.45, 1.0)
  return studio_color_accent_amber()

def studio_viewport_hud_color_particle(tier_particles: int) -> Color
  requires tier_particles >= 0
  ensures result.a == 1.0
  decreases tier_particles
=
  if tier_particles >= 100000:
    return color_rgb(0.85, 0.35, 0.55, 1.0)
  if tier_particles >= 10000:
    return studio_color_accent_amber()
  if tier_particles >= 1000:
    return studio_color_accent_cyan()
  return studio_color_border()

def studio_viewport_hud_color_native_badge(native_pixels: int) -> Color
  requires native_pixels >= 0
  requires native_pixels <= 1
  ensures result.a == 1.0
  decreases native_pixels
=
  if native_pixels == 1:
    return studio_color_accent_cyan()
  return studio_color_border()

def studio_paint_viewport_hud_chip_cmds() -> int
  requires true
  ensures result == 2
  decreases 0
=
  return 2

def studio_paint_viewport_hud_cmds() -> int
  requires true
  ensures result == 4 * studio_paint_viewport_hud_chip_cmds() + 4 * studio_paint_glyph_run_cmds()
  decreases 0
=
  return 4 * studio_paint_viewport_hud_chip_cmds() + 4 * studio_paint_glyph_run_cmds()

def studio_paint_viewport_hud_chip(frame: var PaintFrame, chip: Rect, color: Color) -> unit
  requires frame.cmd_count >= 0
  requires chip.w >= 8.0
  requires chip.h >= 8.0
  ensures frame.cmd_count == old(frame.cmd_count) + studio_paint_viewport_hud_chip_cmds()
  decreases 0
=
  paint_frame_push(frame, paint_cmd_fill_round(chip, studio_color_bg_elevated(), studio_radius_sm_px()))
  paint_frame_push(frame, paint_cmd_stroke_round(chip, color, 1.0, studio_radius_sm_px()))

def studio_paint_viewport_hud(frame: var PaintFrame, display: StudioViewportDisplayCompose) -> unit
  requires frame.cmd_count >= 0
  ensures frame.cmd_count == old(frame.cmd_count) + studio_paint_viewport_hud_cmds()
  decreases display.fps_display
=
  var fps_color: Color = studio_viewport_hud_color_fps(display.fps_meets_target, display.hud_native_pixels)
  studio_paint_viewport_hud_chip(frame, display.fps_hud_rect, fps_color)
  studio_paint_glyph_text(frame, display.fps_hud_rect, studio_viewport_hud_fps_label_first_codepoint(), studio_viewport_hud_fps_label_glyph_count(), studio_color_text_primary())
  var part_color: Color = studio_viewport_hud_color_particle(display.tier_particles)
  studio_paint_viewport_hud_chip(frame, display.particle_hud_rect, part_color)
  studio_paint_glyph_text(frame, display.particle_hud_rect, studio_viewport_hud_particle_label_first_codepoint(), studio_viewport_hud_particle_label_glyph_count(), studio_color_text_primary())
  var native_color: Color = studio_viewport_hud_color_native_badge(display.hud_native_pixels)
  studio_paint_viewport_hud_chip(frame, display.native_badge_rect, native_color)
  studio_paint_glyph_text(frame, display.native_badge_rect, studio_viewport_hud_native_label_first_codepoint(), studio_viewport_hud_native_label_glyph_count(), studio_color_text_muted())
  var grid_color: Color = studio_color_viewport_grid()
  studio_paint_viewport_hud_chip(frame, display.grid_legend_rect, grid_color)
  studio_paint_glyph_text(frame, display.grid_legend_rect, studio_viewport_hud_grid_label_first_codepoint(), studio_viewport_hud_grid_label_glyph_count(), studio_color_text_muted())

def studio_compose_viewport_menu(vp: Rect, profile_id: int) -> StudioViewportMenuCompose
  requires vp.w >= 0.0
  requires vp.h >= 0.0
  requires studio_profile_id_valid(profile_id) == 1
  ensures result.menu_visible >= 0
  ensures result.menu_visible <= 1
  decreases profile_id
=
  var out: StudioViewportMenuCompose = studio_viewport_menu_compose_new()
  if studio_viewport_display_profile_wants_scene(profile_id) != 1:
    return out
  out.menu_visible = 1
  out.bg_btn = studio_viewport_menu_btn_rect_at(vp, 0)
  out.particle_btn = studio_viewport_menu_btn_rect_at(vp, 1)
  out.biomol_btn = studio_viewport_menu_btn_rect_at(vp, 2)
  return out

def studio_attach_viewport_shell(compose: var StudioShellCompose) raises IO -> unit
  requires studio_profile_id_valid(compose.config.active_profile) == 1
  ensures compose.viewport_display.background >= studio_viewport_bg_solid()
  ensures compose.viewport_error.error_kind >= studio_viewport_error_none()
  ensures compose.viewport_error.error_kind <= studio_err_missing_asset()
  decreases 0
=
  var pid: int = compose.config.active_profile
  compose.viewport_display = studio_compose_viewport_display(compose.layout.viewport, pid)
  compose.viewport_menu = studio_compose_viewport_menu(compose.layout.viewport, pid)
  var err_kind: int = studio_viewport_error_sync_from_wgpu(compose)
  var lay_err: StudioShellLayout = compose.layout
  compose.viewport_error = studio_compose_viewport_error_overlay(lay_err, err_kind)

# WP-DRUG-03 — adaptive shell layout keyed to LITL stage (drug profile).
def studio_drug_litl_inspector_field_rows(litl_stage: int) -> int
  requires litl_stage >= 0
  requires litl_stage <= 4
  ensures result >= 2
  ensures result <= 4
  decreases litl_stage
=
  if litl_stage == drug_litl_stage_dft():
    return 4
  if litl_stage == drug_litl_stage_lab():
    return 4
  if litl_stage == drug_litl_stage_retrain():
    return 3
  return 2

def studio_adaptive_panel_region_for_litl_stage(litl_stage: int) -> int
  requires drug_litl_stage_valid(litl_stage) == 1
  ensures result >= studio_region_dock()
  ensures result <= studio_region_agent_strip()
  decreases litl_stage
=
  if litl_stage == drug_litl_stage_hypothesis():
    return studio_region_inspector()
  if litl_stage == drug_litl_stage_generate():
    return studio_region_viewport()
  if litl_stage == drug_litl_stage_dft():
    return studio_region_inspector()
  if litl_stage == drug_litl_stage_lab():
    return studio_region_timeline()
  return studio_region_agent_strip()

def studio_adaptive_panel_set_id(litl_stage: int) -> int
  requires drug_litl_stage_valid(litl_stage) == 1
  ensures result == litl_stage
  decreases litl_stage
=
  return litl_stage

def studio_shell_apply_adaptive_panel_set(compose: var StudioShellCompose, litl_stage: int) -> unit
  requires drug_litl_stage_valid(litl_stage) == 1
  ensures compose.panel.active_region == studio_adaptive_panel_region_for_litl_stage(litl_stage)
  ensures compose.inspector.field_rows == studio_drug_litl_inspector_field_rows(litl_stage)
  decreases litl_stage
=
  compose.panel.active_region = studio_adaptive_panel_region_for_litl_stage(litl_stage)
  compose.inspector.field_rows = studio_drug_litl_inspector_field_rows(litl_stage)

def studio_adaptive_layout_for_drug_tick(w: float, h: float, tick: int) -> StudioShellLayout
  requires w > 0.0
  requires h > 0.0
  requires tick >= 0
  ensures result.inspector.w == studio_inspector_width_for_drug_litl_stage(drug_litl_stage_from_tick(tick))
  decreases tick
=
  var stage: int = drug_litl_stage_from_tick(tick)
  return layout_studio_shell_drug_litl(w, h, stage)

def studio_mcp_dispatch_adaptive_drug(w: float, h: float, tick: int) -> StudioAgentToolRequest
  requires w > 0.0
  requires h > 0.0
  requires tick >= 0
  ensures result.tool_id == studio_mcp_studio_adaptive_layout()
  ensures result.status == studio_mcp_tool_status_ok()
  ensures result.result_code == drug_litl_stage_from_tick(tick)
  decreases tick
=
  var out: StudioAgentToolRequest = studio_agent_tool_request_none()
  out.tool_id = studio_mcp_studio_adaptive_layout()
  out.status = studio_mcp_tool_status_ok()
  out.result_code = studio_mcp_tool_result_ok()
  var stage: int = drug_litl_stage_from_tick(tick)
  out.result_code = stage
  var layout: StudioShellLayout = layout_studio_shell_drug_litl(w, h, stage)
  if layout.inspector.w < studio_inspector_width_for_drug_litl_stage(stage):
    out.status = studio_mcp_tool_status_failed()
    out.result_code = studio_mcp_tool_result_err_io()
    return out
  return out

def studio_compose_shell_drug_litl(w: float, h: float, tick: int, has_selection: int) -> StudioShellCompose
  requires w > 0.0
  requires h > 0.0
  requires tick >= 0
  requires has_selection >= 0
  requires has_selection <= 1
  ensures result.config.active_profile == studio_profile_sim_drug_design()
  decreases tick
=
  var stage: int = drug_litl_stage_from_tick(tick)
  var layout: StudioShellLayout = layout_studio_shell_drug_litl(w, h, stage)
  var out: StudioShellCompose = studio_compose_shell_profile(w, h, 0, has_selection, studio_profile_sim_drug_design())
  out.layout = layout
  studio_shell_apply_adaptive_panel_set(out, stage)
  studio_viewport_display_prepare_for_profile(studio_profile_sim_drug_design())
  out.scene_entity_count = 1
  out.viewport_empty.empty_visible = 0
  studio_attach_viewport_shell(out)
  return out

