def studio_reactive_timeline_sync_playhead(compose: var StudioShellCompose, tick: int, duration_ticks: int) raises IO -> unit
  requires compose.layout.viewport_w > 0.0
  requires tick >= 0
  requires duration_ticks >= 1
  ensures compose_dep_region_is_dirty(compose.reactive.graph, compose_region_id_timeline()) == 0
