type StudioAgentToolRequest = object
  public tool_id: int
  public status: int
  public result_code: int

def studio_agent_tool_request_none() -> StudioAgentToolRequest
  requires true
  ensures result.tool_id == studio_mcp_tool_unknown()
  ensures result.status == studio_mcp_tool_status_idle()
  ensures result.result_code == studio_mcp_tool_result_ok()
  decreases 0
=
  var out: StudioAgentToolRequest
  out.tool_id = studio_mcp_tool_unknown()
  out.status = studio_mcp_tool_status_idle()
  out.result_code = studio_mcp_tool_result_ok()
  return out

