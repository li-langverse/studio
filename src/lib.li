def studio_game_world_checkpoint_from_session(session: SimSessionStub) -> WorldSnapshot
  requires session.tick >= 0
  ensures world_snapshot_valid(result) == 1
  ensures result.name == world_name_slot_arena()
  ensures result.tick == session.tick
  ensures result.entity_count == studio_game_entity_count_stub()
  ensures result.asset_ref_count == studio_game_asset_ref_count_stub()
  decreases session.tick
=
  var snap: WorldSnapshot
  snap.name = world_name_slot_arena()
  snap.tick = session.tick
  snap.entity_count = studio_game_entity_count_stub()
  snap.asset_ref_count = studio_game_asset_ref_count_stub()
  return snap

def studio_game_world_checkpoint_stub(snapshot: WorldSnapshot) -> int
  requires true
  ensures result >= 0
  ensures result <= 1
  decreases snapshot.tick
=
  if world_snapshot_valid(snapshot) != 1:
    return 0
  if snapshot.name != world_name_slot_arena():
    return 0
  if snapshot.tick < 0:
    return 0
  if snapshot.entity_count != studio_game_entity_count_stub():
    return 0
  if snapshot.asset_ref_count != studio_game_asset_ref_count_stub():
    return 0
  return 1

def studio_world_checkpoint_empty() -> StudioWorldCheckpoint
  requires true
  ensures result.valid == 0
  ensures result.tick == 0
  decreases 0
=
  var c: StudioWorldCheckpoint
  c.valid = 0
  c.name = world_name_slot_default()
  c.tick = 0
  c.entity_count = 0
  c.asset_ref_count = 0
  return c

def studio_world_checkpoint_from_snapshot(snapshot: WorldSnapshot) -> StudioWorldCheckpoint
  requires true
  ensures result.tick == snapshot.tick
  ensures result.entity_count == snapshot.entity_count
  ensures result.asset_ref_count == snapshot.asset_ref_count
  decreases snapshot.tick
=
  var c: StudioWorldCheckpoint
  c.name = snapshot.name
  c.tick = snapshot.tick
  c.entity_count = snapshot.entity_count
  c.asset_ref_count = snapshot.asset_ref_count
  c.valid = 0
  if studio_game_world_checkpoint_stub(snapshot) == 1:
    c.valid = 1
  return c

def studio_world_checkpoint_capture(profile_id: int, session: SimSessionStub) -> StudioWorldCheckpoint
  requires session.tick >= 0
  ensures result.tick >= 0
  decreases profile_id
=
  if profile_id != studio_profile_game():
    return studio_world_checkpoint_empty()
  var snap: WorldSnapshot = studio_game_world_checkpoint_from_session(session)
  return studio_world_checkpoint_from_snapshot(snap)

def studio_world_checkpoint_after_sim_tick(profile_id: int, session: SimSessionStub) -> int
  requires session.tick >= 0
  ensures result >= 0
  ensures result <= 1
  decreases profile_id
=
  if profile_id != studio_profile_game():
    return sim_status_ok()
  var c: StudioWorldCheckpoint = studio_world_checkpoint_capture(profile_id, session)
  if c.valid != 1:
    return sim_status_invalid_dt()
  if c.tick != session.tick:
    return sim_status_invalid_dt()
  if c.entity_count != studio_game_entity_count_stub():
    return sim_status_invalid_dt()
  if c.asset_ref_count != studio_game_asset_ref_count_stub():
    return sim_status_invalid_dt()
  return sim_status_ok()

def studio_shell_world_checkpoint_store(compose: var StudioShellCompose, session: SimSessionStub) -> unit
  requires session.tick >= 0
  ensures compose.world_checkpoint.tick == session.tick
  decreases session.tick
=
  compose.world_checkpoint = studio_world_checkpoint_capture(compose.config.active_profile, session)

def studio_shell_timeline_tick_sim_step(compose: var StudioShellCompose, config: StudioProjectConfig, sim_out: var SimSessionStub, dt: float, duration_ticks: int) raises IO -> int
  requires studio_mode_valid(compose.mode) == 1
  requires studio_profile_id_valid(config.active_profile) == 1
  requires sim_out.tick >= 0
  requires duration_ticks >= 1
  ensures result >= -1
  ensures result <= 1
  decreases compose.mode
=
  if studio_mode_sim_step_allowed(compose.mode, studio_timeline_playing()) != 1:
    return 0
  var rc: int = studio_timeline_tick_sim_step(config, sim_out, dt, duration_ticks)
  if rc == 1:
    studio_shell_world_checkpoint_store(compose, sim_out)
    studio_reactive_timeline_sync_playhead(compose, sim_out.tick, duration_ticks)
  return rc

def studio_game_world_checkpoint_roundtrip(session: SimSessionStub) raises Alloc, IO -> int
  requires session.tick >= 0
  ensures result >= 0
  ensures result <= 1
  decreases session.tick
=
  var snap: WorldSnapshot = studio_game_world_checkpoint_from_session(session)
  if studio_game_world_checkpoint_stub(snap) != 1:
    return 0
  if world_roundtrip_ok(snap) != 1:
    return 0
  var buf: str = world_save_to_buffer(snap)
  var loaded: WorldSnapshot = world_load_from_buffer(buf)
  if studio_game_world_checkpoint_stub(loaded) != 1:
    return 0
  if world_snapshot_fields_match(snap, loaded) != 1:
    return 0
  return 1

def studio_game_world_checkpoint_path() raises Alloc, IO -> str
  requires true
  ensures result != ""
  decreases 0
=
  return world_checkpoint_path_default()

def studio_game_world_checkpoint_file_roundtrip(session: SimSessionStub) raises Alloc, IO -> int
  requires session.tick >= 0
  ensures result >= 0
  ensures result <= 1
  decreases session.tick
=
  var snap: WorldSnapshot = studio_game_world_checkpoint_from_session(session)
  if studio_game_world_checkpoint_stub(snap) != 1:
    return 0
  var path_save: str = studio_game_world_checkpoint_path()
  if world_save_to_path(snap, path_save) != 1:
    return 0
  var path_load: str = studio_game_world_checkpoint_path()
  var loaded: WorldSnapshot = world_load_from_path(path_load)
  if studio_game_world_checkpoint_stub(loaded) != 1:
    return 0
  if world_snapshot_fields_match(snap, loaded) != 1:
    return 0
  return 1

# PH-SIM vertical gap #9 — MD particle tier gate via li-scene tier metadata + lig ledger.
def studio_md_particle_tier_select_ok(tier_id: int) -> int
  requires tier_id >= 0
  requires tier_id <= 2
  ensures result >= 0
  ensures result <= 1
  decreases tier_id
=
  var tier: SceneMdParticleTier = scene_md_particle_tier_by_id(tier_id)
  if tier.tier_id != tier_id:
    return 0
  if tier.particles <= 0:
    return 0
  if tier.kernel_tag != scene_md_kernel_lennard_jones():
    return 0
  var ledger: LigMemoryLedger = scene_md_particle_memory_ledger_default()
  if tier_id == scene_md_tier_100k():
    if scene_md_particle_tier_refuse_md_100k_over_budget(ledger) == 1:
      return 0
  if scene_md_particle_tier_would_fit(tier_id, ledger) != 1:
    return 0
  return 1

# PH-SIM SIM-1 + vertical gap #4 — profile sync, domain tick stub, session counter.
def studio_sim_step_hook(config: StudioProjectConfig, sim_out: var SimSessionStub, dt: float) -> int
  requires studio_profile_id_valid(config.active_profile) == 1
  requires sim_out.tick >= 0
  ensures sim_out.studio_profile_id == config.active_profile
  ensures sim_out.sim_contract_id == li_sim_profile_from_studio_id(config.active_profile)
  ensures sim_out.output_detail == sim_output_detail_for_studio_profile(config.active_profile)
  decreases config.active_profile
=
  studio_apply_profile_to_sim(config, sim_out)
  var prof: int = config.active_profile
  var detail_hook: int = sim_out.output_detail
  if detail_hook > 3:
    detail_hook = 3
  if prof == studio_profile_sim_scientific():
    if dt <= 0.0:
      return sim_status_invalid_dt()
    return studio_sim_scientific_step_hook(sim_out, dt)
  if prof == studio_profile_sim_rl():
    if dt <= 0.0:
      return sim_status_invalid_dt()
    return studio_sim_rl_step_hook(sim_out, dt)
  if prof == studio_profile_sim_automotive():
    if sim_automotive_tick_stub(detail_hook) != 1:
      return sim_status_invalid_dt()
    return studio_sim_sensor_step_hook(sim_out, dt)
  if prof == studio_profile_sim_robotics():
    if sim_robotics_tick_stub(detail_hook) != 1:
      return sim_status_invalid_dt()
    return studio_sim_robotics_step_hook(sim_out, dt)
  if prof == studio_profile_sim_additive():
    if sim_additive_tick_stub(detail_hook) != 1:
      return sim_status_invalid_dt()
  if prof == studio_profile_sim_drug_design():
    if sim_drug_design_tick_stub(detail_hook) != 1:
      return sim_status_invalid_dt()
  if prof == studio_profile_game():
    if dt <= 0.0:
      return sim_status_invalid_dt()
    if studio_game_step_hook(sim_out, dt) != sim_status_ok():
      return sim_status_invalid_dt()
  var step_rc: int = sim_step(sim_out, dt)
  if step_rc != sim_status_ok():
    return step_rc
  if prof == studio_profile_game():
    if studio_world_checkpoint_after_sim_tick(prof, sim_out) != sim_status_ok():
      return sim_status_invalid_dt()
  return sim_status_ok()

def studio_scene_is_empty(scene_entity_count: int) -> int
  requires scene_entity_count >= 0
  ensures result >= 0
  ensures result <= 1
