def studio_profile_chip_width_px() -> float
  requires true
  ensures result == 88.0
  decreases 0
=
  return 88.0

def studio_profile_chip_height_px() -> float
  requires true
  ensures result == 24.0
  decreases 0
=
  return 24.0

def studio_profile_paint_tag_h(profile_id: int) -> float
  requires studio_profile_id_valid(profile_id) == 1
  ensures result >= 20.0
  ensures result <= 28.0
  decreases profile_id
=
  if profile_id == studio_profile_game():
    return 21.0
  if profile_id == studio_profile_sim_rl():
    return 22.0
  if profile_id == studio_profile_sim_automotive():
    return 23.0
  if profile_id == studio_profile_sim_robotics():
    return 24.0
  if profile_id == studio_profile_sim_additive():
    return 25.0
  if profile_id == studio_profile_sim_scientific():
    return 26.0
  if profile_id == studio_profile_sim_drug_design():
    return 27.0
  return 20.0

def studio_profile_chip_rect_at(top_x: float, top_y: float, top_w: float, top_h: float, profile_id: int) -> Rect
  requires top_w >= studio_profile_chip_width_px() + 16.0
  requires top_h >= studio_profile_chip_height_px()
  requires studio_profile_id_valid(profile_id) == 1
  ensures result.w == studio_profile_chip_width_px()
  decreases profile_id
=
  var pid_tag: int = profile_id
  var tag_h: float = studio_profile_paint_tag_h(pid_tag)
  var pad: float = 12.0
  var x: float = top_x + top_w - studio_profile_chip_width_px() - pad
  var y: float = top_y + (top_h - studio_profile_chip_height_px()) / 2.0
  return rect_make(x, y, studio_profile_chip_width_px(), tag_h)

def studio_profile_color(profile_id: int) -> Color
  requires studio_profile_id_valid(profile_id) == 1
  ensures result.r >= 0.0
  decreases profile_id
=
  if profile_id == studio_profile_game():
    return studio_color_accent_cyan()
  if profile_id == studio_profile_sim_rl():
    return studio_color_accent_mint()
  if profile_id == studio_profile_sim_drug_design():
    return studio_color_accent_violet()
  return studio_color_accent_amber()

def studio_paint_topbar_profile_cmds() -> int
  requires true
  ensures result == studio_paint_topbar_profile_accent_cmds() + 2 + studio_paint_glyph_run_cmds()
  decreases 0
=
  return studio_paint_topbar_profile_accent_cmds() + 2 + studio_paint_glyph_run_cmds()

def studio_paint_topbar_profile(frame: var PaintFrame, topbar: Rect, profile_id: int) -> unit
  requires frame.cmd_count >= 0
  requires studio_profile_id_valid(profile_id) == 1
  ensures frame.cmd_count == old(frame.cmd_count) + studio_paint_topbar_profile_cmds()
  ensures frame.last_kind == paint_op_draw_glyphs()
  decreases profile_id
=
  studio_paint_topbar_profile_accent(frame, topbar, profile_id)
  var pid_chip: int = profile_id
  var pid_color: int = profile_id
  var top_copy: Rect = topbar
  var top_x: float = top_copy.x
  var top_y: float = top_copy.y
  var top_w: float = top_copy.w
  var top_h: float = top_copy.h
  var chip_rect: Rect = studio_profile_chip_rect_at(top_x, top_y, top_w, top_h, pid_chip)
  paint_frame_push_accent_chip(frame, chip_rect, studio_profile_color(pid_color))
  var prof_cp: int = studio_profile_label_first_codepoint(pid_chip)
  var prof_cnt: int = studio_profile_label_glyph_count(pid_chip)
  studio_paint_glyph_text(frame, chip_rect, prof_cp, prof_cnt, studio_color_text_primary())

# W0 — readable typography via bitmap atlas (body/caption token sizes).
def studio_typography_glyph_line_height_px() -> float
  requires true
  ensures result == studio_typography_body_px() + 4.0
  decreases 0
=
  return studio_typography_body_px() + 4.0

def studio_typography_caption_line_height_px() -> float
  requires true
  ensures result == studio_typography_caption_px() + 3.0
  decreases 0
=
  return studio_typography_caption_px() + 3.0

def studio_paint_glyph_run_cmds() -> int
  requires true
  ensures result == 1
  decreases 0
=
  return 1

def studio_paint_glyph_text_rect(anchor: Rect, glyph_count: int) -> Rect
  requires anchor.w >= 8.0
  requires anchor.h >= studio_typography_glyph_line_height_px()
  requires glyph_count >= 1
  requires glyph_count <= 32
  ensures result.w >= 8.0
  ensures result.h == studio_typography_glyph_line_height_px()
  decreases glyph_count
=
  var pad: float = studio_spacing_rhythm_px()
  var lh: float = studio_typography_glyph_line_height_px()
  var y: float = anchor.y + (anchor.h - lh) / 2.0
  var w: float = anchor.w - pad - pad
  if w < 8.0:
    w = 8.0
  return rect_make(anchor.x + pad, y, w, lh)

def studio_paint_glyph_text(frame: var PaintFrame, anchor: Rect, first_codepoint: int, glyph_count: int, color: Color) -> unit
  requires frame.cmd_count >= 0
  requires glyph_count >= 1
  requires glyph_count <= 32
  requires font_atlas_codepoint_supported(first_codepoint) == 1
  ensures frame.cmd_count == old(frame.cmd_count) + studio_paint_glyph_run_cmds()
  ensures frame.last_kind == paint_op_draw_glyphs()
  decreases glyph_count
=
  var dest: Rect = studio_paint_glyph_text_rect(anchor, glyph_count)
  paint_frame_push(frame, paint_cmd_draw_glyphs_run(dest, font_face_inter(), color, first_codepoint, glyph_count))

def studio_outliner_label_first_codepoint(label_id: int) -> int
  requires label_id >= studio_outliner_label_root()
  requires label_id <= studio_outliner_label_mesh()
  ensures font_atlas_codepoint_supported(result) == 1
  ensures result == 87 or result == 67 or result == 77
  decreases label_id
=
  if label_id == studio_outliner_label_root():
    return 87
  if label_id == studio_outliner_label_camera():
    return 67
  return 77

def studio_outliner_label_glyph_count(label_id: int) -> int
  requires label_id >= studio_outliner_label_root()
  requires label_id <= studio_outliner_label_mesh()
  ensures result >= 4
  ensures result <= 6
  decreases label_id
=
  if label_id == studio_outliner_label_root():
    return 5
  if label_id == studio_outliner_label_camera():
    return 6
  return 4

def studio_profile_label_first_codepoint(profile_id: int) -> int
  requires studio_profile_id_valid(profile_id) == 1
  ensures font_atlas_codepoint_supported(result) == 1
  ensures result == 71 or result == 82 or result == 68 or result == 83
  decreases profile_id
=
  if profile_id == studio_profile_game():
    return 71
  if profile_id == studio_profile_sim_rl():
    return 82
  if profile_id == studio_profile_sim_drug_design():
    return 68
  if profile_id == studio_profile_sim_scientific():
    return 83
  return 83

def studio_profile_label_glyph_count(profile_id: int) -> int
  requires studio_profile_id_valid(profile_id) == 1
  ensures result >= 2
  ensures result <= 6
  decreases profile_id
=
  if profile_id == studio_profile_game():
    return 4
  if profile_id == studio_profile_sim_rl():
    return 2
  if profile_id == studio_profile_sim_drug_design():
    return 4
  if profile_id == studio_profile_sim_scientific():
    return 3
  return 6

def studio_agent_status_label_first_codepoint(task_state: int) -> int
  requires task_state >= studio_agent_task_idle()
  requires task_state <= studio_agent_task_done()
  ensures font_atlas_codepoint_supported(result) == 1
  decreases task_state
=
  if task_state == studio_agent_task_running():
    return 82
  if task_state == studio_agent_task_failed():
    return 70
  if task_state == studio_agent_task_done():
    return 68
  if task_state == studio_agent_task_blocked():
    return 66
  return 73

def studio_agent_status_label_glyph_count(task_state: int) -> int
  requires task_state >= studio_agent_task_idle()
  requires task_state <= studio_agent_task_done()
  ensures result >= 3
  ensures result <= 7
  decreases task_state
=
  if task_state == studio_agent_task_running():
    return 7
  if task_state == studio_agent_task_failed():
    return 6
  if task_state == studio_agent_task_done():
    return 4
  if task_state == studio_agent_task_blocked():
    return 7
  return 4

