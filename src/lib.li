def studio_viewport_display_prepare_for_profile(profile_id: int) raises IO -> unit
  requires studio_profile_id_valid(profile_id) == 1
  ensures studio_viewport_display_read_bg() >= studio_viewport_bg_solid()
  decreases profile_id
=
  studio_viewport_display_reset_for_profile(profile_id)
  if profile_id == studio_profile_game():
    var _bg_game: int = li_rt_studio_viewport_display_set_bg(studio_viewport_bg_grid())
    var _pt_game: int = li_rt_studio_viewport_display_set_particle_tier(studio_particle_display_off())
    return
  if profile_id == studio_profile_sim_rl():
    var _bg_rl: int = li_rt_studio_viewport_display_set_bg(studio_viewport_bg_grid())
    var _pt_rl: int = li_rt_studio_viewport_display_set_particle_tier(scene_md_tier_1k())
    return
  if profile_id == studio_profile_sim_drug_design():
    var _bg_drug: int = li_rt_studio_viewport_display_set_bg(studio_viewport_bg_grid())
    var _bm_drug: int = li_rt_studio_viewport_display_set_biomol_style(studio_biomol_style_sticks())
    var _pt_drug: int = li_rt_studio_viewport_display_set_particle_tier(scene_md_tier_1k())
    return
  if profile_id == studio_profile_sim_scientific():
    var _bg_sci: int = li_rt_studio_viewport_display_set_bg(studio_viewport_bg_grid())
    return

def studio_viewport_display_profile_wants_scene(profile_id: int) -> int
  requires studio_profile_id_valid(profile_id) == 1
  ensures result >= 0
  ensures result <= 1
