def studio_paint_outliner_row_cmds() -> int
  requires true
  ensures result == 2 + studio_paint_glyph_run_cmds()
  decreases 0
=
  return 2 + studio_paint_glyph_run_cmds()

def studio_paint_outliner_cmds(node_count: int) -> int
  requires node_count >= 0
  requires node_count <= studio_outliner_max_nodes()
  ensures result == studio_paint_elevated_panel_shadow_cmds() + node_count * studio_paint_outliner_row_cmds()
  decreases node_count
=
  return studio_paint_elevated_panel_shadow_cmds() + node_count * studio_paint_outliner_row_cmds()

def studio_paint_outliner_row(frame: var PaintFrame, row: Rect, selected: int, label_id: int, hovered: int) -> unit
  requires frame.cmd_count >= 0
  requires selected >= 0
  requires selected <= 1
  requires hovered >= 0
  requires hovered <= 1
  requires label_id >= studio_outliner_label_root()
  requires label_id <= studio_outliner_label_mesh()
  ensures frame.cmd_count == old(frame.cmd_count) + studio_paint_outliner_row_cmds()
  decreases label_id
=
  if selected == 1:
    paint_frame_push(frame, paint_cmd_fill_round(row, studio_color_accent_mint(), studio_radius_sm_px()))
    var cp_sel: int = studio_outliner_label_first_codepoint(label_id)
    var cnt_sel: int = studio_outliner_label_glyph_count(label_id)
    studio_paint_glyph_text(frame, row, cp_sel, cnt_sel, studio_color_text_primary())
    return
  var row_fill: Color = studio_color_bg_elevated()
  if hovered == 1:
    row_fill = studio_color_hover_surface()
  paint_frame_push(frame, paint_cmd_fill_round(row, row_fill, studio_radius_sm_px()))
  paint_frame_push(frame, paint_cmd_stroke_round(row, studio_color_border(), 1.0, studio_radius_sm_px()))
  var cp0: int = studio_outliner_label_first_codepoint(label_id)
  var cnt0: int = studio_outliner_label_glyph_count(label_id)
  var label_color: Color = studio_color_text_muted()
  if hovered == 1:
    label_color = studio_color_text_primary()
  studio_paint_glyph_text(frame, row, cp0, cnt0, label_color)

def studio_paint_outliner(frame: var PaintFrame, outliner: StudioOutlinerCompose, hover: StudioShellHoverState) -> unit
  requires frame.cmd_count >= 0
  requires outliner.node_count >= 0
  requires outliner.node_count <= studio_outliner_max_nodes()
  ensures frame.cmd_count == old(frame.cmd_count) + studio_paint_outliner_cmds(outliner.node_count)
  decreases outliner.node_count
=
  studio_paint_elevated_panel_with_shadow(frame, outliner.rect)
  if outliner.node_count > 0:
    var sel0: int = 0
    if outliner.selected_node == outliner.node0.id:
      sel0 = 1
    studio_paint_outliner_row(frame, outliner.row0_rect, sel0, outliner.node0.label_id, studio_shell_hover_outliner_row_is(hover, 0))
  if outliner.node_count > 1:
    var sel1: int = 0
    if outliner.selected_node == outliner.node1.id:
      sel1 = 1
    studio_paint_outliner_row(frame, outliner.row1_rect, sel1, outliner.node1.label_id, studio_shell_hover_outliner_row_is(hover, 1))
  if outliner.node_count > 2:
    var sel2: int = 0
    if outliner.selected_node == outliner.node2.id:
      sel2 = 1
    studio_paint_outliner_row(frame, outliner.row2_rect, sel2, outliner.node2.label_id, studio_shell_hover_outliner_row_is(hover, 2))

def studio_paint_dock_cmds() -> int
  requires true
  ensures result == studio_paint_panel_shadow_cmds() + 1 + studio_dock_slot_count() * studio_paint_dock_slot_cmds(0) + studio_paint_glyph_run_cmds()
  decreases 0
=
  return studio_paint_panel_shadow_cmds() + 1 + studio_dock_slot_count() * studio_paint_dock_slot_cmds(0) + studio_paint_glyph_run_cmds()

def studio_paint_timeline_cmds() -> int
  requires true
  ensures result == studio_paint_panel_shadow_cmds() + 6
  decreases 0
=
  return studio_paint_panel_shadow_cmds() + 6

def studio_paint_inspector_empty_cmds() -> int
