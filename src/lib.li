def studio_profile_unknown() -> int
  requires true
  ensures result == 0
  decreases 0
=
  return 0

def studio_profile_game() -> int
  requires true
  ensures result == 1
  decreases 0
=
  return 1

def studio_profile_sim_rl() -> int
  requires true
  ensures result == 2
  decreases 0
=
  return 2

def studio_profile_sim_automotive() -> int
  requires true
  ensures result == 3
  decreases 0
=
  return 3

def studio_profile_sim_robotics() -> int
