def studio_paint_glyph_pipeline_ok() -> int
  requires true
  ensures result >= 0
  ensures result <= 1
  decreases 0
=
  if font_atlas_codepoint_supported(65) != 1:
    return 0
  if paint_op_draw_glyphs() < 0:
    return 0
  return 1

