  return studio_mcp_set_biomol_style()

def studio_mcp_server_default_arg_for_tool(tool_id: int) -> int
  requires studio_mcp_tool_id_valid(tool_id) == 1
  ensures result >= -1
  decreases tool_id
=
  if tool_id == studio_mcp_lic_check():
    return studio_mcp_arg_lic_check_pass()
  if tool_id == studio_mcp_lic_build():
    return studio_mcp_arg_lic_build_pass()
  if tool_id == studio_mcp_sim_set_profile():
    return studio_profile_game()
  if tool_id == studio_mcp_world_scaffold():
    return studio_profile_game()
  if tool_id == studio_mcp_publish_bundle():
    return studio_export_format_mask_3mf()
  if tool_id == studio_mcp_am_export_print():
    return am_export_format_3mf()
  if tool_id == studio_mcp_studio_adaptive_layout():
    return drug_litl_stage_hypothesis()
  if tool_id == studio_mcp_set_viewport_background():
    return studio_viewport_bg_solid()
  if tool_id == studio_mcp_set_particle_display():
    return scene_md_tier_1k()
  if tool_id == studio_mcp_set_biomol_style():
    return studio_biomol_style_cartoon()
  return 0

def studio_mcp_server_reply_ok(method: int) -> StudioMcpServerReply
  requires method >= studio_mcp_server_method_unknown()
  requires method <= studio_mcp_server_method_ping()
  ensures result.ok == studio_mcp_server_flag_on()
  ensures result.method == method
  decreases method
=
  var out: StudioMcpServerReply
  out.ok = studio_mcp_server_flag_on()
  out.method = method
  out.tool_count = studio_mcp_tool_count()
  out.tool_index = 0
  out.tool_id = studio_mcp_tool_unknown()
  out.request = studio_agent_tool_request_none()
  out.error_code = studio_mcp_tool_result_ok()
  return out

def studio_mcp_server_reply_err(method: int, error_code: int) -> StudioMcpServerReply
  requires method >= studio_mcp_server_method_unknown()
  requires method <= studio_mcp_server_method_ping()
  ensures result.ok == studio_mcp_server_flag_off()
  ensures result.method == method
  ensures result.error_code == error_code
  decreases method
=
  var out: StudioMcpServerReply
  out.ok = studio_mcp_server_flag_off()
  out.method = method
  out.tool_count = 0
  out.tool_index = 0
  out.tool_id = studio_mcp_tool_unknown()
  out.request = studio_agent_tool_request_none()
  out.error_code = error_code
  return out

def studio_mcp_server_handle_initialize(state: var StudioMcpServerState) -> StudioMcpServerReply
  requires state.protocol_version == studio_mcp_server_protocol_version()
  ensures state.initialized == studio_mcp_server_flag_on()
  ensures result.ok == studio_mcp_server_flag_on()
  ensures result.method == studio_mcp_server_method_initialize()
  decreases state.initialized
=
  state.initialized = studio_mcp_server_flag_on()
  return studio_mcp_server_reply_ok(studio_mcp_server_method_initialize())

def studio_mcp_server_handle_tools_list(state: StudioMcpServerState) -> StudioMcpServerReply
  requires state.initialized == studio_mcp_server_flag_on()
  ensures result.ok == studio_mcp_server_flag_on()
  ensures result.method == studio_mcp_server_method_tools_list()
  ensures result.tool_count == studio_mcp_tool_count()
  decreases state.initialized
=
  return studio_mcp_server_reply_ok(studio_mcp_server_method_tools_list())

def studio_mcp_server_handle_tools_call(state: StudioMcpServerState, tool_name: str, arg: int) raises IO, Alloc -> StudioMcpServerReply
  requires state.initialized == studio_mcp_server_flag_on()
  ensures result.method == studio_mcp_server_method_tools_call()
  decreases state.initialized
=
  if state.initialized != studio_mcp_server_flag_on():
    return studio_mcp_server_reply_err(studio_mcp_server_method_tools_call(), studio_mcp_tool_result_err_io())
  var tool_id: int = studio_mcp_tool_from_name(tool_name)
  if studio_mcp_tool_id_valid(tool_id) != 1:
    return studio_mcp_server_reply_err(studio_mcp_server_method_tools_call(), studio_mcp_tool_result_err_io())
  var call_arg: int = arg
  if call_arg == 0:
    call_arg = studio_mcp_server_default_arg_for_tool(tool_id)
  var req: StudioAgentToolRequest = studio_mcp_tool_dispatch_arg(tool_id, call_arg)
  var out: StudioMcpServerReply = studio_mcp_server_reply_ok(studio_mcp_server_method_tools_call())
  out.tool_id = tool_id
  out.request = req
  if req.status != studio_mcp_tool_status_ok():
    out.ok = studio_mcp_server_flag_off()
    out.error_code = req.result_code
  return out

def studio_mcp_server_handle_method(state: var StudioMcpServerState, method: int, tool_name: str, arg: int) raises IO, Alloc -> StudioMcpServerReply
  requires method >= studio_mcp_server_method_unknown()
  requires method <= studio_mcp_server_method_ping()
  ensures result.method == method
  decreases method
=
  if method == studio_mcp_server_method_initialize():
    return studio_mcp_server_handle_initialize(state)
  if method == studio_mcp_server_method_tools_list():
    if state.initialized != studio_mcp_server_flag_on():
      return studio_mcp_server_reply_err(method, studio_mcp_tool_result_err_io())
    return studio_mcp_server_handle_tools_list(state)
  if method == studio_mcp_server_method_tools_call():
    return studio_mcp_server_handle_tools_call(state, tool_name, arg)
  if method == studio_mcp_server_method_ping():
    if state.initialized != studio_mcp_server_flag_on():
      return studio_mcp_server_reply_err(method, studio_mcp_tool_result_err_io())
    return studio_mcp_server_reply_ok(method)
  return studio_mcp_server_reply_err(method, studio_mcp_tool_result_err_io())

