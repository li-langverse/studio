def studio_publish_magic_for_format(fmt: int) -> int
  requires studio_publish_format_ok(fmt) == 1
  ensures result > 0
  decreases fmt
=
  if fmt == studio_publish_format_pdf():
    return studio_publish_magic_pdf()
  if fmt == studio_publish_format_png():
