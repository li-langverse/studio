  decreases 0
=
  return studio_spacing_unit_px() / 2.0

def studio_paint_panel_shadow_rect(panel: Rect) -> Rect
  requires panel.w >= 0.0
  requires panel.h >= 0.0
  ensures result.w == panel.w
  ensures result.h == panel.h
  decreases 0
=
  var off: float = studio_paint_panel_shadow_offset_px()
  return rect_make(panel.x + off, panel.y + off, panel.w, panel.h)

def studio_paint_panel_shadow_cmds() -> int
  requires true
  ensures result == 1
  decreases 0
=
  return 1

def studio_paint_panel_shadow(frame: var PaintFrame, panel: Rect) -> unit
  requires frame.cmd_count >= 0
  requires panel.w >= 0.0
  requires panel.h >= 0.0
  ensures frame.cmd_count == old(frame.cmd_count) + studio_paint_panel_shadow_cmds()
  ensures frame.last_kind == paint_op_fill_round_rect()
  decreases 0
=
  var shadow_rect: Rect = studio_paint_panel_shadow_rect(panel)
  paint_frame_push(frame, paint_cmd_fill_round(shadow_rect, studio_color_panel_shadow(), studio_default_panel_radius_px()))

