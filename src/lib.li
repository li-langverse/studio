# PH-GD-1 — native shell tick (pairs with li-render bridge; binary: studio_main.li).
def studio_native_project_tick_stub() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var p: StudioProject = studio_project_new()
  studio_play(p)
  studio_viewport_tick(p)
  if p.playing != 1:
    return 1
  if p.viewport_ticks != 1:
    return 2
  return 0

def studio_native_shell_smoke() -> int
  requires true
  ensures result == 0
  decreases 0
=
  return studio_native_project_tick_stub()

# PH-UX — command palette (≤3 clicks: play, pause, lic build gate).
def studio_cmd_play() -> int
  requires true
  ensures result == 1
  decreases 0
=
  return 1

def studio_cmd_pause() -> int
  requires true
  ensures result == 2
  decreases 0
=
  return 2

def studio_cmd_lic_build() -> int
  requires true
  ensures result == 3
  decreases 0
=
  return 3

def studio_command_execute(project: StudioProject, cmd_id: int) -> int
  requires cmd_id >= 1
  requires cmd_id <= 3
  ensures result == cmd_id
  decreases cmd_id
=
  if cmd_id == studio_cmd_play():
    start_playing(project)
    tick_viewport(project)
    return studio_cmd_play()
  if cmd_id == studio_cmd_pause():
    stop_playing(project)
    return studio_cmd_pause()
  return studio_cmd_lic_build()

def studio_command_palette_smoke() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var p: StudioProject = studio_project_new()
  if studio_command_execute(p, studio_cmd_play()) != 1:
    return 1
  if p.playing != 1:
    return 2
  if studio_command_execute(p, studio_cmd_pause()) != 2:
    return 3
  if p.playing != 0:
    return 4
  if studio_command_execute(p, studio_cmd_lic_build()) != 3:
    return 5
  return 0

