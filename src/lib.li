def studio_determinism_tier_default() -> int
  requires true
  ensures result == 1
  decreases 0
=
  return 1

def studio_determinism_tier_valid(tier: int) -> int
  requires true
  ensures result >= 0
  ensures result <= 1
  decreases tier
=
  if tier < 0:
    return 0
  if tier > 3:
    return 0
  return 1

def studio_determinism_tier_to_output_detail(tier: int) -> int
  requires studio_determinism_tier_valid(tier) == 1
  ensures result >= output_detail_summary()
  ensures result <= output_detail_repro()
  decreases tier
=
  if tier == 0:
    return output_detail_summary()
  if tier == 1:
    return output_detail_fields()
  if tier == 2:
    return output_detail_debug()
  return output_detail_repro()

