def studio_paint_inspector_selected_cmds() -> int
  requires true
  ensures result == inspector_pilot_paint_cmds(1) + studio_paint_inspector_field_glyph_cmds()
  decreases 0
=
  return inspector_pilot_paint_cmds(1) + studio_paint_inspector_field_glyph_cmds()

def studio_paint_inspector_cmds(has_selection: int) -> int
  requires has_selection >= 0
  requires has_selection <= 1
  ensures result >= inspector_pilot_paint_cmds(0)
  ensures result <= inspector_pilot_paint_cmds(1) + studio_paint_inspector_field_glyph_cmds()
  decreases has_selection
=
  if has_selection == 0:
    return studio_paint_inspector_empty_cmds()
  return studio_paint_inspector_selected_cmds()

def studio_paint_viewport_error_cmds() -> int
  requires true
  ensures result == 2
  decreases 0
=
  return 2

def studio_paint_viewport_error(frame: var PaintFrame, overlay: StudioViewportErrorOverlay) -> unit
  requires frame.cmd_count >= 0
  requires overlay.visible == 1
  ensures frame.cmd_count == old(frame.cmd_count) + studio_paint_viewport_error_cmds()
  ensures frame.last_kind == paint_op_stroke_rect()
  decreases overlay.error_kind
=
  frame.cmd_count = frame.cmd_count + studio_paint_viewport_error_cmds()
  frame.last_kind = paint_op_stroke_rect()
  frame.last_rect = overlay.message_rect
  frame.last_color = studio_color_agent_error()
  frame.last_kind = paint_op_stroke_rect()
  frame.last_rect = overlay.retry_rect
  frame.last_color = studio_color_accent_cyan()

def studio_paint_viewport_empty(frame: var PaintFrame, viewport_empty: StudioViewportEmptyCompose) -> unit
  requires frame.cmd_count >= 0
  requires viewport_empty.empty_visible == 1
  ensures frame.cmd_count == old(frame.cmd_count) + studio_paint_viewport_empty_cmds()
  decreases 0
=
  frame.cmd_count = frame.cmd_count + studio_paint_viewport_empty_cmds()
  frame.last_kind = paint_op_stroke_rect()
  frame.last_rect = viewport_empty.frame_rect
  frame.last_color = studio_color_border()
  frame.last_kind = paint_op_fill_rect()
  frame.last_rect = viewport_empty.title_rect
  frame.last_color = studio_color_border()
  frame.last_kind = paint_op_stroke_rect()
  frame.last_rect = viewport_empty.cta_rect
  frame.last_color = studio_color_border()

def studio_paint_viewport_empty_cmds() -> int
  requires true
  ensures result == 3
  decreases 0
=
  return 3

def studio_viewport_game_entity_preview_count() -> int
  requires true
  ensures result == 3
  decreases 0
=
  return 3

def studio_viewport_game_entity_rect_at(vp: Rect, index: int) -> Rect
  requires vp.w >= 120.0
  requires vp.h >= 80.0
  requires index >= 0
  requires index < studio_viewport_game_entity_preview_count()
  ensures result.w >= 24.0
  decreases index
=
  var cx: float = vp.x + vp.w * 0.5 - 48.0
  var cy: float = vp.y + vp.h * 0.5 - 20.0
  var x: float = cx
  if index == 1:
    x = cx + 36.0
  if index == 2:
    x = cx + 72.0
  return rect_make(x, cy, 28.0, 40.0)

def studio_viewport_game_entity_color(index: int) -> Color
  requires index >= 0
  requires index < studio_viewport_game_entity_preview_count()
  ensures result.a == 1.0
  decreases index
=
  if index == 1:
    return studio_color_accent_violet()
  if index == 2:
    return studio_color_accent_mint()
  return studio_color_accent_cyan()

def studio_paint_viewport_game_preview_cmds() -> int
  requires true
  ensures result == studio_viewport_game_entity_preview_count() * 2
  decreases 0
=
  return studio_viewport_game_entity_preview_count() * 2

def studio_paint_viewport_game_preview(frame: var PaintFrame, vp: Rect) -> unit
  requires frame.cmd_count >= 0
  requires vp.w >= 120.0
  requires vp.h >= 80.0
  ensures frame.cmd_count == old(frame.cmd_count) + studio_paint_viewport_game_preview_cmds()
  decreases 0
=
  var idx: int = 0
  while idx < studio_viewport_game_entity_preview_count():
    var ent: Rect = studio_viewport_game_entity_rect_at(vp, idx)
    var ent_color: Color = studio_viewport_game_entity_color(idx)
    paint_frame_push(frame, paint_cmd_fill_round(ent, ent_color, studio_radius_md_px()))
    paint_frame_push(frame, paint_cmd_stroke_round(ent, studio_color_text_primary(), 1.0, studio_radius_md_px()))
    idx = idx + 1

def studio_viewport_rl_reward_dot_count() -> int
  requires true
  ensures result == 6
  decreases 0
=
  return 6

def studio_viewport_rl_reward_dot_rect_at(vp: Rect, index: int) -> Rect
  requires vp.w >= 80.0
  requires vp.h >= 48.0
  requires index >= 0
  requires index < studio_viewport_rl_reward_dot_count()
  ensures result.w == 5.0
  ensures result.h == 5.0
  decreases index
=
  var base_x: float = vp.x + vp.w * 0.22
  var base_y: float = vp.y + vp.h * 0.62
  var x: float = base_x
  var y: float = base_y
  if index == 1:
    x = base_x + 18.0
  if index == 2:
    x = base_x + 36.0
    y = base_y - 6.0
  if index == 3:
    x = base_x + 54.0
  if index == 4:
    x = base_x + 72.0
    y = base_y - 6.0
  if index == 5:
    x = base_x + 90.0
    y = base_y - 12.0
  return rect_make(x, y, 5.0, 5.0)

def studio_paint_viewport_rl_preview_cmds() -> int
  requires true
  ensures result == studio_viewport_rl_reward_dot_count()
  decreases 0
=
  return studio_viewport_rl_reward_dot_count()

def studio_paint_viewport_rl_preview(frame: var PaintFrame, vp: Rect) -> unit
  requires frame.cmd_count >= 0
  requires vp.w >= 80.0
  requires vp.h >= 48.0
  ensures frame.cmd_count == old(frame.cmd_count) + studio_paint_viewport_rl_preview_cmds()
  decreases 0
=
  var idx: int = 0
  while idx < studio_viewport_rl_reward_dot_count():
    var dot: Rect = studio_viewport_rl_reward_dot_rect_at(vp, idx)
    paint_frame_push(frame, paint_cmd_fill_round(dot, studio_color_accent_amber(), 2.0))
    idx = idx + 1

def studio_viewport_drug_stick_count() -> int
  requires true
  ensures result == 3
  decreases 0
=
  return 3

def studio_viewport_drug_stick_rect_at(vp: Rect, index: int) -> Rect
  requires vp.w >= 120.0
  requires vp.h >= 80.0
  requires index >= 0
  requires index < studio_viewport_drug_stick_count()
  ensures result.w == 4.0
  ensures result.h >= 24.0
  decreases index
=
  var cx: float = vp.x + vp.w * 0.42
  var cy: float = vp.y + vp.h * 0.4
  var x: float = cx
  var y: float = cy
  if index == 1:
    x = cx + studio_spacing_rhythm_px() * 3.5
    y = cy - studio_spacing_rhythm_px()
  if index == 2:
    x = cx + studio_spacing_rhythm_px() * 1.75
    y = cy + studio_spacing_rhythm_px() * 2.25
  return rect_make(x, y, 4.0, 36.0)

def studio_paint_viewport_drug_preview_cmds() -> int
  requires true
  ensures result == studio_viewport_drug_stick_count() * 2
  decreases 0
=
  return studio_viewport_drug_stick_count() * 2

def studio_paint_viewport_drug_preview(frame: var PaintFrame, vp: Rect) -> unit
  requires frame.cmd_count >= 0
  requires vp.w >= 120.0
  requires vp.h >= 80.0
  ensures frame.cmd_count == old(frame.cmd_count) + studio_paint_viewport_drug_preview_cmds()
  decreases 0
=
  var idx: int = 0
  while idx < studio_viewport_drug_stick_count():
    var stick: Rect = studio_viewport_drug_stick_rect_at(vp, idx)
    paint_frame_push(frame, paint_cmd_fill_round(stick, studio_color_accent_violet(), studio_radius_sm_px()))
    paint_frame_push(frame, paint_cmd_stroke_round(stick, studio_color_text_primary(), 1.0, studio_radius_sm_px()))
    idx = idx + 1

def studio_paint_viewport_profile_preview_cmds(profile_id: int) -> int
  requires studio_profile_id_valid(profile_id) == 1
  ensures result >= 0
  decreases profile_id
=
  if profile_id == studio_profile_game():
    return studio_paint_viewport_game_preview_cmds()
  if profile_id == studio_profile_sim_rl():
    return studio_paint_viewport_rl_preview_cmds()
  if profile_id == studio_profile_sim_drug_design():
    return studio_paint_viewport_drug_preview_cmds()
  return 0

def studio_paint_viewport_profile_preview(frame: var PaintFrame, vp: Rect, profile_id: int) -> unit
  requires frame.cmd_count >= 0
  requires studio_profile_id_valid(profile_id) == 1
  ensures frame.cmd_count == old(frame.cmd_count) + studio_paint_viewport_profile_preview_cmds(profile_id)
  decreases profile_id
=
  if profile_id == studio_profile_game():
    studio_paint_viewport_game_preview(frame, vp)
    return
  if profile_id == studio_profile_sim_rl():
    studio_paint_viewport_rl_preview(frame, vp)
    return
  if profile_id == studio_profile_sim_drug_design():
    studio_paint_viewport_drug_preview(frame, vp)
    return

def studio_paint_viewport_grid_cmds() -> int
  requires true
  ensures result == 5
  decreases 0
=
  return 5

def studio_paint_viewport_grid(frame: var PaintFrame, vp: Rect) -> unit
  requires frame.cmd_count >= 0
  requires vp.w >= 12.0
  requires vp.h >= 12.0
  ensures frame.cmd_count == old(frame.cmd_count) + studio_paint_viewport_grid_cmds()
  ensures frame.last_kind == paint_op_stroke_round_rect()
  decreases 0
=
  paint_frame_push(frame, paint_cmd_viewport_grid(vp))
  paint_frame_push(frame, paint_cmd_fill(studio_viewport_grid_axis_x_rect(vp), studio_color_accent_cyan()))
  paint_frame_push(frame, paint_cmd_fill(studio_viewport_grid_axis_y_rect(vp), studio_color_accent_violet()))
  var origin: Rect = studio_viewport_grid_origin_rect(vp)
  paint_frame_push(frame, paint_cmd_fill_round(origin, studio_color_text_primary(), 2.0))
  paint_frame_push(frame, paint_cmd_stroke_round(origin, studio_color_accent_cyan(), 1.0, 2.0))

def studio_paint_viewport_scene_cmds() -> int
  requires true
  ensures result == studio_paint_viewport_grid_cmds()
  decreases 0
=
  return studio_paint_viewport_grid_cmds()

def studio_paint_viewport_display_bg_cmds(background: int) -> int
  requires background >= studio_viewport_bg_solid()
  requires background <= studio_viewport_bg_gradient()
  ensures result >= 0
  ensures result <= 2
  decreases background
=
  if background == studio_viewport_bg_gradient():
    return 2
  if background == studio_viewport_bg_solid():
    return 1
  return 0

def studio_paint_viewport_display_cmds(display: StudioViewportDisplayCompose) -> int
  requires display.background >= studio_viewport_bg_solid()
  requires display.background <= studio_viewport_bg_gradient()
  ensures result >= 0
  decreases display.background
=
  var n: int = studio_paint_viewport_display_bg_cmds(display.background)
  if display.particle_dots_visible == 1:
    n = n + studio_viewport_display_particle_dot_count()
  if display.tier_particles > 0:
    n = n + 1
  n = n + 1
  n = n + studio_paint_viewport_hud_cmds()
  return n

def studio_paint_viewport_menu_btn_cmds() -> int
  requires true
  ensures result == 1 + studio_paint_glyph_run_cmds()
  decreases 0
=
  return 1 + studio_paint_glyph_run_cmds()

def studio_paint_viewport_menu_cmds(menu: StudioViewportMenuCompose) -> int
  requires true
  ensures result >= 0
  ensures result <= 3 * studio_paint_viewport_menu_btn_cmds()
  decreases menu.menu_visible
=
  if menu.menu_visible != 1:
    return 0
  return 3 * studio_paint_viewport_menu_btn_cmds()

def studio_viewport_display_bg_color(background: int) -> Color
  requires background >= studio_viewport_bg_solid()
  requires background <= studio_viewport_bg_gradient()
  ensures result.r >= 0.0
  decreases background
=
  if background == studio_viewport_bg_gradient():
    return color_rgb(0.04, 0.06, 0.12, 1.0)
  if background == studio_viewport_bg_grid():
    return color_rgb(0.05, 0.07, 0.10, 1.0)
  return color_rgb(0.051, 0.067, 0.090, 1.0)

def studio_viewport_display_biomol_color(style: int) -> Color
  requires style >= studio_biomol_style_cartoon()
  requires style <= studio_biomol_style_sticks()
  ensures result.r >= 0.0
  decreases style
=
  if style == studio_biomol_style_surface():
    return studio_color_accent_violet()
  if style == studio_biomol_style_sticks():
    return studio_color_accent_mint()
  return studio_color_accent_cyan()

def studio_paint_viewport_display_dot(frame: var PaintFrame, vp: Rect, index: int) -> unit
  requires frame.cmd_count >= 0
  requires index >= 0
  requires index < studio_viewport_display_particle_dot_count()
  ensures frame.cmd_count == old(frame.cmd_count) + 1
  decreases index
=
  var dot: Rect = studio_viewport_display_particle_dot_rect_at(vp, index)
  frame.cmd_count = frame.cmd_count + 1
  frame.last_kind = paint_op_fill_rect()
  frame.last_rect = dot
  frame.last_color = studio_color_accent_amber()

def studio_paint_viewport_display(frame: var PaintFrame, vp: Rect, display: StudioViewportDisplayCompose) -> unit
  requires frame.cmd_count >= 0
  requires vp.w >= 0.0
  requires vp.h >= 0.0
  ensures frame.cmd_count == old(frame.cmd_count) + studio_paint_viewport_display_cmds(display)
  decreases display.background
=
  var bg_n: int = studio_paint_viewport_display_bg_cmds(display.background)
  if bg_n >= 1:
    frame.cmd_count = frame.cmd_count + 1
    frame.last_kind = paint_op_fill_rect()
    frame.last_rect = vp
    frame.last_color = studio_viewport_display_bg_color(display.background)
  if display.background == studio_viewport_bg_gradient():
    frame.cmd_count = frame.cmd_count + 1
    frame.last_kind = paint_op_fill_rect()
    var band: Rect = rect_make(vp.x, vp.y, vp.w, vp.h * 0.35)
    frame.last_rect = band
    frame.last_color = color_rgb(0.08, 0.10, 0.18, 1.0)
  if display.particle_dots_visible == 1:
    studio_paint_viewport_display_dot(frame, vp, 0)
    studio_paint_viewport_display_dot(frame, vp, 1)
    studio_paint_viewport_display_dot(frame, vp, 2)
    studio_paint_viewport_display_dot(frame, vp, 3)
    studio_paint_viewport_display_dot(frame, vp, 4)
    studio_paint_viewport_display_dot(frame, vp, 5)
    studio_paint_viewport_display_dot(frame, vp, 6)
    studio_paint_viewport_display_dot(frame, vp, 7)
  if display.tier_particles > 0:
    frame.cmd_count = frame.cmd_count + 1
    frame.last_kind = paint_op_fill_rect()
    frame.last_rect = display.tier_label_rect
    frame.last_color = studio_color_border()
  frame.cmd_count = frame.cmd_count + 1
  frame.last_kind = paint_op_stroke_rect()
  frame.last_rect = display.biomol_chip_rect
  frame.last_color = studio_viewport_display_biomol_color(display.biomol_style)
  studio_paint_viewport_hud(frame, display)

def studio_paint_viewport_menu(frame: var PaintFrame, menu: StudioViewportMenuCompose) -> unit
  requires frame.cmd_count >= 0
  ensures frame.cmd_count == old(frame.cmd_count) + studio_paint_viewport_menu_cmds(menu)
  decreases menu.menu_visible
=
  if menu.menu_visible != 1:
    return
  paint_frame_push(frame, paint_cmd_stroke_round(menu.bg_btn, studio_color_accent_cyan(), 1.0, studio_radius_sm_px()))
  studio_paint_glyph_text(frame, menu.bg_btn, studio_viewport_menu_bg_label_first_codepoint(), studio_viewport_menu_bg_label_glyph_count(), studio_color_text_primary())
  paint_frame_push(frame, paint_cmd_stroke_round(menu.particle_btn, studio_color_accent_amber(), 1.0, studio_radius_sm_px()))
  studio_paint_glyph_text(frame, menu.particle_btn, studio_viewport_menu_particle_label_first_codepoint(), studio_viewport_menu_particle_label_glyph_count(), studio_color_text_primary())
  paint_frame_push(frame, paint_cmd_stroke_round(menu.biomol_btn, studio_color_accent_violet(), 1.0, studio_radius_sm_px()))
  studio_paint_glyph_text(frame, menu.biomol_btn, studio_viewport_menu_biomol_label_first_codepoint(), studio_viewport_menu_biomol_label_glyph_count(), studio_color_text_primary())

def studio_paint_dock_slot(frame: var PaintFrame, dock: StudioDockCompose, slot: int, hovered: int) -> unit
  requires frame.cmd_count >= 0
  requires slot >= 0
  requires slot < studio_dock_slot_count()
  requires dock.active_slot >= 0
  requires dock.active_slot < studio_dock_slot_count()
  requires hovered >= 0
  requires hovered <= 1
  ensures frame.cmd_count == old(frame.cmd_count) + studio_paint_dock_slot_cmds(0)
  decreases slot
=
  var slot_rect: Rect = studio_dock_slot_rect_at(dock.rect.x, dock.rect.y, dock.rect.w, dock.rect.h, slot)
  var is_active: int = 0
  if slot == dock.active_slot:
    is_active = 1
  if is_active == 1:
    paint_frame_push(frame, paint_cmd_fill_round(slot_rect, studio_color_accent_cyan(), studio_radius_sm_px()))
    paint_frame_push(frame, paint_cmd_stroke_round(slot_rect, studio_color_border(), 1.0, studio_radius_sm_px()))
  if is_active == 0:
    var slot_fill: Color = studio_color_bg_elevated()
    if hovered == 1:
      slot_fill = studio_color_hover_surface()
    paint_frame_push(frame, paint_cmd_fill_round(slot_rect, slot_fill, studio_radius_sm_px()))
    paint_frame_push(frame, paint_cmd_stroke_round(slot_rect, studio_color_border(), 1.0, studio_radius_sm_px()))
  var icon_id: int = icon_atlas_image_for_dock_slot(slot)
  var icon_src: Rect = icon_atlas_src_rect(icon_id)
  var icon_tint: Color = studio_color_text_muted()
  if is_active == 1:
    icon_tint = studio_color_text_primary()
  if hovered == 1:
    icon_tint = studio_color_text_primary()
  paint_frame_push(frame, paint_cmd_draw_image(slot_rect, icon_id, icon_src, icon_tint))

def studio_paint_dock(frame: var PaintFrame, dock: StudioDockCompose, hover: StudioShellHoverState) -> unit
  requires frame.cmd_count >= 0
  requires dock.active_slot >= 0
  requires dock.active_slot < icon_atlas_slot_count()
  ensures frame.cmd_count == old(frame.cmd_count) + studio_paint_dock_cmds()
  ensures frame.last_kind == paint_op_draw_glyphs()
  decreases dock.active_slot
=
  studio_paint_panel_shadow(frame, dock.rect)
  paint_frame_push(frame, paint_cmd_fill_gradient(dock.rect, studio_color_bg_primary(), studio_color_bg_elevated()))
  studio_paint_dock_slot(frame, dock, 0, studio_shell_hover_dock_slot_is(hover, 0))
  studio_paint_dock_slot(frame, dock, 1, studio_shell_hover_dock_slot_is(hover, 1))
  studio_paint_dock_slot(frame, dock, 2, studio_shell_hover_dock_slot_is(hover, 2))
  studio_paint_dock_slot(frame, dock, 3, studio_shell_hover_dock_slot_is(hover, 3))
  studio_paint_dock_slot(frame, dock, 4, studio_shell_hover_dock_slot_is(hover, 4))
  var active_rect: Rect = studio_dock_slot_rect_at(dock.rect.x, dock.rect.y, dock.rect.w, dock.rect.h, dock.active_slot)
  var dock_label_rect: Rect = rect_make(dock.rect.x, active_rect.y + active_rect.h + 2.0, dock.rect.w, studio_typography_caption_line_height_px())
  var cap_cp: int = studio_dock_slot_caption_first_codepoint(dock.active_slot)
  var cap_cnt: int = studio_dock_slot_caption_glyph_count(dock.active_slot)
  studio_paint_glyph_text(frame, dock_label_rect, cap_cp, cap_cnt, studio_color_text_muted())

def studio_paint_timeline(frame: var PaintFrame, timeline: StudioTimelineCompose, hover: StudioShellHoverState) -> unit
  requires frame.cmd_count >= 0
  ensures frame.cmd_count == old(frame.cmd_count) + studio_paint_timeline_cmds()
  ensures frame.last_kind == paint_op_stroke_round_rect()
  decreases 0
=
  studio_paint_panel_shadow(frame, timeline.track_rect)
  paint_frame_push(frame, paint_cmd_fill_gradient(timeline.track_rect, studio_color_bg_primary(), studio_color_bg_elevated()))
  paint_frame_push(frame, paint_cmd_stroke_round(timeline.track_rect, studio_color_border(), 1.0, studio_default_panel_radius_px()))
  var playhead_color: Color = studio_color_accent_amber()
  if hover.timeline_playhead == 1:
    playhead_color = studio_color_accent_cyan()
  paint_frame_push(frame, paint_cmd_fill_round(timeline.playhead_rect, playhead_color, studio_radius_sm_px()))
  var playhead_ring: Color = studio_color_border()
  if hover.timeline_playhead == 1:
    playhead_ring = studio_color_focus_ring()
  paint_frame_push(frame, paint_cmd_stroke_round(timeline.playhead_rect, playhead_ring, 1.0, studio_radius_sm_px()))
  var play_fill: Color = studio_color_bg_elevated()
  if hover.timeline_play_btn == 1:
    play_fill = studio_color_hover_surface()
  paint_frame_push(frame, paint_cmd_fill_round(timeline.play_btn_rect, play_fill, studio_radius_sm_px()))
  paint_frame_push(frame, paint_cmd_stroke_round(timeline.play_btn_rect, studio_color_border(), 1.0, studio_radius_sm_px()))

def studio_paint_agent(frame: var PaintFrame, agent: StudioAgentChromeCompose) -> unit
  requires frame.cmd_count >= 0
  ensures frame.cmd_count == old(frame.cmd_count) + studio_paint_agent_cmds(agent.task_state, agent.agent_context_label, agent.invoke_input_visible, agent.tool_trace_visible)
  ensures frame.last_color.r >= 0.0
  decreases agent.task_state
=
  frame.cmd_count = frame.cmd_count + studio_paint_agent_cmds(agent.task_state, agent.agent_context_label, agent.invoke_input_visible, agent.tool_trace_visible)
  studio_paint_panel_shadow(frame, agent.rect)
  paint_frame_push(frame, paint_cmd_fill_round(agent.rect, studio_color_bg_elevated(), studio_default_panel_radius_px()))
  frame.last_kind = paint_op_fill_rect()
  frame.last_rect = agent.status_rect
  frame.last_color = studio_agent_status_color(agent.task_state)
  if studio_agent_context_visible(agent.agent_context_label) == 1:
    frame.last_kind = paint_op_stroke_rect()
    frame.last_rect = agent.context_rect
    frame.last_color = studio_color_border()
  if agent.progress.visible == 1:
    frame.last_kind = paint_op_fill_rect()
    frame.last_rect = agent.progress.progress_rect
    frame.last_color = studio_color_accent_cyan()
  if agent.cancel_visible == 1:
    frame.last_kind = paint_op_stroke_rect()
    frame.last_rect = agent.cancel_rect
    frame.last_color = studio_color_border()
  if agent.error_visible == 1:
    frame.last_kind = paint_op_fill_rect()
    frame.last_rect = agent.error_strip_rect
    frame.last_color = studio_color_agent_error()
    frame.last_kind = paint_op_stroke_rect()
    frame.last_rect = agent.error_strip_rect
    frame.last_color = studio_color_agent_error()
  if agent.retry_visible == 1:
    frame.last_kind = paint_op_stroke_rect()
    frame.last_rect = agent.retry_hint_rect
    frame.last_color = studio_color_accent_cyan()
  if agent.invoke_input_visible == 1:
    frame.last_kind = paint_op_stroke_rect()
    frame.last_rect = agent.send_rect
    frame.last_color = studio_color_accent_cyan()
    frame.last_kind = paint_op_fill_rect()
    frame.last_rect = agent.task_input_rect
    frame.last_color = studio_color_bg_elevated()
  if agent.tool_trace_visible == 1:
    frame.last_kind = paint_op_stroke_rect()
    frame.last_rect = agent.tool_trace_rect
    frame.last_color = studio_color_accent_mint()

def studio_paint_inspector(frame: var PaintFrame, inspector: StudioInspectorCompose) -> unit
  requires frame.cmd_count >= 0
  ensures frame.cmd_count == old(frame.cmd_count) + studio_paint_inspector_cmds(inspector.has_selection)
  decreases inspector.has_selection
=
  if inspector.widget_pilot == 1:
    inspector_pilot_paint(inspector.pilot_spec, inspector.pilot_layout, frame)
    if inspector.has_selection == 1:
      studio_paint_inspector_field_glyphs(frame, inspector)
    return
  if inspector.has_selection == 0:
    studio_paint_elevated_panel_with_shadow(frame, inspector.rect)
    paint_frame_push(frame, paint_cmd_stroke_round(inspector.hint_box_rect, studio_color_border(), 1.0, studio_default_panel_radius_px()))
    var h1_cp: int = studio_inspector_empty_hint1_first_codepoint()
    var h1_cnt: int = studio_inspector_empty_hint1_glyph_count()
    studio_paint_glyph_text(frame, inspector.hint_line1_rect, h1_cp, h1_cnt, studio_color_text_primary())
    var h2_cp: int = studio_inspector_empty_hint2_first_codepoint()
    var h2_cnt: int = studio_inspector_empty_hint2_glyph_count()
    studio_paint_glyph_text(frame, inspector.hint_line2_rect, h2_cp, h2_cnt, studio_color_text_muted())
  if inspector.has_selection == 1:
    studio_paint_panel_shadow(frame, inspector.rect)
    paint_frame_push(frame, paint_cmd_fill_gradient(inspector.rect, studio_color_bg_primary(), studio_color_bg_elevated()))
    paint_frame_push(frame, paint_cmd_stroke_round(inspector.rect, studio_color_accent_violet(), 1.0, studio_default_panel_radius_px()))
    paint_frame_push(frame, paint_cmd_fill_round(inspector.header_rect, studio_color_accent_violet(), studio_radius_sm_px()))
    paint_frame_push(frame, paint_cmd_fill_round(inspector.field_row_rect, studio_color_bg_elevated(), studio_radius_sm_px()))


def studio_paint_compose_panels(frame: var PaintFrame, dock: StudioDockCompose, outliner: StudioOutlinerCompose, timeline: StudioTimelineCompose, inspector: StudioInspectorCompose) -> unit
  requires frame.cmd_count >= 0
  ensures frame.cmd_count == old(frame.cmd_count) + studio_paint_compose_panels_count(inspector.has_selection)
  decreases 0
=
  studio_paint_dock(frame, dock, studio_shell_hover_new())
  studio_paint_outliner(frame, outliner, studio_shell_hover_new())
  studio_paint_timeline(frame, timeline, studio_shell_hover_new())
  studio_paint_inspector(frame, inspector)

def studio_paint_compose_panels_count(has_selection: int) -> int
  requires has_selection >= 0
  requires has_selection <= 1
  ensures result == studio_paint_dock_cmds() + studio_paint_outliner_cmds(studio_outliner_demo_node_count()) + studio_paint_timeline_cmds() + studio_paint_inspector_cmds(has_selection)
  decreases has_selection
=
  return studio_paint_dock_cmds() + studio_paint_outliner_cmds(studio_outliner_demo_node_count()) + studio_paint_timeline_cmds() + studio_paint_inspector_cmds(has_selection)

def studio_shell_viewport_cmds(scene_entity_count: int, viewport_error_kind: int, display: StudioViewportDisplayCompose, menu: StudioViewportMenuCompose, profile_id: int) -> int
  requires scene_entity_count >= 0
  requires viewport_error_kind >= studio_viewport_error_none()
  requires viewport_error_kind <= studio_err_missing_asset()
  requires studio_profile_id_valid(profile_id) == 1
  ensures result >= 1
  decreases viewport_error_kind
=
  if studio_viewport_error_visible(viewport_error_kind) == 1:
    return studio_paint_viewport_error_cmds()
  if scene_entity_count == 0:
    return studio_paint_viewport_empty_cmds()
  return studio_paint_viewport_scene_cmds() + studio_paint_viewport_display_cmds(display) + studio_paint_viewport_menu_cmds(menu) + studio_paint_viewport_profile_preview_cmds(profile_id)

def studio_shell_chrome_count(has_selection: int, scene_entity_count: int, task_state: int) -> int
  requires has_selection >= 0
  requires has_selection <= 1
  requires scene_entity_count >= 0
  requires task_state >= studio_agent_task_idle()
  requires task_state <= studio_agent_task_done()
  ensures result >= studio_paint_compose_panels_count(has_selection)
  decreases task_state
=
  var sel_palette: int = has_selection
  var sel_ctx: int = has_selection
  var scene0: int = scene_entity_count
  var ts0: int = task_state
  var disp0: StudioViewportDisplayCompose = studio_viewport_display_compose_new()
  var menu0: StudioViewportMenuCompose = studio_viewport_menu_compose_new()
  var invoke0: int = studio_agent_invoke_input_visible(ts0)
  var trace0: int = studio_agent_tool_trace_visible_for(ts0, studio_mcp_tool_unknown())
  return studio_shell_chrome_count_palette(sel_palette, scene0, ts0, studio_palette_closed_flag(), studio_agent_context_for_shell(sel_ctx, ts0), studio_viewport_error_none(), disp0, menu0, invoke0, trace0, studio_profile_game())

def studio_shell_chrome_count_palette(has_selection: int, scene_entity_count: int, task_state: int, palette_open: int, agent_context_label: int, viewport_error_kind: int, display: StudioViewportDisplayCompose, menu: StudioViewportMenuCompose, invoke_visible: int, tool_trace_visible: int, profile_id: int) -> int
  requires has_selection >= 0
  requires has_selection <= 1
  requires scene_entity_count >= 0
  requires task_state >= studio_agent_task_idle()
  requires task_state <= studio_agent_task_done()
  requires palette_open >= studio_palette_closed_flag()
  requires palette_open <= studio_palette_open_flag()
  requires agent_context_label >= studio_agent_context_none()
  requires agent_context_label <= studio_agent_context_selection()
  requires viewport_error_kind >= studio_viewport_error_none()
  requires viewport_error_kind <= studio_err_missing_asset()
  requires invoke_visible >= 0
  requires invoke_visible <= 1
  requires tool_trace_visible >= 0
  requires tool_trace_visible <= 1
  requires studio_profile_id_valid(profile_id) == 1
  ensures result >= studio_paint_compose_panels_count(has_selection)
  decreases task_state
=
  var sel0: int = has_selection
  var scene0: int = scene_entity_count
  var ts0: int = task_state
  var pal0: int = palette_open
  var ctx0: int = agent_context_label
  return studio_paint_compose_panels_count(sel0) + 1 + studio_paint_topbar_profile_cmds() + studio_paint_palette_shortcut_hints_cmds(pal0) + studio_shell_viewport_cmds(scene0, viewport_error_kind, display, menu, profile_id) + studio_paint_agent_cmds(ts0, ctx0, invoke_visible, tool_trace_visible) + studio_paint_palette_cmds(pal0)

def studio_shell_chrome_count_for_compose(compose: StudioShellCompose) -> int
  requires compose.panel.active_region >= studio_region_dock()
  requires compose.panel.active_region <= studio_region_agent_strip()
  ensures result >= studio_shell_chrome_count_palette(compose.inspector.has_selection, compose.scene_entity_count, compose.agent.task_state, compose.palette.is_open, compose.agent.agent_context_label, compose.viewport_error.error_kind, compose.viewport_display, compose.viewport_menu, compose.agent.invoke_input_visible, compose.agent.tool_trace_visible, compose.config.active_profile)
  decreases compose.agent.task_state
=
  var base: int = studio_shell_chrome_count_palette(compose.inspector.has_selection, compose.scene_entity_count, compose.agent.task_state, compose.palette.is_open, compose.agent.agent_context_label, compose.viewport_error.error_kind, compose.viewport_display, compose.viewport_menu, compose.agent.invoke_input_visible, compose.agent.tool_trace_visible, compose.config.active_profile)
  return base + studio_paint_focus_ring_cmds(compose.panel.active_region)


def studio_paint_shell_chrome(frame: var PaintFrame, compose: StudioShellCompose) -> unit
  requires frame.cmd_count >= 0
  ensures frame.cmd_count == studio_shell_chrome_count_for_compose(compose)
  decreases compose.agent.task_state
=
  studio_paint_dock(frame, compose.dock, compose.hover)
  studio_paint_outliner(frame, compose.outliner, compose.hover)
  studio_paint_timeline(frame, compose.timeline, compose.hover)
  studio_paint_inspector(frame, compose.inspector)
  paint_frame_push(frame, paint_cmd_fill_gradient(compose.layout.topbar, studio_color_bg_primary(), studio_color_bg_elevated()))
  var prof0: int = compose.config.active_profile
  studio_paint_topbar_profile(frame, compose.layout.topbar, prof0)
  studio_paint_palette_shortcut_hints(frame, compose.layout.topbar, compose.palette)
  if compose.viewport_error.visible == 1:
    studio_paint_viewport_error(frame, compose.viewport_error)
  if compose.viewport_error.visible == 0:
    if compose.scene_entity_count == 0:
      studio_paint_viewport_empty(frame, compose.viewport_empty)
    if compose.scene_entity_count > 0:
      studio_paint_viewport_grid(frame, compose.layout.viewport)
      studio_paint_viewport_display(frame, compose.layout.viewport, compose.viewport_display)
      studio_paint_viewport_profile_preview(frame, compose.layout.viewport, prof0)
      studio_paint_viewport_menu(frame, compose.viewport_menu)
  studio_paint_agent(frame, compose.agent)
  paint_studio_palette(frame, compose.palette)
  studio_paint_focus_ring_for_panel(frame, compose)

def studio_paint_palette_overlay(frame: var PaintFrame, palette: StudioCommandPaletteCompose) -> unit
  requires frame.cmd_count >= 0
  requires palette.is_open >= studio_palette_closed_flag()
  requires palette.is_open <= studio_palette_open_flag()
  ensures frame.cmd_count == old(frame.cmd_count) + studio_paint_palette_cmds(palette.is_open)
  decreases palette.is_open
=
  paint_studio_palette(frame, palette)

def studio_shell_frame(w: float, h: float) -> PaintFrame
  requires w > 0.0
  requires h > 0.0
  ensures result.cmd_count == studio_shell_chrome_count_for_compose(studio_compose_shell_agent(w, h, 0, 1, 1, studio_agent_task_running()))
  decreases 0
=
  var compose: StudioShellCompose = studio_compose_shell_agent(w, h, 0, 1, 1, studio_agent_task_running())
  var frame: PaintFrame = paint_frame_new()
  studio_paint_shell_chrome(frame, compose)
  return frame


def studio_shell_loading_frame(w: float, h: float) -> PaintFrame
  requires w > 0.0
  requires h > 0.0
  ensures result.cmd_count > 0
  decreases 0
=
  var w0: float = w
  var h0: float = h
  var w1: float = w
  var h1: float = h
  var compose: StudioShellCompose = studio_compose_shell_loading(w0, h0, 0, 0, 0, studio_shell_loading_on())
  var idle: StudioShellCompose = studio_compose_shell(w1, h1, 0, 0, 0)
  var frame: PaintFrame = paint_frame_new()
  var idle_frame: PaintFrame = paint_frame_new()
  studio_paint_shell_chrome(idle_frame, idle)
  studio_paint_shell_chrome(frame, compose)
  studio_paint_shell_loading(frame, compose.loading)
  return frame

def studio_agent_chrome_ok(agent: StudioAgentChromeCompose) -> int
  requires true
  ensures result >= 0
  ensures result <= 1
  decreases 0
=
  if agent.rect.h != studio_agent_strip_height_px():
    return 0
  if agent.cancel_visible == 1:
    if agent.cancel_rect.w != studio_agent_cancel_btn_width_px():
      return 0
  if agent.error_visible == 1:
    if agent.error_strip_rect.h != studio_agent_error_strip_height_px():
      return 0
  if agent.task_state == studio_agent_task_running():
    if agent.cancel_visible != 1:
      return 0
    if agent.progress.visible != 1:
      return 0
    if agent.progress.step_total <= 0:
      return 0
  if agent.task_state == studio_agent_task_failed():
    if agent.error_visible != 1:
      return 0
    if agent.retry_visible != 1:
      return 0
    if agent.retry_hint_rect.w != studio_agent_retry_hint_width_px():
      return 0
  if studio_agent_context_visible(agent.agent_context_label) == 1:
    if agent.context_rect.w != studio_agent_context_label_width_px():
      return 0
  if agent.invoke_input_visible == 1:
    if agent.send_rect.w != studio_agent_send_btn_width_px():
      return 0
    if agent.task_input_rect.w <= 0.0:
      return 0
  if agent.tool_trace_visible == 1:
    if agent.tool_trace_rect.w != studio_agent_tool_trace_width_px():
      return 0
  return 1

def studio_panel_switch_inspector(panel: var GuiPanelState, elapsed_ms: float) -> PanelSwitchTiming
  requires elapsed_ms >= 0.0
  requires panel.switch_count >= 0
  ensures panel.active_region == studio_region_inspector()
  decreases 0
=
  return gui_panel_switch_to(panel, studio_region_inspector(), elapsed_ms)

def studio_panel_switch_timeline(panel: var GuiPanelState, elapsed_ms: float) -> PanelSwitchTiming
  requires elapsed_ms >= 0.0
  requires panel.switch_count >= 0
  ensures panel.active_region == studio_region_timeline()
  decreases 0
=
  return gui_panel_switch_to(panel, studio_region_timeline(), elapsed_ms)

def studio_compose_ok(compose: StudioShellCompose) -> int
  requires true
  ensures result >= 0
  ensures result <= 1
  decreases 0
=
  if compose.dock.rect.w != studio_dock_width_px():
    return 0
  if compose.outliner.node_count != studio_outliner_demo_node_count():
    return 0
  if compose.outliner.node_count > studio_outliner_max_nodes():
    return 0
  if compose.timeline.rect.h != studio_timeline_height_px():
    return 0
  if compose.inspector.rect.w != studio_inspector_width_px():
    return 0
  if compose.layout.viewport.w <= 0.0:
    return 0
  if studio_palette_ok(compose.palette) != 1:
    return 0
  return 1

def studio_palette_shell_ok(compose: StudioShellCompose) -> int
  requires true
  ensures result >= 0
  ensures result <= 1
  decreases 0
=
  if compose.palette.is_open != studio_palette_open_flag():
    return 0
  if compose.palette.backdrop_rect.w <= 0.0:
    return 0
  if compose.palette.search_rect.h != studio_palette_search_bar_height_px():
    return 0
  return 1

def studio_palette_apply_action(compose: var StudioShellCompose, action_id: int) -> int
  requires action_id >= studio_palette_action_none()
  requires action_id <= studio_palette_action_focus_agent()
  ensures result >= 0
  ensures result <= 1
  decreases action_id
=
  if action_id == studio_palette_action_focus_agent():
    studio_shell_apply_mode(compose, studio_mode_agent())
    return 1
  var region: int = gui_studio_palette_region_for_action(action_id)
  if region >= studio_region_dock():
    var _timing: PanelSwitchTiming = gui_panel_switch_to(compose.panel, region, 0.0)
    return 1
  return 0

def studio_handle_studio_key(compose: var StudioShellCompose, input: InputState) -> int
  requires compose.layout.viewport_w > 0.0
  requires compose.layout.viewport_h > 0.0
  requires compose.panel.switch_count >= 0
  requires input.key_escape >= 0
  requires input.key_escape <= 1
  requires input.key_cmd_k >= 0
  requires input.key_cmd_k <= 1
  requires input.key_digit >= 0
  requires input.key_digit <= 5
  ensures result >= studio_key_action_none()
  ensures result <= studio_key_action_palette_exec()
  decreases input.key_digit
=
  var key_w: float = compose.layout.viewport_w
  var key_h: float = compose.layout.viewport_h
  var action: int = gui_handle_studio_key_palette(compose.panel, compose.palette, key_w, key_h, input)
  if action != studio_key_action_none():
    studio_reactive_resync_palette(compose)
    studio_reactive_flush_palette(compose)
  if action == studio_key_action_palette_exec():
    var _applied: int = studio_palette_apply_action(compose, compose.panel.last_palette_action)
  return action

def studio_viewport_error_overlay_visible_flag(overlay: StudioViewportErrorOverlay) -> int
  requires true
  ensures result == overlay.visible
  ensures result >= 0
  ensures result <= 1
  decreases 0
=
  return overlay.visible

def studio_shell_viewport_error_kind_is(compose: StudioShellCompose, kind: int) -> int
  requires kind >= studio_viewport_error_none()
  requires kind <= studio_err_missing_asset()
  ensures result >= 0
  ensures result <= 1
  decreases kind
=
  if compose.viewport_error.error_kind != kind:
    return 0
  return 1

def studio_shell_viewport_error_visible(compose: StudioShellCompose) -> int
  requires true
  ensures result == compose.viewport_error.visible
  ensures result >= 0
  ensures result <= 1
  decreases 0
=
  return compose.viewport_error.visible


# PH-GD-1 / UX-14 — demo frames honor STUDIO_DEMO_PROFILE + optional host present.
def studio_demo_profile_from_env() -> int raises IO
  requires true
  ensures studio_profile_id_valid(result) == 1
  decreases 0
=
  var pid: int = li_rt_studio_demo_profile_from_env()
  if studio_profile_id_valid(pid) != 1:
    return studio_profile_game()
  return pid

def studio_shell_demo_apply_profile(compose: var StudioShellCompose, profile_id: int) -> unit
  requires studio_profile_id_valid(profile_id) == 1
  ensures compose.config.active_profile == profile_id
  decreases profile_id
=
  compose.config = studio_project_config_new(profile_id)

# WP-UX-14 — honest native_pixels: paint blit or wgpu readback/draw-list/swapchain (not external CPU host alone).
def studio_native_pixel_source_honest(source: int) -> int
  requires source >= 0
  requires source <= 5
  ensures result >= 0
  ensures result <= 1
  decreases source
=
  if source == lig_native_pixel_source_paint_blit():
    return 1
  if source == lig_native_pixel_source_wgpu_readback():
    return 1
  if source == lig_native_pixel_source_wgpu_draw_list():
    return 1
  if source == lig_native_pixel_source_wgpu_swapchain():
    return 1
  return 0

def studio_native_pixel_source_expected() -> int raises IO
  requires true
  ensures result >= 0
  ensures result <= 5
  decreases 0
=
  if lig_present_wgpu_swapchain_active() == 1:
    return lig_native_pixel_source_wgpu_swapchain()
  if lig_present_wgpu_readback_active() == 1:
    return lig_native_pixel_source_wgpu_readback()
  return lig_native_pixel_source_paint_blit()

def studio_native_pixels_wgpu_readback_host_smoke() -> int raises IO
  requires true
  ensures result >= 0
  ensures result <= 8
  decreases 0
=
  if lig_present_wgpu_readback_active() != 1:
    return 0
  var vp_w: float = 1280.0
  var vp_h: float = 720.0
  if lig_present_blit_paint_summary(vp_w, vp_h, 1, 8) != 1:
    return 1
  if lig_present_host_native_pixels_flag() != 1:
    return 2
  if lig_present_host_native_pixel_source_flag() != lig_native_pixel_source_wgpu_readback():
    return 3
  var counter: RenderFpsCounter = render_fps_counter_new()
  render_fps_counter_host_tick(counter)
  if counter.native_pixels != 1:
    return 4
  return 0

def studio_native_pixels_wgpu_swapchain_host_smoke() -> int raises IO
  requires true
  ensures result >= 0
  ensures result <= 8
  decreases 0
=
  if lig_present_wgpu_swapchain_active() != 1:
    return 0
  var vp_w: float = 1280.0
  var vp_h: float = 720.0
  var rb: LigWgpuSwapchainReadback = lig_wgpu_swapchain_readback_run()
  if rb.status != lig_wgpu_swapchain_status_pass():
    return 0
  if lig_wgpu_swapchain_readback_passed(rb) != 1:
    return 1
  if rb.pixels_sampled <= 0:
    return 2
  if rb.native_pixel_source != lig_native_pixel_source_wgpu_swapchain():
    return 3
  var layout: StudioShellLayout = layout_studio_shell_adaptive(vp_w, vp_h)
  var vp: ViewportRegion = gui_viewport_region_from_layout(layout)
  var smoke: RenderViewportSmoke = render_wgpu_viewport_readback(vp)
  if render_viewport_readback_ok(smoke) != 1:
    return 4
  if smoke.native_pixels != 1:
    return 5
  if lig_present_host_native_pixels_flag() != 1:
    return 6
  if lig_present_host_native_pixel_source_flag() != lig_native_pixel_source_wgpu_swapchain():
    return 7
  return 0

def studio_vertical_demo_compose(profile_id: int, frame_id: int, key_compose: int) -> StudioShellCompose
  requires studio_profile_id_valid(profile_id) == 1
  requires frame_id >= 0
  requires frame_id <= 2
  requires key_compose >= 0
  requires key_compose <= 1
  ensures studio_compose_ok(result) == 1
  decreases frame_id
=
  if profile_id == studio_profile_sim_drug_design():
    var tick: int = frame_id
    if key_compose == 1:
      tick = 0
    return studio_compose_shell_drug_litl(1280.0, 720.0, tick, 1)
  var palette_open: int = studio_palette_closed_flag()
  if key_compose == 0:
    if frame_id == 2:
      palette_open = studio_palette_open_flag()
  var out: StudioShellCompose = studio_compose_shell_palette(1280.0, 720.0, 0, 1, palette_open)
  studio_shell_demo_apply_profile(out, profile_id)
  if studio_viewport_display_profile_wants_scene(profile_id) == 1:
    studio_viewport_display_prepare_for_profile(profile_id)
    out.scene_entity_count = 1
    out.viewport_empty.empty_visible = 0
    studio_attach_viewport_shell(out)
  return out

def studio_present_loop_raster_version() -> int
  requires true
  ensures result == 1
  decreases 0
=
  return 1

# Phase 4 (wsg-w4-c-host-slim) — C present host is window/input/surface I/O only.
def studio_c_host_slim_version() -> int
  requires true
  ensures result == 1
  decreases 0
=
  return 1

# Phase 5 (wsg-w5-windows-native) — Windows SDL present host (.exe), no WSL requirement.
def studio_windows_native_present_version() -> int
  requires true
  ensures result == 1
  decreases 0
=
  return 1

# Phase 5 (wsg-w5-macos-wgpu) — macOS aarch64-apple-darwin wgpu/Metal surface (PH-HW WP3).
def studio_macos_wgpu_present_version() -> int
  requires true
  ensures result == 1
  decreases 0
=
  return 1

def studio_macos_wgpu_surface_smoke() -> int raises IO
  requires true
  ensures result >= 0
  ensures result <= 8
  decreases 0
=
  if lig_present_host_active() != 1:
    return 0
  if lig_present_wgpu_swapchain_active() != 1:
    return 0
  var rb: LigWgpuSwapchainReadback = lig_wgpu_swapchain_readback_run()
  if rb.status != lig_wgpu_swapchain_status_pass():
    return 1
  if lig_wgpu_swapchain_readback_passed(rb) != 1:
    return 2
  if rb.pixels_sampled <= 0:
    return 3
  if rb.native_pixel_source != lig_native_pixel_source_wgpu_swapchain():
    return 4
  if lig_present_surface_ok() != 1:
    return 5
  var layout: StudioShellLayout = layout_studio_shell_adaptive(1280.0, 720.0)
  var vp: ViewportRegion = gui_viewport_region_from_layout(layout)
  var smoke: RenderViewportSmoke = render_wgpu_viewport_readback(vp)
  if render_viewport_readback_ok(smoke) != 1:
    return 6
  if smoke.native_pixels != 1:
    return 7
  return 0

# Phase 5 (wsg-w5-linux-appimage) — Linux AppImage with bundled SDL/wgpu present host.
def studio_linux_appimage_version() -> int
  requires true
  ensures result == 1
  decreases 0
=
  return 1

def studio_linux_appimage_smoke() -> int raises IO
  requires true
  ensures result >= 0
  ensures result <= 4
  decreases 0
=
  if lig_present_host_active() != 1:
    return 0
  if studio_present_loop_raster_version() != 1:
    return 1
  if studio_c_host_slim_version() != 1:
    return 2
  if lig_present_wgpu_swapchain_active() == 1:
    var rb: LigWgpuSwapchainReadback = lig_wgpu_swapchain_readback_run()
    if lig_wgpu_swapchain_readback_passed(rb) != 1:
      return 3
  return 0

