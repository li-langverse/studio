# WP-UX-15 — Studio interaction mode FSM on compose (§3 mode matrix).
def studio_mode_default() -> int
  requires true
  ensures result == studio_mode_author()
  decreases 0
=
  return studio_mode_author()

def studio_bench_mode_from_env() raises IO -> int
  requires true
  ensures result >= 0
  ensures result <= 1
  decreases 0
=
  return li_rt_studio_bench_mode_from_env()

def studio_mode_from_profile(profile_id: int) -> int
  requires studio_profile_id_valid(profile_id) == 1
  ensures studio_mode_valid(result) == 1
  decreases profile_id
=
  if profile_id == studio_profile_sim_drug_design():
    return studio_mode_adaptive()
  if profile_id == studio_profile_sim_scientific():
    return studio_mode_analyze()
  return studio_mode_default()

def studio_mode_primary_region(mode: int) -> int
  requires studio_mode_valid(mode) == 1
  ensures result >= studio_region_dock()
  ensures result <= studio_region_agent_strip()
  decreases mode
=
  if mode == studio_mode_simulate():
    return studio_region_timeline()
  if mode == studio_mode_agent():
    return studio_region_agent_strip()
  if mode == studio_mode_analyze():
    return studio_region_viewport()
  if mode == studio_mode_bench():
    return studio_region_viewport()
  return studio_region_inspector()

def studio_mode_sim_step_allowed(mode: int, timeline_playing: int) -> int
  requires studio_mode_valid(mode) == 1
  requires timeline_playing >= 0
  requires timeline_playing <= 1
  ensures result >= 0
  ensures result <= 1
  decreases mode
=
  if mode == studio_mode_bench():
    return 1
  if mode == studio_mode_analyze():
    return 1
  if mode == studio_mode_simulate():
    if timeline_playing == 1:
      return 1
    return 0
  return 0

def studio_mode_mcp_tool_allowed(mode: int, tool_id: int) -> int
  requires studio_mode_valid(mode) == 1
  ensures result >= 0
  ensures result <= 1
  decreases mode
=
  if studio_mcp_tool_id_valid(tool_id) != 1:
    return 0
  if mode == studio_mode_agent():
    return 1
  if mode == studio_mode_bench():
    if tool_id == studio_mcp_lic_check():
      return 1
    return 0
  if mode == studio_mode_publish():
    if tool_id == studio_mcp_lic_check():
      return 1
    if tool_id == studio_mcp_lic_build():
      return 1
    if tool_id == studio_mcp_publish_bundle():
      return 1
    return 0
  if mode == studio_mode_analyze():
    if tool_id == studio_mcp_lic_check():
      return 1
    if tool_id == studio_mcp_publish_bundle():
      return 1
    if tool_id == studio_mcp_chem_dft_run():
      return 1
    if tool_id == studio_mcp_set_viewport_background():
      return 1
    if tool_id == studio_mcp_set_particle_display():
      return 1
    if tool_id == studio_mcp_set_biomol_style():
      return 1
    return 0
  if mode == studio_mode_adaptive():
    if tool_id == studio_mcp_studio_adaptive_layout():
      return 1
    if tool_id == studio_mcp_lic_check():
      return 1
    if tool_id == studio_mcp_sim_set_profile():
      return 1
    return 0
  if mode == studio_mode_simulate():
    if tool_id == studio_mcp_lic_check():
      return 1
    if tool_id == studio_mcp_sim_set_profile():
      return 1
    return 0
  if tool_id == studio_mcp_world_scaffold():
    return 1
  if tool_id == studio_mcp_sim_set_profile():
    return 1
  if tool_id == studio_mcp_lic_check():
    return 1
  if tool_id == studio_mcp_set_viewport_background():
    return 1
  if tool_id == studio_mcp_set_particle_display():
    return 1
  if tool_id == studio_mcp_set_biomol_style():
    return 1
  return 0

def studio_mode_transition(mode: int, trigger: int) -> int
  requires studio_mode_valid(mode) == 1
  ensures studio_mode_valid(result) == 1
  decreases mode
=
  if trigger == studio_mode_trigger_play():
    if mode == studio_mode_author():
      return studio_mode_simulate()
  if trigger == studio_mode_trigger_stop():
    if mode == studio_mode_simulate():
      return studio_mode_author()
  if trigger == studio_mode_trigger_agent():
    return studio_mode_agent()
  if trigger == studio_mode_trigger_agent_done():
    if mode == studio_mode_agent():
      return studio_mode_author()
  if trigger == studio_mode_trigger_publish():
    return studio_mode_publish()
  if trigger == studio_mode_trigger_bench_env():
    return studio_mode_bench()
  if trigger == studio_mode_trigger_adaptive_profile():
    return studio_mode_adaptive()
  return mode

def studio_shell_apply_mode(compose: var StudioShellCompose, mode: int) -> unit
  requires studio_mode_valid(mode) == 1
  requires compose.layout.viewport_w > 0.0
  ensures compose.mode == mode
  decreases mode
=
  compose.mode = mode
  studio_reactive_resync_mode(compose, mode)
  var region: int = studio_mode_primary_region(mode)
  var _timing: PanelSwitchTiming = gui_panel_switch_to(compose.panel, region, 0.0)
  studio_reactive_flush_mode_regions(compose)

def studio_shell_handle_mode_trigger(compose: var StudioShellCompose, trigger: int) raises IO -> int
  requires studio_mode_valid(compose.mode) == 1
  requires trigger >= studio_mode_trigger_none()
  requires trigger <= studio_mode_trigger_adaptive_profile()
  ensures result >= 0
  ensures result <= 1
  decreases trigger
=
  var next: int = studio_mode_transition(compose.mode, trigger)
  if trigger == studio_mode_trigger_play():
    if compose.mode == studio_mode_author():
      var _play: int = studio_timeline_toggle_play()
  if trigger == studio_mode_trigger_stop():
    if studio_timeline_playing() == 1:
      var _stop: int = studio_timeline_toggle_play()
  if next == compose.mode:
    if trigger == studio_mode_trigger_stop():
      return 1
    return 0
  studio_shell_apply_mode(compose, next)
  return 1

def studio_shell_sync_mode_from_env(compose: var StudioShellCompose) raises IO -> unit
  requires studio_mode_valid(compose.mode) == 1
  requires compose.layout.viewport_w > 0.0
  ensures studio_mode_valid(compose.mode) == 1
  decreases compose.mode
=
  if studio_bench_mode_from_env() == 1:
    studio_shell_apply_mode(compose, studio_mode_bench())

# Phase 2 — Function layer reactive stores on shell (agent FSM, palette, mode, timeline playhead).
type StudioReactiveShell = object
  public inv: ComposeInvalidation
  public graph: ComposeDepGraph
  public cache: ComposeCache
  public agent_task: StoreInt
  public palette_open: StoreInt
  public shell_mode: StoreInt
  public timeline_tick: StoreFloat
  public agent_progress: DerivedInt

# PH-GD-2 — last WorldSnapshot tick cached on shell (game profile).
type StudioWorldCheckpoint = object
  public valid: int
  public name: int
  public tick: int
  public entity_count: int
  public asset_ref_count: int

# UX-11 — shell loading / skeleton rects (viewport + inspector); no spinner IR
type StudioShellLoadingState = object
  public shell_loading: int
  public viewport_skeleton: Rect
  public inspector_skeleton: Rect
  public inspector_header_skeleton: Rect
  public inspector_field_skeleton: Rect
  public inspector_field2_skeleton: Rect

type StudioShellCompose = object
  public layout: StudioShellLayout
  public config: StudioProjectConfig
  public mode: int
  public dock: StudioDockCompose
  public outliner: StudioOutlinerCompose
  public timeline: StudioTimelineCompose
  public inspector: StudioInspectorCompose
  public viewport_empty: StudioViewportEmptyCompose
  public viewport_error: StudioViewportErrorOverlay
  public viewport_display: StudioViewportDisplayCompose
  public viewport_menu: StudioViewportMenuCompose
  public agent: StudioAgentChromeCompose
  public palette: StudioCommandPaletteCompose
  public panel: GuiPanelState
  public scene_entity_count: int
  public loading: StudioShellLoadingState
  public world_checkpoint: StudioWorldCheckpoint
  public reactive: StudioReactiveShell
  public widget_tree: ShellWidgetTree
  public widget_tree_layout: ShellWidgetTreeLayout
  public widget_tree_active: int
  public hover: StudioShellHoverState


def studio_reactive_shell_new(task_state: int, palette_open: int, mode: int, playhead_pct: float) -> StudioReactiveShell
  requires task_state >= studio_agent_task_idle()
  requires task_state <= studio_agent_task_done()
  requires palette_open >= studio_palette_closed_flag()
  requires palette_open <= studio_palette_open_flag()
  requires studio_mode_valid(mode) == 1
  requires playhead_pct >= 0.0
  requires playhead_pct <= 1.0
  ensures store_int_get(result.agent_task) == task_state
  ensures store_int_get(result.palette_open) == palette_open
  ensures store_int_get(result.shell_mode) == mode
  ensures store_float_get(result.timeline_tick) == playhead_pct
  decreases task_state
=
  var rs: StudioReactiveShell
  rs.inv = compose_invalidation_new()
  rs.graph = compose_dep_graph_new()
  rs.cache = compose_cache_new()
  rs.agent_task = store_int_new(reactive_store_id_agent_task(), task_state)
  rs.palette_open = store_int_new(reactive_store_id_palette_open(), palette_open)
  rs.shell_mode = store_int_new(reactive_store_id_shell_mode(), mode)
  rs.timeline_tick = store_float_new(reactive_store_id_timeline_tick(), playhead_pct)
  rs.agent_progress = derived_int_new(0, reactive_store_id_agent_task(), derived_int_from_agent_task_state(task_state))
  return rs

def studio_reactive_shell_hydrate(compose: var StudioShellCompose) -> unit
  requires compose.layout.viewport_w > 0.0
  requires studio_mode_valid(compose.mode) == 1
  ensures compose.reactive.graph.agent_dirty == 0
  ensures compose.reactive.graph.palette_dirty == 0
  decreases compose.mode
=
  compose.reactive = studio_reactive_shell_new(compose.agent.task_state, compose.palette.is_open, compose.mode, compose.timeline.playhead_pct)

def studio_reactive_resync_agent_task(compose: var StudioShellCompose, task_state: int) -> unit
  requires compose.layout.viewport_w > 0.0
  requires task_state >= studio_agent_task_idle()
  requires task_state <= studio_agent_task_done()
  ensures store_int_get(compose.reactive.agent_task) == task_state
  decreases task_state
=
  store_int_set_with_deps(compose.reactive.agent_task, task_state, compose.reactive.inv, compose.reactive.graph)

def studio_reactive_resync_palette(compose: var StudioShellCompose) -> unit
  requires compose.layout.viewport_w > 0.0
  requires compose.palette.is_open >= studio_palette_closed_flag()
  requires compose.palette.is_open <= studio_palette_open_flag()
  ensures store_int_get(compose.reactive.palette_open) == compose.palette.is_open
  decreases compose.palette.is_open
=
  var pal: int = compose.palette.is_open
  store_int_set_with_deps(compose.reactive.palette_open, pal, compose.reactive.inv, compose.reactive.graph)

def studio_reactive_resync_mode(compose: var StudioShellCompose, mode: int) -> unit
  requires compose.layout.viewport_w > 0.0
  requires studio_mode_valid(mode) == 1
  ensures store_int_get(compose.reactive.shell_mode) == mode
  decreases mode
=
  store_int_set_with_deps(compose.reactive.shell_mode, mode, compose.reactive.inv, compose.reactive.graph)

def studio_reactive_resync_timeline_playhead(compose: var StudioShellCompose, playhead_pct: float) -> unit
  requires compose.layout.viewport_w > 0.0
  requires playhead_pct >= 0.0
  requires playhead_pct <= 1.0
  ensures store_float_get(compose.reactive.timeline_tick) == playhead_pct
  decreases 0
=
  store_float_set_with_deps(compose.reactive.timeline_tick, playhead_pct, compose.reactive.inv, compose.reactive.graph)

def studio_reactive_flush_palette(compose: var StudioShellCompose) -> unit
  requires compose.layout.viewport_w > 0.0
  ensures compose_dep_region_is_dirty(compose.reactive.graph, compose_region_id_palette()) == 0
  decreases 0
=
  var gen: int = compose.reactive.palette_open.generation
  if compose_cache_should_recompose(compose.reactive.cache, compose.reactive.graph, compose_region_id_palette(), gen) != 1:
    compose_cache_note_skipped(compose.reactive.cache, compose_region_id_palette())
    return
  var pal: int = store_int_get(compose.reactive.palette_open)
  compose.palette = studio_compose_palette(compose.layout.viewport_w, compose.layout.viewport_h, pal)
  compose.panel.palette_open = pal
  compose_dep_clear_region(compose.reactive.graph, compose_region_id_palette())
  store_int_clear_dirty(compose.reactive.palette_open, compose.reactive.inv)
  compose_cache_note_recomposed(compose.reactive.cache, compose_region_id_palette(), gen)
  if compose.widget_tree_active == 1:
    studio_shell_sync_widget_tree_from_reactive(compose)

def studio_reactive_flush_timeline(compose: var StudioShellCompose) -> unit
  requires compose.layout.viewport_w > 0.0
  ensures compose_dep_region_is_dirty(compose.reactive.graph, compose_region_id_timeline()) == 0
  decreases 0
=
  var gen: int = compose.reactive.timeline_tick.generation
  if compose_cache_should_recompose(compose.reactive.cache, compose.reactive.graph, compose_region_id_timeline(), gen) != 1:
    compose_cache_note_skipped(compose.reactive.cache, compose_region_id_timeline())
    return
  var pct: float = store_float_get(compose.reactive.timeline_tick)
  compose.timeline.playhead_pct = pct
  compose.timeline.playhead_rect = studio_timeline_playhead_rect_at(compose.timeline.track_rect.x, compose.timeline.track_rect.y, compose.timeline.track_rect.w, compose.timeline.track_rect.h, pct)
  compose_dep_clear_region(compose.reactive.graph, compose_region_id_timeline())
  compose.reactive.timeline_tick.dirty = 0
  compose_cache_note_recomposed(compose.reactive.cache, compose_region_id_timeline(), gen)
  if compose.widget_tree_active == 1:
    studio_shell_sync_widget_tree_from_reactive(compose)

def studio_reactive_flush_mode_regions(compose: var StudioShellCompose) -> unit
  requires compose.layout.viewport_w > 0.0
  requires studio_mode_valid(compose.mode) == 1
  ensures store_int_get(compose.reactive.shell_mode) == compose.mode
  decreases compose.mode
=
  var mode_gen: int = compose.reactive.shell_mode.generation
  if compose_cache_should_recompose(compose.reactive.cache, compose.reactive.graph, compose_region_id_dock(), mode_gen) == 1:
    compose_dep_clear_region(compose.reactive.graph, compose_region_id_dock())
    compose_cache_note_recomposed(compose.reactive.cache, compose_region_id_dock(), mode_gen)
  if compose_cache_should_recompose(compose.reactive.cache, compose.reactive.graph, compose_region_id_dock(), mode_gen) == 0:
    compose_cache_note_skipped(compose.reactive.cache, compose_region_id_dock())
  if compose_cache_should_recompose(compose.reactive.cache, compose.reactive.graph, compose_region_id_inspector(), mode_gen) == 1:
    compose_dep_clear_region(compose.reactive.graph, compose_region_id_inspector())
    compose_cache_note_recomposed(compose.reactive.cache, compose_region_id_inspector(), mode_gen)
  if compose_cache_should_recompose(compose.reactive.cache, compose.reactive.graph, compose_region_id_inspector(), mode_gen) == 0:
    compose_cache_note_skipped(compose.reactive.cache, compose_region_id_inspector())
  if compose_cache_should_recompose(compose.reactive.cache, compose.reactive.graph, compose_region_id_viewport_hud(), mode_gen) == 1:
    compose_dep_clear_region(compose.reactive.graph, compose_region_id_viewport_hud())
    compose_cache_note_recomposed(compose.reactive.cache, compose_region_id_viewport_hud(), mode_gen)
  if compose_cache_should_recompose(compose.reactive.cache, compose.reactive.graph, compose_region_id_viewport_hud(), mode_gen) == 0:
    compose_cache_note_skipped(compose.reactive.cache, compose_region_id_viewport_hud())
  store_int_clear_dirty(compose.reactive.shell_mode, compose.reactive.inv)
  if compose.widget_tree_active == 1:
    studio_shell_sync_widget_tree_from_reactive(compose)

def studio_reactive_flush_agent_from_run(compose: var StudioShellCompose, run: StudioAgentRun) -> unit
  requires compose.layout.viewport_w > 0.0
  requires run.task_state >= studio_agent_task_idle()
  requires run.task_state <= studio_agent_task_done()
  ensures compose.agent.task_state == run.task_state
  ensures compose_dep_region_is_dirty(compose.reactive.graph, compose_region_id_agent()) == 0
  decreases run.task_state
=
  var gen: int = compose.reactive.agent_task.generation
  if compose_cache_should_recompose(compose.reactive.cache, compose.reactive.graph, compose_region_id_agent(), gen) != 1:
    compose_cache_note_skipped(compose.reactive.cache, compose_region_id_agent())
    return
  var ctx: int = run.agent_context_label
  if ctx == studio_agent_context_none():
    ctx = studio_agent_context_for_shell(compose.inspector.has_selection, run.task_state)
  var tool: StudioAgentToolRequest = studio_agent_tool_request_for_run(run)
  compose.agent = studio_compose_agent_chrome_with_tool(compose.layout, run.task_state, ctx, tool)
  if run.task_state == studio_agent_task_running():
    compose.agent.progress = studio_compose_agent_progress_run(run, compose.agent.status_rect)
  if run.task_state == studio_agent_task_done():
    compose.agent.progress = studio_compose_agent_progress_run(run, compose.agent.status_rect)
  if run.task_state == studio_agent_task_idle():
    if compose.mode == studio_mode_agent():
      studio_shell_apply_mode(compose, studio_mode_author())
  if run.task_state == studio_agent_task_done():
    studio_shell_apply_mode(compose, studio_mode_author())
  derived_int_sync_agent_progress(compose.reactive.agent_progress, compose.reactive.agent_task, compose.reactive.inv)
  compose_dep_clear_region(compose.reactive.graph, compose_region_id_agent())
  store_int_clear_dirty(compose.reactive.agent_task, compose.reactive.inv)
  compose_cache_note_recomposed(compose.reactive.cache, compose_region_id_agent(), gen)
  if compose.widget_tree_active == 1:
    studio_shell_sync_widget_tree_from_reactive(compose)

def studio_reactive_begin_flush_frame(compose: var StudioShellCompose) -> unit
  requires compose.layout.viewport_w > 0.0
  ensures compose.reactive.cache.recompose_count == 0
  ensures compose.reactive.cache.skip_count == 0
  decreases 0
=
  compose_cache_begin_frame(compose.reactive.cache)

