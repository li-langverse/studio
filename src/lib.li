# Phase 5 (wsg-w5-perf-budgets) — viewport/UI perf budgets (PH-UX gates, release notes).
def studio_perf_budgets_version() -> int
  requires true
  ensures result == 1
  decreases 0
=
  return 1

def studio_viewport_fps_budget() -> float
  requires true
  ensures result == 60.0
  decreases 0
=
  return 60.0

def studio_panel_switch_ms_budget() -> float
  requires true
  ensures result == 100.0
  decreases 0
=
  return 100.0

def studio_load_ms_budget() -> float
  requires true
  ensures result == 2000.0
  decreases 0
=
  return 2000.0

def studio_memory_warn_peak_mib_budget() -> float
  requires true
  ensures result == 512.0
  decreases 0
=
  return 512.0

def studio_perf_budgets_smoke() -> int
  requires true
  ensures result >= 0
  ensures result <= 8
  decreases 0
=
  if studio_perf_budgets_version() != 1:
    return 1
  if studio_viewport_fps_budget() != 60.0:
    return 2
  if studio_panel_switch_ms_budget() != 100.0:
    return 3
  if studio_load_ms_budget() != 2000.0:
    return 4
  if studio_memory_warn_peak_mib_budget() != 512.0:
    return 5
  if render_viewport_fps_target() != studio_viewport_fps_budget():
