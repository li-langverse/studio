# Phase 4 (wsg-w4-present-loop) — PaintFrame → Li UI rasterizer (CPU or wgpu) before host blit.
def studio_shell_present_raster_pass(shell_w: float, shell_h: float, frame: PaintFrame, profile_id: int) -> RenderUiRasterResult raises IO
  requires shell_w >= 0.0
  requires shell_h >= 0.0
  requires studio_profile_id_valid(profile_id) == 1
  requires frame.cmd_count >= 0
  ensures result.cmd_count == frame.cmd_count
  decreases frame.cmd_count
=
  if lig_present_host_active() == 1:
    return render_ui_raster_pass(shell_w, shell_h, frame, profile_id)
  return render_ui_raster_pass_pure(shell_w, shell_h, frame, profile_id)

def studio_shell_present_raster_and_blit(compose: StudioShellCompose, frame: PaintFrame, profile_id: int, frame_id: int) -> int raises IO
  requires studio_profile_id_valid(profile_id) == 1
  requires compose.layout.viewport_w > 0.0
  requires compose.layout.viewport_h > 0.0
  requires frame_id >= 0
  requires frame_id <= 2
  requires frame.cmd_count >= 0
  ensures result >= 0
  decreases frame_id
=
  var shell_w: float = compose.layout.viewport_w
  var shell_h: float = compose.layout.viewport_h
  var raster: RenderUiRasterResult = studio_shell_present_raster_pass(shell_w, shell_h, frame, profile_id)
  if frame.cmd_count > 0:
    if render_ui_raster_result_ok(raster) != 1:
      return 40 + frame_id
  if lig_present_host_active() != 1:
    return 0
  var vp: ViewportRegion = gui_viewport_region_from_layout(compose.layout)
  var blit_fail_code: int = 52 + frame_id
  if lig_present_wgpu_readback_active() == 1:
    blit_fail_code = 54
    var draw_list: RenderDrawList = render_draw_list_new()
    render_draw_list_push_clear(draw_list, 0.05, 0.07, 0.1)
    var draw_mat: RenderPbrLiteMaterial = render_pbr_lite_material_default()
    render_draw_list_push_mesh(draw_list, 1, draw_mat)
    render_draw_list_push_particles(draw_list, 1000, draw_mat)
    if render_draw_list_submit(vp, draw_list, profile_id) != 1:
      return 54 + frame_id
  if lig_present_blit_paint_summary(vp.w, vp.h, profile_id, frame.cmd_count) != 1:
    return blit_fail_code
  var _presented: LigPresentFrame = studio_shell_host_present_loop_tick(vp.w, vp.h, frame_id)
  if _presented.presented != 1:
    return 50 + frame_id
  if _presented.native_pixels != 1:
    return 51 + frame_id
  if lig_native_pixel_source_honest_product(_presented.native_pixel_source) != 1:
    if lig_present_wgpu_readback_active() == 1:
      return 55
    return 53 + frame_id
  var expected_src: int = studio_native_pixel_source_expected()
  if _presented.native_pixel_source != expected_src:
    if lig_present_wgpu_readback_active() == 1:
      return 55
    return 53 + frame_id
  return 0

def studio_vertical_demo_frame(profile_id: int, frame_id: int) -> int raises IO
  requires studio_profile_id_valid(profile_id) == 1
  requires frame_id >= 0
  requires frame_id <= 2
  ensures result >= 0
  decreases frame_id
=
  var compose: StudioShellCompose = studio_vertical_demo_compose(profile_id, frame_id, 1)
  var input: InputState = studio_shell_input_from_host()
  if frame_id == 2:
    if input.key_cmd_k == 0:
      if input.key_escape == 0:
        if input.key_digit == 0:
          input.key_cmd_k = 1
  var _key_action: int = studio_shell_handle_host_key(compose, input)
  studio_shell_sync_hover(compose, input)
  var has_sel: int = compose.inspector.has_selection
  var scene_n: int = compose.scene_entity_count
  var task_st: int = compose.agent.task_state
  var pal_op: int = compose.palette.is_open
  var ctx_lbl: int = compose.agent.agent_context_label
  var play_pct: float = compose.timeline.playhead_pct
  var frame: PaintFrame = paint_frame_new()
  studio_paint_shell_chrome(frame, compose)
  var topbar: Rect = compose.layout.topbar
  studio_paint_topbar_profile(frame, topbar, profile_id)
  var present_rc: int = studio_shell_present_raster_and_blit(compose, frame, profile_id, frame_id)
  if present_rc != 0:
    return present_rc
  if frame_id == 0:
    return 0
  if frame_id == 1:
    if play_pct != studio_timeline_playhead_pct():
      return 21
    return 0
  return 0

def studio_shell_demo_frame(frame_id: int) -> int raises IO
  requires frame_id >= 0
  requires frame_id <= 2
  ensures result >= 0
  decreases frame_id
=
  var profile_id: int = studio_demo_profile_from_env()
  return studio_vertical_demo_frame(profile_id, frame_id)

def studio_shell_demo_frame_budget() -> int raises IO
  requires true
  ensures result >= 1
  ensures result <= 64
  decreases 0
=
  return li_rt_studio_demo_frames_from_env()

def studio_shell_demo_loop_tick_start() -> int raises IO
  requires true
  ensures result >= 0
  decreases 0
=
  return li_rt_studio_demo_loop_tick_from_env()

def studio_shell_demo_pattern_index(loop_tick: int) -> int
  requires loop_tick >= 0
  ensures result >= 0
  ensures result <= 2
  decreases loop_tick
=
  if loop_tick <= 0:
    return 0
  if loop_tick == 1:
    return 1
  if loop_tick == 2:
    return 2
  var prev: int = loop_tick - 3
  return studio_shell_demo_pattern_index(prev)

def studio_shell_demo_present_loop_rec(i: int, budget: int, base_tick: int) -> int raises IO
  requires i >= 0
  requires budget >= 1
  requires budget <= 64
  requires base_tick >= 0
  requires i <= budget
  ensures result >= 0
  decreases budget - i
=
  if i >= budget:
    return 0
  var pattern: int = studio_shell_demo_pattern_index(base_tick + i)
  var r: int = studio_shell_demo_frame(pattern)
  if r != 0:
    return 100 + i * 10 + r
  return studio_shell_demo_present_loop_rec(i + 1, budget, base_tick)

def studio_shell_demo_present_loop() -> int raises IO
  requires true
  ensures result >= 0
  decreases 0
=
  var budget: int = studio_shell_demo_frame_budget()
  var base_tick: int = studio_shell_demo_loop_tick_start()
  return studio_shell_demo_present_loop_rec(0, budget, base_tick)

# WP-UX-09 — probe-shaped mock for lic check smokes (matches studio_shell_input_probe JSON).
def studio_shell_input_probe_mock_cmd_k_digit(digit: int) -> InputState
  requires digit >= 0
  requires digit <= 5
  ensures result.key_cmd_k == 1
  ensures result.key_digit == digit
  ensures result.key_escape == 0
  decreases digit
=
  var s: InputState = input_default()
  s.key_cmd_k = 1
  s.key_digit = digit
  return s

def studio_shell_input_probe_mock_escape() -> InputState
  requires true
  ensures result.key_escape == 1
  ensures result.key_cmd_k == 0
  ensures result.key_digit == 0
  decreases 0
=
  var s: InputState = input_default()
  s.key_escape = 1
  return s

# WP-UX-09 — SDL/mock InputState → studio_handle_studio_key on live compose (host bridge).
def studio_shell_handle_host_key(compose: var StudioShellCompose, input: InputState) -> int
  requires compose.layout.viewport_w > 0.0
  requires compose.layout.viewport_h > 0.0
  requires compose.panel.switch_count >= 0
  requires input.key_escape >= 0
  requires input.key_escape <= 1
  requires input.key_cmd_k >= 0
  requires input.key_cmd_k <= 1
  requires input.key_digit >= 0
  requires input.key_digit <= 5
  ensures result >= studio_key_action_none()
  ensures result <= studio_key_action_palette_exec()
  decreases input.key_digit
=
  return studio_handle_studio_key(compose, input)

# PH-HW WP3 — InputState from studio-shell-input-bridge runtime (SDL or mock).
def studio_shell_input_from_host() -> InputState raises IO
  requires true
  ensures result.pointer_down >= 0
  ensures result.pointer_down <= 1
  ensures result.key_escape >= 0
  ensures result.key_escape <= 1
  ensures result.key_cmd_k >= 0
  ensures result.key_cmd_k <= 1
  ensures result.key_digit >= 0
  ensures result.key_digit <= 5
  decreases 0
=
  var s: InputState = input_default()
  s.pointer_down = li_rt_studio_shell_input_pointer_down()
  s.pointer_x = li_rt_studio_shell_input_pointer_x()
  s.pointer_y = li_rt_studio_shell_input_pointer_y()
  s.key_escape = li_rt_studio_shell_input_key_escape()
  s.key_cmd_k = li_rt_studio_shell_input_key_cmd_k()
  s.key_digit = li_rt_studio_shell_input_key_digit()
  return s

def studio_shell_host_present_loop_tick(vp_w: float, vp_h: float, frame_id: int) -> LigPresentFrame raises IO
  requires vp_w >= 0.0
  requires vp_h >= 0.0
  requires frame_id >= 0
  ensures result.frame_id >= 0
  decreases frame_id
=
  var iw: int = 1280
  var ih: int = 720
  if vp_w < 64.0:
    iw = 0
  if vp_h < 36.0:
    ih = 0
  var _host: int = li_rt_studio_host_present_tick(iw, ih)
  var swap: LigSwapchain = lig_present_swapchain_create(vp_w, vp_h)
  return lig_present_frame(swap, frame_id)

def studio_shell_host_frame(compose: var StudioShellCompose, frame_id: int) -> int raises IO
  requires frame_id >= 0
  requires frame_id <= 4
  ensures result >= 0
  decreases frame_id
=
  var input: InputState = studio_shell_input_from_host()
  var _action: int = studio_shell_handle_host_key(compose, input)
  studio_viewport_error_sync_render(compose)
  var _vp_err: int = studio_shell_handle_viewport_error_pointer(compose, input)
  studio_shell_sync_hover(compose, input)
  var vp: ViewportRegion = gui_viewport_region_from_layout(compose.layout)
  var _presented: LigPresentFrame = studio_shell_host_present_loop_tick(vp.w, vp.h, frame_id)
  if _presented.presented != 1:
    return 20
  var frame: PaintFrame = paint_frame_new()
  studio_paint_shell_chrome(frame, compose)
  if frame.cmd_count < 1:
    return 30
  return 0

# Plan-loop §6 / §11 — composable vertical DoD (honest slice; full ship criteria remain in master plan).
def studio_vertical_dod_game_composable_ok() -> int raises Alloc, IO
  requires true
  ensures result >= 0
  ensures result <= 1
  decreases 0
=
  var cfg: StudioProjectConfig = studio_project_config_new(studio_profile_game())
  var sess: SimSessionStub = sim_session_stub_default()
  studio_apply_config_to_sim(cfg, sess)
  if studio_game_step_hook(sess, 0.016) != sim_status_ok():
    return 0
  if sess.game_physics_steps < 1:
    return 0
  if sess.game_pz >= 0.0:
    return 0
  if studio_game_world_checkpoint_roundtrip(sess) != 1:
    return 0
  if lig_native_pixel_source_honest_product(lig_native_pixel_source_wgpu_readback()) != 1:
    return 0
  return 1

def studio_vertical_dod_sim_rl_composable_ok() -> int
  requires true
  ensures result >= 0
  ensures result <= 1
  decreases 0
=
  var cfg: StudioProjectConfig = studio_project_config_new(studio_profile_sim_rl())
  var sess: SimSessionStub = sim_session_stub_default()
  studio_apply_config_to_sim(cfg, sess)
  if studio_sim_rl_step_hook(sess, 0.02) != sim_status_ok():
    return 0
  var psz: int = sim_rl_env_pool_size_default()
  if sess.env_pool_size != psz:
    return 0
  if sess.env_pool_steps_emitted != psz:
    return 0
  if sim_env_obs_dim() != 8:
    return 0
  var obs: EnvStepResult = env_obs_from_session(sess)
  if obs.obs1 != sess.last_dt:
    return 0
  if obs.env_index != psz - 1:
    return 0
  return 1

