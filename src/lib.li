def studio_agent_run_retry(run: StudioAgentRun) -> StudioAgentRun
  requires run.task_state >= studio_agent_task_idle()
  requires run.task_state <= studio_agent_task_done()
  requires run.agent_context_label >= studio_agent_context_none()
