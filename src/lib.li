def studio_profile_sim_drug_design() -> int
  requires true
  ensures result == 7
  decreases 0
=
  return 7

def studio_profile_id_valid(profile_id: int) -> int
  requires true
  ensures result >= 0
  ensures result <= 1
  decreases profile_id
=
  if profile_id == studio_profile_unknown():
    return 1
  if profile_id == studio_profile_game():
    return 1
  if profile_id == studio_profile_sim_rl():
    return 1
  if profile_id == studio_profile_sim_automotive():
    return 1
  if profile_id == studio_profile_sim_robotics():
    return 1
  if profile_id == studio_profile_sim_additive():
    return 1
  if profile_id == studio_profile_sim_scientific():
    return 1
  if profile_id == studio_profile_sim_drug_design():
    return 1
  return 0

def studio_profile_from_name(name: str) raises IO, Alloc -> int
  requires true
  ensures studio_profile_id_valid(result) == 1
  decreases 0
=
  return li_rt_studio_profile_from_name(name)

def studio_parse_toml_profile_line(line: str) raises IO, Alloc -> int
  requires true
  ensures studio_profile_id_valid(result) == 1
  decreases 0
=
