# PKG-li-studio — World Studio shell API (PH-GD-1).

type StudioProject = object
  public name: int
  public playing: int
  public viewport_ticks: int
  public outliner_count: int

def li_studio_version() -> int
  requires true
  ensures result == 17
  decreases 0
=
  return 17

def studio_project_new() -> StudioProject
  requires true
  ensures result.playing == 0
  ensures result.viewport_ticks == 0
  ensures result.outliner_count == 0
  decreases 0
=
  var p: StudioProject
  p.name = 0
  p.playing = 0
  p.viewport_ticks = 0
  p.outliner_count = 0
  return p

def studio_play(project: StudioProject) -> unit
  requires true
  ensures project.playing == 1
  decreases 0
=
  project.playing = 1

def studio_pause(project: StudioProject) -> unit
  requires true
  ensures project.playing == 0
  decreases 0
=
  project.playing = 0

# Short names for authors and agents.
def start_playing(project: StudioProject) -> unit
  requires true
  decreases 0
=
  studio_play(project)

def stop_playing(project: StudioProject) -> unit
  requires true
  decreases 0
=
  studio_pause(project)

def tick_viewport(project: StudioProject) -> unit
  requires project.playing == 1
  decreases project.viewport_ticks
=
  studio_viewport_tick(project)

def studio_viewport_tick(project: StudioProject) -> unit
  requires project.playing == 1
  ensures project.viewport_ticks >= 1
  decreases project.viewport_ticks
=
  project.viewport_ticks = project.viewport_ticks + 1

def studio_outliner_set_count(project: StudioProject, count: int) -> unit
  requires count >= 0
  ensures project.outliner_count == count
  decreases count
=
  project.outliner_count = count

# PH-DRUG / PH-UX — adaptive panels (studio.adaptive path TBD).
def studio_adaptive_panel_for_stage(stage_id: int) -> int
  requires stage_id >= 0
  requires stage_id <= 3
  ensures result == stage_id
  decreases stage_id
=
  return stage_id

def studio_adaptive_layout_reset(project: StudioProject) -> unit
  requires true
  ensures project.playing == project.playing
  decreases 0
=
  project.name = project.name

# PH-PUB-0 — publication export hooks (studio.publish path TBD).
def studio_publish_figure_stub(dpi: int) -> int
  requires dpi >= 72
  requires dpi <= 600
  ensures result == dpi
  decreases dpi
=
  return dpi

def studio_publish_bundle_stub(file_count: int) -> int
  requires file_count > 0
  ensures result == file_count
  decreases file_count
=
  return file_count

# PH-PUB — publication bundle with content hash (repro bundles).
type PublishBundle = object
  public file_count: int
  public content_hash: int
  public dpi: int

def studio_publish_bundle_hash_stub(file_count: int, dpi: int) -> PublishBundle
  requires file_count > 0
  requires dpi >= 72
  requires dpi <= 600
  ensures result.file_count == file_count
  ensures result.dpi == dpi
  ensures result.content_hash >= 0
  decreases file_count
=
  var b: PublishBundle
  b.file_count = file_count
  b.dpi = dpi
  b.content_hash = file_count * 997 + dpi
  return b

def studio_pub_bioeng_bundle_stub(scorecard_beats: int, file_count: int) -> int
  requires scorecard_beats >= 0
  requires scorecard_beats <= 1
  requires file_count > 0
  ensures result >= 0
  decreases file_count
=
  var b: PublishBundle = studio_publish_bundle_hash_stub(file_count, 300)
  return b.content_hash + scorecard_beats

def studio_publish_smoke() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var b: PublishBundle = studio_publish_bundle_hash_stub(3, 300)
  if b.content_hash != 3291:
    return 1
  if studio_publish_figure_stub(b.dpi) != 300:
    return 2
  return 0

def publish_field_checkpoint(manifest_hash: int, file_count: int) -> int
  requires manifest_hash >= 0
  requires file_count > 0
  ensures result > 0
  decreases file_count
=
  var b: PublishBundle = studio_publish_bundle_hash_stub(file_count, 300)
  return b.content_hash + manifest_hash

def publish_repro(manifest_hash: int, file_count: int) -> int
  requires manifest_hash >= 0
  requires file_count > 0
  decreases file_count
=
  return publish_field_checkpoint(manifest_hash, file_count)

def studio_game_frame_tag(realm_id: int, width: int, height: int) -> int
  requires realm_id >= 0
  requires width > 0
  requires height > 0
  ensures result > 0
  decreases width
=
  return realm_id + width + height + 3000

def studio_sim_frame_tag(field_id: int, steps: int) -> int
  requires field_id >= 0
  requires steps > 0
  ensures result > 0
  decreases steps
=
  return field_id + steps + 4000

# One call: play + game frame tag + sim frame tag (agents copy this first).
def run_play_session(
    project: StudioProject,
    realm_id: int,
    width: int,
    height: int,
    field_id: int,
    sim_steps: int) -> int
  requires realm_id >= 0
  requires width > 0
  requires height > 0
  requires field_id >= 0
  requires sim_steps > 0
  ensures result > 0
  decreases width
=
  start_playing(project)
  tick_viewport(project)
  var tag: int = studio_game_frame_tag(realm_id, width, height)
  tag = tag + studio_sim_frame_tag(field_id, sim_steps)
  return tag

def run_play_session_smoke() -> int
  requires true
  ensures result == 0
  decreases 0
=
  var p: StudioProject = studio_project_new()
  if run_play_session(p, 1, 1280, 720, 0, 4) < 7000:
    return 1
  return 0

def studio_play_mode_smoke() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if run_play_session_smoke() != 0:
    return 1
  if publish_repro(42, 2) <= 0:
    return 2
  return 0

