
import gui
import ui

# li-studio — compose dock + timeline + inspector + agent chrome (PH-UX-05/06/07).

# PH-SIM / UX-05 — World Studio runtime profiles (world-studio-vision §5).
extern proc li_rt_studio_profile_from_name(name: str) -> int
  requires true
  ensures result >= 0
  decreases 0

extern proc li_rt_studio_parse_toml_profile_line(line: str) -> int
  requires true
  ensures result >= 0
  decreases 0

