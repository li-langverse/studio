def studio_shell_widget_tree_params(compose: StudioShellCompose) -> ShellWidgetTreeParams
  requires compose.layout.viewport_w > 0.0
  requires compose.layout.inspector.h > gui_inspector_pilot_header_h_px()
  ensures result.has_selection == compose.inspector.has_selection
  ensures result.active_dock_slot == compose.dock.active_slot
  decreases compose.dock.active_slot
=
  return shell_widget_tree_params_from_stores(compose.reactive.agent_task, compose.reactive.palette_open, compose.reactive.shell_mode, compose.reactive.timeline_tick, compose.dock.active_slot, compose.inspector.has_selection, compose.scene_entity_count)

def studio_shell_build_widget_tree(compose: StudioShellCompose) -> ShellWidgetTree
  requires compose.layout.viewport_w > 0.0
  requires compose.layout.inspector.w > 0.0
  requires compose.layout.inspector.h > gui_inspector_pilot_header_h_px()
  ensures result.region_count == shell_widget_tree_region_count()
  decreases compose.dock.active_slot
=
  var params: ShellWidgetTreeParams = studio_shell_widget_tree_params(compose)
  return shell_widget_tree_new(params, compose.layout.inspector.w, compose.layout.inspector.h)

def studio_shell_layout_widget_tree(compose: var StudioShellCompose) -> unit
  requires compose.layout.viewport_w > 0.0
  requires compose.layout.inspector.h > gui_inspector_pilot_header_h_px()
  ensures compose.widget_tree_layout.region_count == shell_widget_tree_region_count()
  decreases compose.dock.active_slot
=
  compose.widget_tree = studio_shell_build_widget_tree(compose)
  compose.widget_tree_layout = shell_widget_tree_layout(compose.widget_tree, compose.layout)
  compose.widget_tree_active = 1

def studio_shell_attach_widget_tree(compose: var StudioShellCompose) -> unit
  requires compose.layout.viewport_w > 0.0
  ensures compose.widget_tree_active == 1
  ensures shell_widget_tree_all_regions_laid_out(compose.widget_tree_layout) == 1
  ensures compose.hover.dock_slot == studio_hover_dock_none()
  decreases compose.dock.active_slot
=
  compose.hover = studio_shell_hover_new()
  studio_shell_layout_widget_tree(compose)

def studio_shell_sync_widget_tree_from_reactive(compose: var StudioShellCompose) -> unit
  requires compose.layout.viewport_w > 0.0
  requires compose.widget_tree_active == 1
  ensures compose.widget_tree.params.agent_task_state == store_int_get(compose.reactive.agent_task)
  ensures compose.widget_tree.params.palette_open == store_int_get(compose.reactive.palette_open)
  ensures compose.widget_tree.params.playhead_pct == store_float_get(compose.reactive.timeline_tick)
  decreases compose.reactive.agent_task.generation
=
  var params: ShellWidgetTreeParams = studio_shell_widget_tree_params(compose)
  compose.widget_tree = shell_widget_tree_new(params, compose.layout.inspector.w, compose.layout.inspector.h)
  compose.widget_tree_layout = shell_widget_tree_layout(compose.widget_tree, compose.layout)

