import studio
import ui

def main() -> int raises IO
  requires true
  ensures result == 0
  decreases 0
=
  if li_std_studio_version() < 10:
    return 1
  if li_std_gui_version() < 1:
    return 2
  if li_std_ui_studio_composables_version() < 3:
    return 3
  var loop_rc: int = studio_shell_demo_present_loop()
  if loop_rc != 0:
    return 4
  return 0
