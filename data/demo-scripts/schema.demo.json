{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "World Studio DemoScript",
  "type": "object",
  "required": ["name", "profile", "size", "fps", "native_only", "steps"],
  "properties": {
    "name": {"type": "string"},
    "profile": {"type": "string"},
    "size": {"type": "array", "items": {"type": "integer"}, "minItems": 2, "maxItems": 2},
    "fps": {"type": "integer", "minimum": 1},
    "hold_ms_default": {"type": "integer", "minimum": 0},
    "native_only": {"type": "boolean"},
    "description": {"type": "string"},
    "aimd": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "steps": {"type": "integer", "minimum": 64},
        "temperature_k": {"type": "number"},
        "potential_v": {"type": "number"},
        "algo_id": {"type": "integer"},
        "algo_name": {"type": "string"},
        "headless_batch": {"type": "boolean"},
        "show_steps_in_ui": {"type": "boolean"}
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "wait_ms": {"type": "integer"},
          "wait_frames": {"type": "integer"},
          "ui_key": {"type": "string"},
          "ui_click": {"type": "string"},
          "ui_set_value": {"type": "object"},
          "mcp_configure": {"type": "string"},
          "aimd_run_batch": {"type": "boolean"},
          "capture": {"type": "string", "enum": ["frame", "final_frame"]}
        }
      }
    }
  }
}
