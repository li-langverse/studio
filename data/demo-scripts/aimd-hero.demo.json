{
  "$schema": "./schema.demo.json",
  "name": "aimd-hero",
  "profile": "sim_scientific",
  "size": [1280, 720],
  "fps": 30,
  "hold_ms_default": 600,
  "native_only": true,
  "steps": [
    {"wait_ms": 400, "ui_click": "shell.agent.input"},
    {"wait_ms": 200},
    {"capture": "agent_panel"},
    {"wait_ms": 800, "ui_click": "shell.agent.send_button"},
    {"wait_ms": 1200, "capture": "agent_panel"},
    {"wait_ms": 400, "capture": "final_frame"}
  ]
}
