pen\n  var ctx_lbl: int = compose.agent.agent_context_label\n  var play_pct: float = compose.timeline.playhead_pct\n  var frame: PaintFrame = paint_frame_new()\n  studio_paint_shell_chrome(frame, compose)\n  var topbar: Rect = compose.layout.topbar\n  studio_paint_topbar_profile(frame, topbar, profile_id)\n  if lig_present_host_active() == 1:\n    var vp: ViewportRegion = gui_viewport_region_from_layout(compose.layout)\n    if lig_present_blit_paint_summary(vp.w, vp.h, profile_id, frame.cmd_count) != 1:\n      return 52 + frame_id\n    var _presented: LigPresentFrame = studio_shell_host_present_loop_tick(vp.w, vp.h, frame_id)\n    if _presented.presented != 1:\n      return 50 + frame_id\n    if _presented.native_pixels != 1:\n      return 51 + frame_id\n    if _presented.native_pixel_source != lig_native_pixel_source_paint_blit():\n      return 53 + frame_id\n  if frame_id == 0:\n    return 0\n  if frame_id == 1:\n    if play_pct != studio_timeline_playhead_pct():\n      return 21\n    return 0\n  return 0\n\ndef studio_shell_demo_frame(frame_id: int) -> int raises IO\n  requires frame_id >= 0\n  requires frame_id <= 2\n  ensures result >= 0\n  decreases frame_id\n=\n  var profile_id: int = studio_demo_profile_from_env()\n  return studio_vertical_demo_frame(profile_id, frame_id)\n\ndef studio_shell_demo_frame_budget() -> int raises IO\n  requires true\n  ensures result >= 1\n  ensures result <= 64\n  decreases 0\n=\n  return li_rt_studio_demo_frames_from_env()\n\ndef studio_shell_demo_loop_tick_start() -> int raises IO\n  requires true\n  ensures result >= 0\n  decreases 0\n=\n  return li_rt_studio_demo_loop_tick_from_env()\n\ndef studio_shell_demo_pattern_index(loop_tick: int) -> int\n  requires loop_tick >= 0\n  ensures result >= 0\n  ensures result <= 2",
