              "content": "    contract0 = sim_contract_sim_automotive()\n  if sid == 4:\n    contract0 = sim_contract_sim_robotics()\n  if sid == 5:\n    contract0 = sim_contract_sim_additive()\n  if sid == 6:\n    contract0 = sim_contract_sim_scientific()\n  if sid == 7:\n    contract0 = sim_contract_sim_drug_design()\n  sim_out.sim_contract_id = contract0\n  var detail0: int = output_detail_summary()\n  if sid == 6:\n    detail0 = output_detail_debug()\n  if sid == 7:\n    detail0 = output_detail_debug()\n  if sid >= 2:\n    if sid <= 5:\n      detail0 = output_detail_fields()\n  sim_out.output_detail = detail0\n\n# PH-SIM SIM-3 partial â€” RL env pool stub batches sim_step across parallel env slots.\ndef sim_rl_env_pool_size_default() -> int\n  requires true\n  ensures result == 4\n  decreases 0\n=\n  return 4\n\ntype EnvPoolStub = object\n  public pool_size: int\n  public steps_emitted: int\n  public total_reward: float\n\ntype EnvStepResult = object\n  public obs0: float\n  public obs1: float\n  public obs2: float\n  public obs3: float\n  public obs4: float\n  public obs5: float\n  public obs6: float\n  public obs7: float\n  public act0: float\n  public act1: float\n  public act2: float\n  public act3: float\n  public reward: float\n  public done: int\n  public env_index: int\n\ndef env_pool_stub_default() -> EnvPoolStub\n  requires true\n  ensures result.pool_size == sim_rl_env_pool_size_default()\n  ensures result.steps_emitted == 0\n  ensures result.total_reward == 0.0\n  decreases 0\n=\n  var p: EnvPoolStub\n  p.pool_size = sim_rl_env_pool_size_default()\n  p.steps_emitted = 0\n  p.total_reward = 0.0\n  return p\n\ndef env_tick_as_float(tick: int) -> float\n  requires tick >= 0\n  requires tick <= 32\n  ensures result >= 0.0\n  decreases tick\n=\n  if tick == 0:\n    return 0.0\n  if tick == 1:\n    return 1.0\n  if tick == 2:\n    return 2.0\n  if tick == 3:\n    return 3.0\n  if tick == 4:\n    return 4.0\n  return 5.0\n\ndef env_action_for_index(env_index: int) -> EnvStepResult\n  requires env_index >= 0\n  requires env_index < 32\n  ensures result.env_index == env_index\n  decreases env_index\n=\n  var ei: int = env_index\n  var e1: int = env_index\n  var e2: int = env_index\n  var e3: int = env_index\n  var r: EnvStepResult\n  r.env_index = ei\n  r.act0 = 0.0\n  r.act1 = 0.0\n  r.act2 = 0.0\n  r.act3 = 0.0\n  if e1 == 1:\n    r.act0 = 0.1\n  if e2 == 2:\n    r.act0 = 0.2\n  if e3 == 3:\n    r.act0 = 0.3\n  r.obs0 = 0.0\n  r.obs1 = 0.0\n  r.obs2 = 0.0\n  r.obs3 = 0.0\n  r.obs4 = 0.0\n  r.obs5 = 0.0\n  r.obs6 = 0.0\n  r.obs7 = 0.0\n  r.reward = 0.0\n  r.done = 0\n  return r\n\ndef env_obs_fill_fields(\n    r: var EnvStepResult, tick: int, last_dt: float, env_index: int) -> unit\n  requires tick >= 0\n  requires env_index >= 0\n  requires env_index < 32\n  ensures r.obs1 == last_dt\n  decreases env_index\n=\n  var e1: int = env_index\n  var e2: int = env_index\n  var e3: int = env_index\n  var t_obs: int = tick\n  r.obs0 = env_tick_as_float(t_obs)\n  r.obs1 = last_dt\n  r.obs2 = 0.0\n  if e1 == 1:\n    r.obs2 = 1.0\n  if e2 == 2:\n    r.obs2 = 2.0\n  if e3 == 3:\n    r.obs2 = 3.0\n  r.obs3 = 0.0\n  r.obs4 = 0.0\n  r.obs5 = 0.0\n  r.obs6 = 0.0\n  r.obs7 = 0.0\n\ndef env_reward_for_action(act0: float, env_index: int, tick: int) -> float\n  requires env_index >= 0\n  requires env_index < 32\n  requires tick >= 0\n  ensures result >= -1.0\n  decreases env_index\n=\n  var pen: float = 0.0\n  var e1: int = env_index\n  var e2: int = env_index\n  var e3: int = env_index\n  var t_rew: int = tick\n  if e1 == 1:\n    pen = 0.05\n  if e2 == 2:\n    pen = 0.10\n  if e3 == 3:\n    pen = 0.15\n  return act0 - pen + 0.01 * env_tick_as_float(t_rew)\n\ndef env_step_contract_pre(\n    pool_size: int, tick: int, last_dt: float, env_index: int) -> EnvStepResult\n  requires pool_size > 0\n  requires env_index >= 0\n  requires env_index < pool_size\n  requires tick >= 0\n  ensures result.env_index == env_index\n  ensures result.done == 0\n  decreases env_index\n=\n  var t_obs: int = tick\n  var ei_act: int = env_index\n  var ei_obs: int = env_index\n  var r: EnvStepResult = env_action_for_index(ei_act)\n  env_obs_fill_fields(r, t_obs, last_dt, ei_obs)\n  r.reward = 0.0\n  r.done = 0\n  return r\n\ndef env_step_contract_post(\n    pre: EnvStepResult, tick: int, last_dt: float, pool_size: int) -> EnvStepResult\n  requires tick >= 0\n  requires pool_size > 0\n  requires pre.env_index >= 0\n  requires pre.env_index < pool_size\n  ensures result.env_index == pre.env_index\n  ensures result.done >= 0\n  ensures result.done <= 1\n  decreases pre.env_index\n=\n  var idx_obs: int = pre.env_index\n  var idx_rew: int = pre.env_index\n  var act0: float = pre.act0\n  var t_obs: int = tick\n  var t_rew: int = tick\n  var t_done: int = tick\n  var r: EnvStepResult = pre\n  env_obs_fill_fields(r, t_obs, last_dt, idx_obs)\n  r.reward = env_reward_for_action(act0, idx_rew, t_rew)\n  r.done = 0\n  if t_done >= pool_size * 8:\n    r.done = 1\n  return r\n\ndef env_pool_stub_step(pool: var EnvPoolStub, session: var SimSessionStub, dt: float) -> int\n  requires pool.pool_size > 0\n  requires pool.pool_size <= 32\n  requires session.tick >= 0\n  requires session.replay_capacity > 0\n  ensures result >= 0\n  ensures result <= 1\n  decreases pool.pool_size\n=\n  if dt <= 0.0:\n    return sim_status_invalid_dt()\n  var i: int = 0\n  while i < pool.pool_size\n    var tick0: int = session.tick\n    var last_dt0: float = session.last_dt\n    var psz: int = pool.pool_size\n    var pre: EnvStepResult = env_step_contract_pre(psz, tick0, last_dt0, i)\n    if sim_step(session, dt) != sim_status_ok():\n      return sim_status_invalid_dt()\n    var tick1: int = session.tick\n    var last_dt1: float = session.last_dt\n    var post: EnvStepResult = env_step_contract_post(pre, tick1, last_dt1, psz)\n    pool.total_reward = pool.total_reward + post.reward\n    pool.steps_emitted = pool.steps_emitted + 1\n    i = i + 1\n  return sim_status_ok()\n\n# PH-SIM SIM-3 â€” batch env pool step on a live session (obs/reward contract + replay).\ndef sim_rl_session_env_pool_step(session: var SimSessionStub, dt: float) -> int\n  requires session.tick >= 0\n  requires session.replay_capacity > 0\n  ensures result >= 0\n  ensures result <= 1\n  decreases session.tick\n=\n  if dt <= 0.0:\n    return sim_status_invalid_dt()\n  var pool: EnvPoolStub = env_pool_stub_default()\n  if env_pool_stub_step(pool, session, dt) != sim_status_ok():\n    return sim_status_invalid_dt()\n  if pool.steps_emitted != pool.pool_size:\n    return sim_status_invalid_dt()\n  if pool.total_reward <= 0.0:\n    return sim_status_invalid_dt()\n  if sim_session_replay_last_tick(session) != pool.pool_size:\n    return sim_status_invalid_dt()\n  return sim_status_ok()\n\ndef sim_rl_tick_stub(detail: int) -> int\n  requires detail >= 0\n  requires detail <= 3\n  ensures result >= 0\n  ensures result <= 1\n  decreases 0\n=\n  var sess: SimSessionStub = sim_session_stub_default()\n  sim_session_apply_studio_profile(2, sess)\n  var dt: float = 0.02\n  if detail == 0:\n    dt = 0.016\n  if sim_rl_session_env_pool_step(sess, dt) != sim_status_ok():\n    return 0\n  return 1\n",
